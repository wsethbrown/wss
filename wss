#!/usr/bin/env bash
set -e

# Whiskey Share Society — Development CLI
# Usage: ./wss [command] [options]   (tip: symlink or alias `wss` to this file)

PROJECT_NAME="Whiskey Share Society"
APP_URL="http://localhost:3000"
TEST_DB_URL="postgresql://wss:password@db:5432/wss_test"

# Run from the repo root regardless of where the script is invoked from.
cd "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1"; }

# Detect the Compose flavor available on this machine.
# Docker Compose v2 ships as the `docker compose` subcommand; v1 was `docker-compose`.
DC=""
detect_compose() {
  if docker compose version >/dev/null 2>&1; then
    DC="docker compose"
  elif command -v docker-compose >/dev/null 2>&1; then
    DC="docker-compose"
  fi
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    log_error "Docker is not installed or not in PATH."; exit 1
  fi
  if ! docker info >/dev/null 2>&1; then
    log_error "Docker daemon is not running. Start Docker Desktop and retry."; exit 1
  fi
  detect_compose
  if [[ -z "$DC" ]]; then
    log_error "Docker Compose not found (need 'docker compose' v2 or 'docker-compose' v1)."; exit 1
  fi
}

check_env_file() {
  if [[ ! -f .env ]]; then
    log_warning ".env not found — OAuth/Stripe will use fallback values."
    log_info "Copy .env.example to .env and fill in your keys."
  fi
}

show_help() {
  cat << EOF
${GREEN}🥃 Whiskey Share Society — Development CLI${NC}

${YELLOW}Usage:${NC} wss <command> [options]

${YELLOW}Lifecycle:${NC}
  ${GREEN}up${NC} / ${GREEN}start${NC}        Start db + redis + web (and Stripe forwarding if the CLI is installed)
  ${GREEN}down${NC} / ${GREEN}stop${NC}       Stop all services
  ${GREEN}restart${NC}           Restart all services
  ${GREEN}status${NC} / ${GREEN}ps${NC}       Show service status
  ${GREEN}build${NC}             Rebuild Docker images
  ${GREEN}setup${NC}             First run: build, start, create/migrate/seed the database
  ${GREEN}clean${NC}             Remove containers + volumes (destructive)

${YELLOW}Working in the app:${NC}
  ${GREEN}logs${NC} [service]    Follow logs (all services, or one: web/db/redis)
  ${GREEN}console${NC} / shell   Rails console in the web container
  ${GREEN}bash${NC}              Bash shell in the web container
  ${GREEN}test${NC} [args]       Run the test suite against the test DB (args pass through to \`rails test\`)
  ${GREEN}db${NC} <migrate|seed|reset|console>

${YELLOW}Examples:${NC}
  wss up                         # start everything
  wss logs web                   # tail the app log
  wss test test/models           # run just the model tests
  wss db reset                   # drop, create, migrate, seed

${BLUE}App:${NC} ${APP_URL}
EOF
}

# --- Stripe webhook forwarding (optional; only if the Stripe CLI is installed) ---
start_stripe_webhooks() {
  command -v stripe >/dev/null 2>&1 || { log_info "Stripe CLI not installed — skipping webhook forwarding."; return 0; }
  if pgrep -f "stripe listen" >/dev/null; then
    log_warning "Stripe webhook forwarding already running."; return 0
  fi
  nohup stripe listen --forward-to ${APP_URL}/webhooks/stripe --skip-verify > stripe-webhooks.log 2>&1 &
  echo $! > .stripe_pid
  sleep 2
  if ps -p "$(cat .stripe_pid)" >/dev/null 2>&1; then
    log_success "Stripe webhook forwarding started (logs: stripe-webhooks.log)."
  else
    log_warning "Stripe webhook forwarding failed to start."
  fi
}
stop_stripe_webhooks() {
  [[ -f .stripe_pid ]] || return 0
  local pid; pid=$(cat .stripe_pid)
  if ps -p "$pid" >/dev/null 2>&1; then kill "$pid" && log_info "Stopped Stripe webhook forwarding."; fi
  rm -f .stripe_pid
}

# --- Commands ---
cmd_up() {
  require_docker; check_env_file
  log_info "Starting ${PROJECT_NAME}..."
  $DC up -d
  # Wait for the web port to answer before declaring victory.
  local tries=0
  until curl -s -o /dev/null "${APP_URL}/up" 2>/dev/null || [[ $tries -ge 30 ]]; do
    sleep 1; tries=$((tries+1))
  done
  start_stripe_webhooks
  if curl -s -o /dev/null -w "%{http_code}" "${APP_URL}/" 2>/dev/null | grep -q "200\|30"; then
    log_success "Running at ${APP_URL}"
  else
    log_warning "Containers up, but ${APP_URL} did not respond yet. Check: wss logs web"
  fi
}

cmd_down() {
  require_docker
  stop_stripe_webhooks
  log_info "Stopping ${PROJECT_NAME}..."
  $DC down
  log_success "Stopped."
}

cmd_restart() {
  require_docker
  stop_stripe_webhooks
  $DC restart
  start_stripe_webhooks
  log_success "Restarted. App at ${APP_URL}"
}

cmd_build()  { require_docker; log_info "Building images..."; $DC build "${@:2}"; log_success "Built."; }
cmd_logs()   { require_docker; if [[ -n "$2" ]]; then $DC logs -f "$2"; else $DC logs -f; fi; }
cmd_console(){ require_docker; $DC exec web bin/rails console; }
cmd_bash()   { require_docker; $DC exec web bash; }

cmd_test() {
  require_docker
  log_info "Running tests against the test database..."
  $DC up -d db >/dev/null 2>&1
  $DC run --rm -e RAILS_ENV=test -e DATABASE_URL="${TEST_DB_URL}" web \
    bash -c "bin/rails db:test:prepare && bin/rails test ${*:2}"
}

cmd_db() {
  require_docker
  case "$2" in
    migrate) $DC exec web bin/rails db:migrate ;;
    seed)    $DC exec web bin/rails db:seed ;;
    reset)   $DC exec web bin/rails db:reset ;;
    console) $DC exec web bin/rails dbconsole ;;
    *) log_error "Unknown db command: '$2' (use migrate|seed|reset|console)"; exit 1 ;;
  esac
}

cmd_setup() {
  require_docker; check_env_file
  log_info "First-time setup: build + start + prepare database..."
  $DC build
  $DC up -d
  sleep 5
  $DC exec web bin/rails db:prepare db:seed
  log_success "Setup complete. App at ${APP_URL}"
}

cmd_clean() {
  require_docker
  log_warning "This removes all WSS containers and volumes (database data included)."
  read -r -p "Are you sure? (y/N) " response
  if [[ "$response" =~ ^[Yy]$ ]]; then
    $DC down -v --remove-orphans
    log_success "Cleaned up."
  else
    log_info "Cancelled."
  fi
}

cmd_status() {
  require_docker
  $DC ps
  echo ""
  if [[ -f .stripe_pid ]] && ps -p "$(cat .stripe_pid)" >/dev/null 2>&1; then
    log_success "Stripe webhook forwarding: running (logs: stripe-webhooks.log)"
  else
    log_info "Stripe webhook forwarding: not running"
  fi
}

case "$1" in
  up|start)       cmd_up "$@" ;;
  down|stop)      cmd_down ;;
  restart)        cmd_restart ;;
  build)          cmd_build "$@" ;;
  logs)           cmd_logs "$@" ;;
  console|shell)  cmd_console ;;
  bash)           cmd_bash ;;
  test)           cmd_test "$@" ;;
  db)             cmd_db "$@" ;;
  setup)          cmd_setup ;;
  clean)          cmd_clean ;;
  status|ps)      cmd_status ;;
  help|--help|-h|"") show_help ;;
  *) log_error "Unknown command: $1"; echo ""; show_help; exit 1 ;;
esac
