# Whiskey Share Society — environment variables.
# Copy to `.env` (which is gitignored) and fill in real values. NEVER commit `.env`.

# --- Rails -------------------------------------------------------------------
RAILS_ENV=development
# RAILS_LOG_LEVEL=info
# RAILS_MAX_THREADS=5

# --- Database ----------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
# Production uses a dedicated role password:
# WSS_DATABASE_PASSWORD=

# --- Stripe (payments) -------------------------------------------------------
# From the Stripe Dashboard. In production the app refuses to boot without these.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen` (dev) or the Dashboard webhook endpoint (prod).
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs for each plan.
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_QUARTERLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# --- Google OAuth ------------------------------------------------------------
# The "Continue with Google" button only appears when BOTH values are set.
# To create credentials:
#   1. https://console.cloud.google.com/apis/credentials → Create credentials
#      → OAuth client ID → Application type: Web application
#   2. Authorized JavaScript origins:
#        http://localhost:3000            (development)
#        https://YOUR-PRODUCTION-DOMAIN   (production)
#   3. Authorized redirect URIs:
#        http://localhost:3000/users/auth/google_oauth2/callback
#        https://YOUR-PRODUCTION-DOMAIN/users/auth/google_oauth2/callback
#   4. If the OAuth consent screen is in "Testing" mode, add your Google account
#      under Test users, or publish the app.
# Paste the resulting client ID / secret below, then restart (./wss restart).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Sign in with Apple ------------------------------------------------------
# Apple Sign In is only enabled when ALL of these are present (see
# config/initializers/devise.rb). Provide the signing key as the full PEM contents
# in APPLE_PRIVATE_KEY — do NOT commit a .pem file.
# NOTE: if your Apple Developer membership/cert lapsed, renew it, then create a new
# "Sign in with Apple" key (Certificates, Identifiers & Profiles → Keys) — revoke
# the old leaked key (it was previously committed to this repo as
# apple_private_key.pem and must be treated as compromised).
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
