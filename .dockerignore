# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
*.md

# Logs
log/*
*.log

# Runtime data
tmp/*
!tmp/.keep

# Environment files
.env
.env.*

# Database
db/*.sqlite3
db/*.sqlite3-*

# Node modules (will be installed in container)
node_modules/

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output

# Dependency directories
vendor/bundle/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker
Dockerfile*
docker-compose*
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml

# Testing
spec/
test/
.rspec
.rubocop.yml

# Kamal deployment
.kamal/

# Ignore bundler config.
/.bundle

# Ignore all default key files.
/config/master.key
/config/credentials/*.key

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore assets.
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Ignore CI service files.
/.github

# Ignore Kamal files.
/config/deploy*.yml
/.kamal

# Ignore development files
/.devcontainer
