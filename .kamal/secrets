# Kamal reads these at deploy time. Every value is pulled from YOUR shell
# environment (or a file) — no literal secrets live in this file or in git.
# Export the variables in your terminal before `kamal setup`/`kamal deploy`;
# docs/launch-checklist.md lists where each value comes from.

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
RAILS_MASTER_KEY=$(cat config/master.key)

# Postgres — one password, used by both the app and the db accessory.
WSS_DATABASE_PASSWORD=$WSS_DATABASE_PASSWORD
POSTGRES_PASSWORD=$WSS_DATABASE_PASSWORD

# Active Record encryption (2FA data). Same values as dev .env — losing
# these means losing every user's 2FA enrollment. Keep offline copies.
AR_ENCRYPTION_PRIMARY_KEY=$AR_ENCRYPTION_PRIMARY_KEY
AR_ENCRYPTION_DETERMINISTIC_KEY=$AR_ENCRYPTION_DETERMINISTIC_KEY
AR_ENCRYPTION_KEY_DERIVATION_SALT=$AR_ENCRYPTION_KEY_DERIVATION_SALT

# Google OAuth (production credentials, not the dev ones)
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET

# Stripe LIVE mode
STRIPE_SECRET_KEY=$STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=$STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=$STRIPE_WEBHOOK_SECRET
STRIPE_MONTHLY_PRICE_ID=$STRIPE_MONTHLY_PRICE_ID
STRIPE_QUARTERLY_PRICE_ID=$STRIPE_QUARTERLY_PRICE_ID
STRIPE_YEARLY_PRICE_ID=$STRIPE_YEARLY_PRICE_ID
STRIPE_FOUNDING_SOCIETY_PRICE_ID=$STRIPE_FOUNDING_SOCIETY_PRICE_ID
STRIPE_FOUNDING_MONTHLY_PRICE_ID=$STRIPE_FOUNDING_MONTHLY_PRICE_ID

# Sentry error alerting (fine to leave unset; the app no-ops without it)
SENTRY_DSN=$SENTRY_DSN

# Cloudflare R2 — uploads + nightly DB backups
R2_ENDPOINT=$R2_ENDPOINT
R2_ACCESS_KEY_ID=$R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=$R2_SECRET_ACCESS_KEY
R2_BUCKET=$R2_BUCKET

# Transactional email (password resets etc.). Unset = mail disabled.
SMTP_ADDRESS=$SMTP_ADDRESS
SMTP_USERNAME=$SMTP_USERNAME
SMTP_PASSWORD=$SMTP_PASSWORD
