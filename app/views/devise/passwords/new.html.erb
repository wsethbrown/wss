<div class="min-h-screen bg-white flex items-center justify-center pt-24 pb-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <!-- Header -->
    <div class="text-center">
      <div class="mx-auto mb-6 flex items-center justify-center">
        <%= image_tag "wss-logo.jpg", alt: "Whiskey Share Society", class: "h-36 w-36 object-cover rounded-xl" %>
      </div>
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Magic Link</h2>
      <p class="text-gray-600">Enter your email to sign in or create a new account</p>
    </div>

    <!-- Success Message -->
    <% if params[:magic_link_sent] %>
      <div class="mb-6 rounded-lg bg-green-50 border border-green-200 text-green-800 px-4 py-4 shadow">
        <div class="flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-green-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span class="font-semibold">Email Sent!</span>
        </div>
        <p class="text-center"><%= params[:magic_link_sent] %></p>
        <% if params[:email] %>
          <p class="text-center text-sm mt-2 text-green-700">
            We sent a magic link to <strong><%= params[:email] %></strong>
          </p>
        <% end %>
      </div>
    <% end %>

    <!-- Form -->
    <%= form_with url: magic_links_path, method: :post, html: { class: "space-y-6" } do |f| %>
      <!-- Email Field -->
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            value: params[:email],
            class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
            placeholder: "Enter your email address" %>
      </div>

      <!-- Submit Button -->
      <div>
        <%= f.submit params[:sent] ? "Send another magic link" : "Send magic link",
            class: "w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-gradient-to-r from-amber-600 to-orange-600 hover:from-amber-700 hover:to-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500" %>
      </div>
    <% end %>

    <!-- Alternative Options -->
    <div class="space-y-4">
      <div class="text-center">
        <p class="text-sm text-gray-600">
          Want to use the full authentication page?
          <%= link_to "Go to sign in", auth_path,
              class: "font-medium text-amber-600 hover:text-amber-500" %>
        </p>
      </div>
    </div>

    <!-- Info Box -->
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <% if params[:sent] %>
            <p class="text-sm text-blue-700">
              <strong>Check your email!</strong> The magic link expires in 15 minutes and can only be used once. If you don't see it, check your spam folder.
            </p>
          <% else %>
            <p class="text-sm text-blue-700">
              We'll send you a secure link that will automatically sign you in or create your account. No password required!
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
