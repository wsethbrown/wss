<%# locals: event, alert (optional) — Table talk, the night's flat comment
    thread. Members/organizer/global admin may post (EventPolicy#comment?)
    while Event#comments_open? (until a week after the night ends). %>
<div id="table-talk" class="bg-white shadow-sm rounded-lg overflow-hidden mt-8">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900">Table talk</h2>
    <% unless event.comments_open? %>
      <span class="text-sm text-gray-400">Comments close a week after the night.</span>
    <% end %>
  </div>
  <div class="p-6">
    <% comments = event.event_comments.ordered.includes(:user) %>
    <% if comments.any? %>
      <div class="divide-y divide-gray-100">
        <% comments.each do |comment| %>
          <div class="py-3 first:pt-0">
            <div class="flex items-baseline justify-between gap-3">
              <p class="text-sm font-semibold text-gray-900"><%= comment.user.full_name %></p>
              <div class="flex shrink-0 items-baseline gap-3">
                <span class="text-xs text-gray-400"><%= l(comment.created_at, format: :short) %></span>
                <% if user_signed_in? && policy(comment).destroy? %>
                  <%= button_to "Delete", event_comment_path(event, comment), method: :delete,
                      class: "cursor-pointer text-xs font-semibold text-gray-400 hover:text-red-600" %>
                <% end %>
              </div>
            </div>
            <p class="mt-1 text-sm text-gray-700 whitespace-pre-line"><%= comment.body %></p>
          </div>
        <% end %>
      </div>
    <% elsif event.comments_open? %>
      <p class="text-gray-500 italic">Nothing on the record yet.</p>
    <% else %>
      <p class="text-gray-500 italic">The night passed without a word.</p>
    <% end %>

    <% if local_assigns[:alert].present? %>
      <p class="mt-4 text-sm text-red-600"><%= alert %></p>
    <% end %>

    <% if user_signed_in? && policy(event).comment? && event.comments_open? %>
      <%= form_with url: event_comments_path(event), method: :post, class: "mt-5 space-y-3" do %>
        <textarea name="event_comment[body]" rows="2" required maxlength="2000"
                  placeholder="Say something about this night…"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500"></textarea>
        <%= submit_tag "Post", class: "cursor-pointer rounded-xl bg-whiskey-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-whiskey-700" %>
      <% end %>
    <% end %>
  </div>
</div>
