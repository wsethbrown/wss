<%# One item in the masthead's metadata row, not a tile: it sits inline beside
    the date and location. turbo_stream swaps it on every RSVP, so the id and
    the single root element both have to stay. %>
<span id="header-rsvp-count" class="inline-flex items-center gap-2">
  <svg class="h-4 w-4 shrink-0 text-whiskey-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"></path>
  </svg>
  <% if event.total_rsvp_count.zero? %>
    No replies yet
  <% else %>
    <%= event.yes_count %> going<% if event.maybe_count.positive? %>, <%= event.maybe_count %> maybe<% end %><% if event.no_count.positive? %>, <%= event.no_count %> no<% end %>
  <% end %>
</span>
