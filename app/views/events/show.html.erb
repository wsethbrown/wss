<% content_for :title, "#{@event.title} - Whiskey Share Society" %>

<div class="min-h-screen bg-gray-50">
  <!-- Flash Messages -->
  <div id="flash-messages"></div>
  
  <!-- Event Header -->
  <div class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumb -->
      <nav class="flex mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <%= link_to society_path(@event.society), class: "inline-flex items-center text-sm font-medium text-gray-700 hover:text-whiskey-600" do %>
              <%= @event.society.name %>
            <% end %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2"><%= @event.title %></span>
            </div>
          </li>
        </ol>
      </nav>

      <div class="flex items-start justify-between">
        <div class="flex-1">
          <!-- Event Title & Society -->
          <div class="flex items-center space-x-4 mb-4">
            <h1 class="font-display text-4xl font-semibold text-gray-900"><%= @event.title %></h1>
            <%= link_to @event.society, 
                class: "inline-flex items-center px-3 py-1.5 rounded-md text-sm font-medium bg-whiskey-100 text-whiskey-800 hover:bg-whiskey-200 transition-colors" do %>
              <%= @event.society.name %>
            <% end %>
          </div>

          <!-- Event Status -->
          <div class="flex items-center space-x-4 mb-6">
            <% if @event.upcoming? %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                Upcoming
              </span>
            <% elsif @event.ongoing? %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                🔴 Live Now
              </span>
            <% else %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                Completed
              </span>
            <% end %>

            <span class="text-sm text-gray-500">
              Organized by <%= link_to @event.organizer.full_name, profile_path(@event.organizer), class: "font-medium text-gray-700 hover:text-whiskey-600" %>
            </span>
          </div>

          <!-- Event Details -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <!-- Date & Time -->
            <div class="flex items-start space-x-3">
              <div class="w-10 h-10 bg-whiskey-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-whiskey-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-medium text-gray-900">Date & Time</h3>
                <p class="text-sm text-gray-600 mt-1">
                  <%= @event.start_time.strftime("%A, %B %d, %Y") %><br>
                  <%= @event.start_time.strftime("%I:%M %p") %> - <%= @event.end_time.strftime("%I:%M %p") %>
                </p>
              </div>
            </div>

            <!-- Location -->
            <% if @event.location.present? %>
              <div class="flex items-start space-x-3">
                <div class="w-10 h-10 bg-whiskey-100 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-whiskey-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm font-medium text-gray-900">Location</h3>
                  <p class="text-sm text-gray-600 mt-1"><%= @event.location %></p>
                </div>
              </div>
            <% end %>

            <!-- Attendees -->
            <%= render "header_rsvp_count", event: @event %>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex items-center space-x-3 ml-6">
          <% if user_signed_in? %>
            <!-- RSVP Buttons - Yes/Maybe/No -->
            <% if @event.upcoming? && !@event.rsvp_closed? %>
              <% user_rsvp = @event.event_rsvps.find_by(user: current_user) %>
              <%= render "rsvp_buttons", event: @event, user_rsvp: user_rsvp %>
            <% elsif @event.upcoming? %>
              <% user_rsvp = @event.event_rsvps.find_by(user: current_user) %>
              <% if user_rsvp %>
                <span class="text-sm text-gray-500">
                  Your RSVP: <span class="font-medium text-gray-700"><%= user_rsvp.status.capitalize %></span>, RSVPs closed
                </span>
              <% else %>
                <span class="text-sm text-gray-500">RSVPs closed, they close 24 hours before the event</span>
              <% end %>
            <% else %>
              <span class="text-sm text-gray-500">Event has ended</span>
            <% end %>

            <!-- Edit Button (for organizers/admins) -->
            <% if policy(@event).update? %>
              <%= link_to "Edit Event", edit_society_event_path(@event.society, @event), 
                  class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
            <% end %>
          <% else %>
            <%= link_to "Sign In to RSVP", new_user_session_path, 
                class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-whiskey-600 hover:bg-whiskey-700" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Event Description -->
      <div class="lg:col-span-2">
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">Event Details</h2>
          </div>
          <div class="p-6">
            <% if @event.description.present? %>
              <div class="prose prose-indigo max-w-none">
                <%= simple_format(@event.description, class: "text-gray-700 leading-relaxed") %>
              </div>
            <% else %>
              <p class="text-gray-500 italic">No description provided for this event.</p>
            <% end %>
          </div>
        </div>

        <%= render "pours" %>

        <%= render "comments", event: @event %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Yes Attendees -->
        <% if @event.confirmed_attendees.any? %>
          <div class="bg-white shadow-sm rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200">
              <h2 class="text-lg font-semibold text-gray-900">Attending (Yes)</h2>
            </div>
            <div class="p-6">
              <div class="space-y-3">
                <% @event.confirmed_attendees.limit(10).each do |attendee| %>
                  <%= link_to profile_path(attendee), class: "flex items-center space-x-3 hover:bg-gray-50 rounded-lg p-2 -m-2 transition-colors" do %>
                    <% if attendee.has_profile_image? %>
                      <img src="<%= attendee.profile_image_url %>" alt="<%= attendee.full_name %>" class="w-8 h-8 rounded-full">
                    <% else %>
                      <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-medium" style="background-color: <%= attendee.avatar_color %>;">
                        <%= attendee.initials %>
                      </div>
                    <% end %>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate"><%= attendee.full_name %></p>
                    </div>
                  <% end %>
                <% end %>
              </div>
              <% if @event.confirmed_attendee_count > 10 %>
                <div class="mt-4 pt-4 border-t border-gray-200">
                  <p class="text-sm text-gray-500 text-center">
                    And <%= @event.confirmed_attendee_count - 10 %> more attendees
                  </p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Host: shown to everyone once assigned; managed by update? holders. -->
        <% if @event.host || policy(@event).update? %>
          <div class="bg-white shadow-sm rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200">
              <h2 class="text-lg font-semibold text-gray-900">Host</h2>
            </div>
            <div class="p-6 space-y-4">
              <% if @event.host %>
                <%= link_to profile_path(@event.host), class: "flex items-center space-x-3 hover:bg-gray-50 rounded-lg p-2 -m-2 transition-colors" do %>
                  <% if @event.host.has_profile_image? %>
                    <img src="<%= @event.host.profile_image_url %>" alt="<%= @event.host.full_name %>" class="w-8 h-8 rounded-full">
                  <% else %>
                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-medium" style="background-color: <%= @event.host.avatar_color %>;">
                      <%= @event.host.initials %>
                    </div>
                  <% end %>
                  <p class="text-sm font-medium text-gray-900 truncate"><%= @event.host.full_name %></p>
                <% end %>
              <% else %>
                <p class="text-sm text-gray-500">No host assigned yet.</p>
              <% end %>
              <% if policy(@event).update? %>
                <%= form_with url: assign_host_society_event_path(@event.society, @event), method: :patch, local: true, class: "space-y-2" do %>
                  <select name="host_id"
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500">
                    <option value="">No host</option>
                    <% @event.society.society_memberships.where(status: "active").includes(:user).map(&:user).uniq.sort_by(&:full_name).each do |member| %>
                      <option value="<%= member.id %>" <%= "selected" if @event.host_id == member.id %>><%= member.full_name %></option>
                    <% end %>
                  </select>
                  <button type="submit"
                          class="w-full px-4 py-2 bg-whiskey-600 text-white text-sm font-medium rounded-lg hover:bg-whiskey-700 transition cursor-pointer">
                    Set host
                  </button>
                <% end %>
                <p class="text-xs text-gray-500">The host sees this event's RSVP replies.</p>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- RSVP replies: the host and event managers only. -->
        <% if policy(@event).view_rsvps? && @event.event_rsvps.any? %>
          <div class="bg-white shadow-sm rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200">
              <h2 class="text-lg font-semibold text-gray-900">RSVP replies</h2>
              <p class="text-xs text-gray-500 mt-1">Only the host and event managers see this.</p>
            </div>
            <div class="p-6 space-y-4">
              <% @event.event_rsvps.includes(:user).order(updated_at: :desc).each do |rsvp| %>
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate"><%= rsvp.user.full_name %></p>
                    <% if rsvp.note.present? %>
                      <p class="mt-0.5 text-sm italic text-gray-600">&ldquo;<%= rsvp.note %>&rdquo;</p>
                    <% end %>
                  </div>
                  <% chip = { "yes" => "bg-green-100 text-green-800", "maybe" => "bg-amber-100 text-amber-800", "no" => "bg-gray-100 text-gray-600" }[rsvp.status] %>
                  <span class="shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= chip %>"><%= rsvp.status.capitalize %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Event Stats -->
        <%= render "stats", event: @event %>

        <!-- Society Info -->
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">Society</h2>
          </div>
          <div class="p-6">
            <%= link_to @event.society, class: "flex items-center space-x-4 hover:bg-gray-50 rounded-lg p-2 -m-2 transition-colors" do %>
              <div class="w-12 h-12 bg-gradient-to-br from-whiskey-500 to-whiskey-500 rounded-xl flex items-center justify-center">
                <%= render 'shared/society_icon', society: @event.society, size: 'default' %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= @event.society.name %></p>
                <p class="text-xs text-gray-500"><%= @event.society.member_count %> members</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>