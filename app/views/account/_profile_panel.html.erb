<%# Extracted from account/index (account tab panel: profile). %>
        <div id="profile-content" class="tab-content min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Profile</h2>
              <p class="text-gray-600">Manage your public profile and whiskey preferences</p>
            </div>
            
            <!-- Profile Photo Section -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Profile Photo</h3>
              <div class="flex items-center space-x-6">
                <% if current_user.profile_image.attached? %>
                  <div class="w-24 h-24 rounded-full overflow-hidden bg-gray-100">
                    <%= image_tag current_user.profile_image, class: "w-full h-full object-cover" %>
                  </div>
                <% else %>
                  <div class="w-24 h-24 rounded-full flex items-center justify-center" style="background-color: <%= current_user.avatar_color %>;">
                    <span class="text-3xl text-white font-semibold"><%= current_user.initials %></span>
                  </div>
                <% end %>
                
                <div class="flex space-x-3">
                  <%= form_with url: account_avatar_path, method: :patch, multipart: true, class: "inline-block" do |f| %>
                    <%= f.file_field :profile_image, accept: "image/*", class: "hidden", id: "profile-image-upload", onchange: "this.form.submit();" %>
                    <label for="profile-image-upload" class="cursor-pointer inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-whiskey-500">
                      Upload Photo
                    </label>
                  <% end %>
                  
                  <% if current_user.profile_image.attached? %>
                    <%= button_to "Remove", account_remove_avatar_path, method: :delete, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-whiskey-500" %>
                  <% end %>
                </div>
              </div>
            </div>
            
            <!-- Basic Info Section -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Basic Information</h3>
              <%= form_with model: current_user, url: account_profile_path, method: :patch, class: "space-y-4", id: "profile-form" do |f| %>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
                    <%= f.text_field :first_name, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm" %>
                  </div>
                  <div>
                    <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
                    <%= f.text_field :last_name, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm" %>
                  </div>
                </div>
                
                <div>
                  <%= f.label :bio, "About Me", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.text_area :bio, rows: 4, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm", placeholder: "Tell others about your whiskey journey..." %>
                </div>
                
                <div>
                  <%= f.label :whiskey_shelf, "My Whiskey Shelf", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <p class="text-sm text-gray-500 mb-2">List the whiskeys you own or love (one per line)</p>
                  <%= f.text_area :whiskey_shelf, rows: 6, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm font-mono", placeholder: "Macallan 18\nGlenfiddich 21\nBlantons Single Barrel\nRedbreast 12" %>
                </div>
                
                <div class="pt-4 flex gap-3">
                  <%= f.submit "Save Profile", class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-whiskey-600 hover:bg-whiskey-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-whiskey-500" %>
                  <%= link_to "See my Profile", profile_path(current_user), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-whiskey-500", target: "_blank" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Account Details Tab Content -->
