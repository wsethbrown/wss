                  <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-sm border border-gray-200">
                    <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    <span class="text-sm text-gray-700 font-medium">30-day guarantee</span>
                  </div>
                  <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-sm border border-gray-200">
                    <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    <span class="text-sm text-gray-700 font-medium">Cancel anytime</span>
                  </div>
                  <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-sm border border-gray-200">
                    <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                      <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                    </svg>
                    <span class="text-sm text-gray-700 font-medium">Secure checkout</span>
                  </div>
                </div>
                
                <!-- Features Info -->
                <div class="bg-gradient-to-br from-blue-50 to-whiskey-50 rounded-2xl p-6 border border-blue-100">
                  <h4 class="text-base font-semibold text-gray-900 mb-3">✨ What are presentation credits?</h4>
                  <p class="text-sm text-gray-700 leading-relaxed">
                    Each month, you'll receive 1 credit that can be used to unlock any premium presentation in our growing library. 
                    Credits are automatically added on the 1st of each month, and presentations accessed with credits remain available 
                    as long as your subscription is active. Perfect for exploring new whiskey types at your own pace!
                  </p>
                </div>
              <% end %>
            </div>
            
            <!-- Credits History -->
            <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-medium text-gray-900">Credits History</h3>
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-amber-100 text-amber-800">
                    <%= current_user.credits %> credit<%= 's' if current_user.credits != 1 %> available
                  </span>
                </div>
              </div>
              
              <% credit_transactions = current_user.credit_transactions.order(created_at: :desc).limit(5) %>
              <% if credit_transactions.any? %>
                <div class="space-y-3">
                  <% credit_transactions.each do |transaction| %>
                    <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
                      <div>
                        <p class="text-sm font-medium text-gray-900">
                          <% case transaction.transaction_type %>
                          <% when 'granted' %>
