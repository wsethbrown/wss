<% content_for :title, "Account - Whiskey Share Society" %>

<div class="min-h-screen">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex">
      <!-- Sidebar Navigation -->
      <div class="w-64 flex-shrink-0 sticky top-8 h-fit">
        <div class="pr-8">
          <h1 class="text-2xl font-bold text-gray-900 mb-6">Account</h1>
          <nav class="space-y-2">
            <a href="#profile" class="flex items-center px-3 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 rounded-md border-l-4 border-indigo-600 group" data-tab="profile">
              <svg class="w-5 h-5 mr-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              Profile
            </a>
            <a href="#account-details" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="account-details">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Account Details
            </a>
            <a href="#presentations" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="presentations">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              My Presentations
            </a>
            <a href="#societies" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="societies">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-3-3.87M9 20H4v-2a3 3 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a3 3 0 00-3-3.87"></path>
              </svg>
              My Societies
            </a>
            <a href="#subscription" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="subscription">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
              </svg>
              Subscription
            </a>
          </nav>
        </div>
      </div>

      <!-- Main Content Area -->
      <div class="w-full ml-8 min-h-screen">
        <div class="w-[800px]">
        
        <!-- Profile Tab Content (Active by default) -->
        <div id="profile-content" class="tab-content min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Profile</h2>
              <p class="text-gray-600">Manage your public profile and whiskey preferences</p>
            </div>
            
            <!-- Profile Photo Section -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Profile Photo</h3>
              <div class="flex items-center space-x-6">
                <% if current_user.profile_image.attached? %>
                  <div class="w-24 h-24 rounded-full overflow-hidden bg-gray-100">
                    <%= image_tag current_user.profile_image, class: "w-full h-full object-cover" %>
                  </div>
                <% else %>
                  <div class="w-24 h-24 rounded-full bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center">
                    <span class="text-3xl text-white font-semibold"><%= current_user.full_name.first.upcase %></span>
                  </div>
                <% end %>
                
                <div class="flex space-x-3">
                  <%= form_with url: account_avatar_path, method: :patch, multipart: true, local: true, class: "inline-block" do |f| %>
                    <%= f.file_field :profile_image, accept: "image/*", class: "hidden", id: "profile-image-upload", onchange: "this.form.submit();" %>
                    <label for="profile-image-upload" class="cursor-pointer inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                      Upload Photo
                    </label>
                  <% end %>
                  
                  <% if current_user.profile_image.attached? %>
                    <%= button_to "Remove", account_remove_avatar_path, method: :delete, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
                  <% end %>
                </div>
              </div>
            </div>
            
            <!-- Basic Info Section -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Basic Information</h3>
              <%= form_with model: current_user, url: account_profile_path, method: :patch, local: true, class: "space-y-4" do |f| %>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
                    <%= f.text_field :first_name, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
                  </div>
                  <div>
                    <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
                    <%= f.text_field :last_name, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
                  </div>
                </div>
                
                <div>
                  <%= f.label :bio, "About Me", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.text_area :bio, rows: 4, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Tell others about your whiskey journey..." %>
                </div>
                
                <div>
                  <%= f.label :whiskey_shelf, "My Whiskey Shelf", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <p class="text-sm text-gray-500 mb-2">List the whiskeys you own or love (one per line)</p>
                  <%= f.text_area :whiskey_shelf, rows: 6, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm font-mono", placeholder: "Macallan 18\nGlenfiddich 21\nBlantons Single Barrel\nRedbreast 12" %>
                </div>
                
                <div class="pt-4">
                  <%= f.submit "Save Profile", class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Account Details Tab Content -->
        <div id="account-details-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Account Details</h2>
              <p class="text-gray-600">Manage your account settings and security</p>
            </div>
            
            <!-- Email Section -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Email Address</h3>
              <div class="space-y-4">
                <div>
                  <p class="text-sm text-gray-500">Current email address</p>
                  <p class="text-base font-medium text-gray-900"><%= current_user.email %></p>
                </div>
                
                <% if current_user.unconfirmed_email.present? %>
                  <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
                    <p class="text-sm text-yellow-800">
                      Email change pending to: <strong><%= current_user.unconfirmed_email %></strong>
                      <br>
                      Please check your email for the verification link.
                    </p>
                  </div>
                <% end %>
                
                <%= form_with url: account_change_email_path, method: :patch, local: true, class: "space-y-3" do |f| %>
                  <div>
                    <%= f.label :new_email, "New email address", class: "block text-sm font-medium text-gray-700 mb-1" %>
                    <%= f.email_field :new_email, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "new.email@example.com" %>
                  </div>
                  <%= f.submit "Change Email", class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
                <% end %>
              </div>
            </div>
            
            <!-- Password Section -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Password</h3>
              
              <% if current_user.passwordless_only? %>
                <div class="bg-blue-50 border border-blue-200 rounded-md p-4 mb-4">
                  <p class="text-sm text-blue-800">
                    You currently sign in using magic links or social login.
                    <br>
                    Add a password to enable email/password sign in.
                  </p>
                </div>
              <% end %>
              
              <%= form_with url: account_change_password_path, method: :patch, local: true, class: "space-y-4" do |f| %>
                <% if current_user.has_password? %>
                  <div>
                    <%= f.label :current_password, class: "block text-sm font-medium text-gray-700 mb-1" %>
                    <%= f.password_field :current_password, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
                  </div>
                <% end %>
                
                <div>
                  <%= f.label :new_password, current_user.has_password? ? "New password" : "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.password_field :new_password, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
                  <p class="mt-1 text-sm text-gray-500">At least 8 characters</p>
                </div>
                
                <div>
                  <%= f.label :confirm_password, "Confirm password", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.password_field :confirm_password, class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
                </div>
                
                <%= f.submit current_user.has_password? ? "Change Password" : "Add Password", class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
              <% end %>
            </div>
            
            <!-- Sign In Methods -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Sign In Methods</h3>
              <div class="space-y-3">
                <% if current_user.provider == 'google_oauth2' %>
                  <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                    <div class="flex items-center space-x-3">
                      <svg class="w-5 h-5 text-gray-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                      </svg>
                      <span class="text-sm font-medium text-gray-700">Google</span>
                    </div>
                    <span class="text-sm text-green-600">Connected</span>
                  </div>
                <% elsif current_user.provider == 'apple' %>
                  <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                    <div class="flex items-center space-x-3">
                      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="black">
                        <path d="M17.05 20.28c-.98.95-2.05.88-3.08.42-1.09-.48-2.08-.48-3.24 0-1.44.62-2.2.44-3.05-.42C1.13 13.72 1.87 6.5 9.36 6.14c1.66.09 2.82.74 3.72.78 1.36-.14 2.68-.87 4.14-.77 1.74.12 3.05.78 3.92 2.05-3.58 2.14-2.74 6.85.86 8.16-.54 1.43-1.26 2.83-2.46 4.3-.64.78-1.31 1.56-2.09 2.3l-.5-.5zM12.03 5.95c-.12-2.44 1.86-4.44 4.24-4.67.36 2.66-2.44 4.84-4.24 4.67z"/>
                      </svg>
                      <span class="text-sm font-medium text-gray-700">Apple</span>
                    </div>
                    <span class="text-sm text-green-600">Connected</span>
                  </div>
                <% end %>
                
                <% if current_user.has_password? %>
                  <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                    <div class="flex items-center space-x-3">
                      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                      </svg>
                      <span class="text-sm font-medium text-gray-700">Email & Password</span>
                    </div>
                    <span class="text-sm text-green-600">Enabled</span>
                  </div>
                <% end %>
                
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                  <div class="flex items-center space-x-3">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                    </svg>
                    <span class="text-sm font-medium text-gray-700">Magic Links</span>
                  </div>
                  <span class="text-sm text-green-600">Always Available</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- My Societies Tab Content -->
        <div id="societies-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">My Societies</h2>
              <p class="text-gray-600">Manage your whiskey societies and memberships</p>
            </div>
            
            <% user_societies = current_user.member_societies.includes(:creator) %>
            <% if user_societies.any? %>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% user_societies.each do |society| %>
                  <a href="<%= society_path(society) %>" class="block bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md hover:border-indigo-300 transition-all duration-200 group">
                    <div class="text-center">
                      <!-- Society Icon -->
                      <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-105 transition-transform">
                        <% if society.is_private %>
                          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                          </svg>
                        <% else %>
                          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                        <% end %>
                      </div>
                      
                      <!-- Society Name & Role Badge -->
                      <div class="mb-3">
                        <h3 class="text-base font-semibold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors"><%= society.name %></h3>
                            <% membership = current_user.society_memberships.find_by(society: society) %>
                            <% if membership&.admin? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Creator</span>
                            <% elsif membership&.officer? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Officer</span>
                            <% end %>
                      </div>
                      
                      <!-- Society Description -->
                      <p class="text-sm text-gray-600 mb-4 line-clamp-2 leading-relaxed">
                        <%= truncate(society.description, length: 80) %>
                      </p>
                      
                      <!-- Society Stats -->
                      <div class="flex justify-center space-x-6 text-xs text-gray-500">
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-3-3.87M9 20H4v-2a3 3 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a3 3 0 00-3-3.87"></path>
                          </svg>
                          <span><%= society.society_memberships.active.count %></span>
                        </div>
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                          <span><%= society.events.count %></span>
                        </div>
                      </div>
                    </div>
                  </a>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-3-3.87M9 20H4v-2a3 3 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a3 3 0 00-3-3.87"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No societies yet</h3>
                <p class="text-gray-500 mb-4">You haven't joined any whiskey societies yet.</p>
                <a href="<%= societies_path %>" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                  Discover Societies
                </a>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Presentations Tab Content -->
        <div id="presentations-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">My Presentations</h2>
              <p class="text-gray-600">Access and manage your whiskey presentations</p>
            </div>
            
            <% user_presentations = current_user.user_presentations.includes(:presentation => :author) %>
            <% if user_presentations.any? %>
              <div class="grid grid-cols-1 gap-6">
                <% user_presentations.each do |user_presentation| %>
                  <% presentation = user_presentation.presentation %>
                  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="flex">
                      <!-- Presentation Image -->
                      <div class="w-64 h-48 bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center">
                        <svg class="w-20 h-20 text-white opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                        </svg>
                      </div>
                      
                      <!-- Presentation Details -->
                      <div class="flex-1 p-6">
                        <div class="flex justify-between items-start">
                          <div>
                            <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= presentation.title %></h3>
                            <p class="text-gray-600 mb-4"><%= presentation.excerpt(200) %></p>
                            
                            <div class="flex items-center space-x-4 text-sm text-gray-500">
                              <span class="flex items-center">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                                <%= presentation.author.full_name %>
                              </span>
                              
                              <span class="flex items-center">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                <%= presentation.reading_time %> min read
                              </span>
                              
                              <% if presentation.category.present? %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                  <%= presentation.category.capitalize %>
                                </span>
                              <% end %>
                            </div>
                          </div>
                          
                          <div class="text-right ml-4">
                            <% if user_presentation.direct_purchase? %>
                              <div class="text-sm text-gray-500 mb-2">Purchased</div>
                            <% else %>
                              <div class="text-sm text-gray-500 mb-2">Credit Purchase</div>
                            <% end %>
                            
                            <a href="#" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                              View Presentation
                            </a>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No presentations yet</h3>
                <p class="text-gray-500 mb-4">Your purchased presentations will appear here.</p>
                <a href="#" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                  Browse Presentations
                </a>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Subscription Tab Content -->
        <div id="subscription-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Subscription</h2>
              <p class="text-gray-600">Manage your subscription and billing preferences</p>
            </div>
            
            <!-- Current Plan -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Current Plan</h3>
              
              <% if current_user.stripe_subscription_id.present? %>
                <div class="space-y-4">
                  <div class="flex justify-between items-center py-3 border-b border-gray-100">
                    <div>
                      <p class="text-sm font-medium text-gray-900">Premium Membership</p>
                      <p class="text-sm text-gray-500">1 presentation credit per month</p>
                    </div>
                    <div class="text-right">
                      <p class="text-lg font-semibold text-gray-900">$9.99/month</p>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <%= current_user.subscription_status&.capitalize || 'Active' %>
                      </span>
                    </div>
                  </div>
                  
                  <div class="flex items-center justify-between">
                    <div>
                      <p class="text-sm text-gray-500">Next billing date</p>
                      <p class="text-sm font-medium text-gray-900">
                        <%= current_user.subscription_ends_at&.strftime('%B %d, %Y') || 'N/A' %>
                      </p>
                    </div>
                    <div>
                      <p class="text-sm text-gray-500">Available credits</p>
                      <p class="text-sm font-medium text-gray-900">1 credit</p>
                    </div>
                  </div>
                  
                  <div class="pt-4">
                    <button class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                      Cancel Subscription
                    </button>
                  </div>
                </div>
              <% else %>
                <div class="text-center py-8">
                  <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                  </svg>
                  <h4 class="text-base font-medium text-gray-900 mb-2">No active subscription</h4>
                  <p class="text-sm text-gray-500 mb-4">Subscribe to get monthly presentation credits</p>
                  <a href="#" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Subscribe Now
                  </a>
                </div>
              <% end %>
            </div>
            
            <!-- Payment Method -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-medium text-gray-900">Payment Method</h3>
                <a href="#" class="text-sm text-indigo-600 hover:text-indigo-500">Update</a>
              </div>
              
              <% if current_user.stripe_customer_id.present? %>
                <div class="flex items-center space-x-3">
                  <div class="flex-shrink-0">
                    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-gray-900">•••• •••• •••• 4242</p>
                    <p class="text-sm text-gray-500">Expires 12/2025</p>
                  </div>
                </div>
              <% else %>
                <p class="text-sm text-gray-500">No payment method on file</p>
              <% end %>
            </div>
            
            <!-- Billing History -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-medium text-gray-900">Billing History</h3>
                <a href="#" class="text-sm text-indigo-600 hover:text-indigo-500">View all</a>
              </div>
              
              <div class="space-y-3">
                <div class="flex justify-between items-center py-2">
                  <div>
                    <p class="text-sm font-medium text-gray-900">Premium Membership</p>
                    <p class="text-sm text-gray-500">July 1, 2025</p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-medium text-gray-900">$9.99</p>
                    <span class="text-xs text-green-600">Paid</span>
                  </div>
                </div>
                
                <div class="flex justify-between items-center py-2">
                  <div>
                    <p class="text-sm font-medium text-gray-900">Premium Membership</p>
                    <p class="text-sm text-gray-500">June 1, 2025</p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-medium text-gray-900">$9.99</p>
                    <span class="text-xs text-green-600">Paid</span>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Portal Link -->
            <% if current_user.stripe_customer_id.present? %>
              <div class="text-center">
                <a href="<%= subscriptions_portal_path %>" class="text-sm text-indigo-600 hover:text-indigo-500">
                  Manage billing in Stripe Customer Portal →
                </a>
              </div>
            <% end %>
          </div>
        </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const tabs = document.querySelectorAll('[data-tab]');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      
      const targetTab = this.getAttribute('data-tab');
      
      // Remove active classes from all tabs
      tabs.forEach(t => {
        t.className = 'flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group';
        const icon = t.querySelector('svg');
        if (icon) {
          icon.className = 'w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600';
        }
      });
      
      // Add active classes to clicked tab
      this.className = 'flex items-center px-3 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 rounded-md border-l-4 border-indigo-600 group';
      const activeIcon = this.querySelector('svg');
      if (activeIcon) {
        activeIcon.className = 'w-5 h-5 mr-3 text-indigo-600';
      }
      
      // Hide all content
      contents.forEach(content => {
        content.classList.add('hidden');
      });
      
      // Show target content
      const targetContent = document.getElementById(targetTab + '-content');
      if (targetContent) {
        targetContent.classList.remove('hidden');
      }
    });
  });
});
</script>