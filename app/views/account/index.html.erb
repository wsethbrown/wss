<% content_for :title, "Account - Whiskey Share Society" %>

<div class="min-h-screen">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex">
      <!-- Sidebar Navigation -->
      <div class="w-64 flex-shrink-0 sticky top-8 h-fit">
        <div class="pr-8">
          <h1 class="text-2xl font-bold text-gray-900 mb-6">Account</h1>
          <nav class="space-y-2">
            <a href="#profile" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="profile">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              Profile
            </a>
            <a href="#account-details" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="account-details">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Account Details
            </a>
            <a href="#presentations" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="presentations">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              My Presentations
            </a>
            <a href="#societies" class="flex items-center px-3 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 rounded-md border-l-4 border-indigo-600 group" data-tab="societies">
              <svg class="w-5 h-5 mr-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-3-3.87M9 20H4v-2a3 3 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a3 3 0 00-3-3.87"></path>
              </svg>
              My Societies
            </a>
            <a href="#subscription" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="subscription">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
              </svg>
              Subscription
            </a>
          </nav>
        </div>
      </div>

      <!-- Main Content Area -->
      <div class="w-full ml-8 min-h-screen">
        <div class="w-[800px]">
        
        <!-- My Societies Tab Content (Active by default) -->
        <div id="societies-content" class="tab-content min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">My Societies</h2>
              <p class="text-gray-600">Manage your whiskey societies and memberships</p>
            </div>
            
            <% user_societies = current_user.member_societies.includes(:creator) %>
            <% if user_societies.any? %>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% user_societies.each do |society| %>
                  <a href="<%= society_path(society) %>" class="block bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md hover:border-indigo-300 transition-all duration-200 group">
                    <div class="text-center">
                      <!-- Society Icon -->
                      <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-105 transition-transform">
                        <% if society.is_private %>
                          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                          </svg>
                        <% else %>
                          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                        <% end %>
                      </div>
                      
                      <!-- Society Name & Role Badge -->
                      <div class="mb-3">
                        <h3 class="text-base font-semibold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors"><%= society.name %></h3>
                            <% membership = current_user.society_memberships.find_by(society: society) %>
                            <% if membership&.admin? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Creator</span>
                            <% elsif membership&.officer? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Officer</span>
                            <% end %>
                      </div>
                      
                      <!-- Society Description -->
                      <p class="text-sm text-gray-600 mb-4 line-clamp-2 leading-relaxed">
                        <%= truncate(society.description, length: 80) %>
                      </p>
                      
                      <!-- Society Stats -->
                      <div class="flex justify-center space-x-6 text-xs text-gray-500">
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-3-3.87M9 20H4v-2a3 3 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a3 3 0 00-3-3.87"></path>
                          </svg>
                          <span><%= society.society_memberships.active.count %></span>
                        </div>
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                          <span><%= society.events.count %></span>
                        </div>
                      </div>
                    </div>
                  </a>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-3-3.87M9 20H4v-2a3 3 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a3 3 0 00-3-3.87"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No societies yet</h3>
                <p class="text-gray-500 mb-4">You haven't joined any whiskey societies yet.</p>
                <a href="<%= societies_path %>" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                  Discover Societies
                </a>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Profile Tab Content -->
        <div id="profile-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Profile</h2>
              <p class="text-gray-600">Manage your public profile and whiskey preferences</p>
            </div>
            <div class="text-center py-12">
              <p class="text-gray-500">Profile content goes here...</p>
            </div>
          </div>
        </div>

        <!-- Account Details Tab Content -->
        <div id="account-details-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Account Details</h2>
              <p class="text-gray-600">Manage your account settings and security</p>
            </div>
            <div class="text-center py-12">
              <p class="text-gray-500">Account details content goes here...</p>
            </div>
          </div>
        </div>

        <!-- Presentations Tab Content -->
        <div id="presentations-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">My Presentations</h2>
              <p class="text-gray-600">Access and manage your whiskey presentations</p>
            </div>
            <div class="text-center py-12">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <h3 class="text-lg font-medium text-gray-900 mb-2">No presentations yet</h3>
              <p class="text-gray-500">Your purchased presentations will appear here.</p>
            </div>
          </div>
        </div>

        <!-- Subscription Tab Content -->
        <div id="subscription-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Subscription</h2>
              <p class="text-gray-600">Manage your subscription and billing preferences</p>
            </div>
            <div class="text-center py-12">
              <p class="text-gray-500">Subscription content goes here...</p>
            </div>
          </div>
        </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const tabs = document.querySelectorAll('[data-tab]');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      
      const targetTab = this.getAttribute('data-tab');
      
      // Remove active classes from all tabs
      tabs.forEach(t => {
        t.className = 'flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group';
        const icon = t.querySelector('svg');
        if (icon) {
          icon.className = 'w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600';
        }
      });
      
      // Add active classes to clicked tab
      this.className = 'flex items-center px-3 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 rounded-md border-l-4 border-indigo-600 group';
      const activeIcon = this.querySelector('svg');
      if (activeIcon) {
        activeIcon.className = 'w-5 h-5 mr-3 text-indigo-600';
      }
      
      // Hide all content
      contents.forEach(content => {
        content.classList.add('hidden');
      });
      
      // Show target content
      const targetContent = document.getElementById(targetTab + '-content');
      if (targetContent) {
        targetContent.classList.remove('hidden');
      }
    });
  });
});
</script>