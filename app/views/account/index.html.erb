      </div>

      <!-- Main Content Area -->
      <div class="w-full ml-8 min-h-screen">
        <div class="w-[800px]">
        
        <!-- Profile Tab Content (Active by default) -->
        <%= render 'account/profile_panel' %>
        <%= render 'account/account_details_panel' %>
        <%= render 'account/societies_panel' %>
        <%= render 'account/followed_panel' %>
        <%= render 'account/presentations_panel' %>
        <%= render 'account/billing_panel' %>
        <%= render 'account/subscription_panel' %>
      </div>
    </div>
  </div>
</div>

<script>
function initializeAccountPage() {
  const tabs = document.querySelectorAll('[data-tab]');
  const contents = document.querySelectorAll('.tab-content');

  function activateTab(tabName) {
    // Get fresh references to tabs and contents
    const currentTabs = document.querySelectorAll('[data-tab]');
    const currentContents = document.querySelectorAll('.tab-content');
    
    // Remove active classes from all tabs
    currentTabs.forEach(t => {
      t.className = 'flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-whiskey-600 hover:bg-gray-50 rounded-md group';
      const icon = t.querySelector('svg');
      if (icon) {
        icon.className = 'w-5 h-5 mr-3 text-gray-400 group-hover:text-whiskey-600';
      }
    });
    
    // Add active classes to target tab
    const targetTab = document.querySelector(`[data-tab="${tabName}"]`);
    if (targetTab) {
      targetTab.className = 'flex items-center px-3 py-2 text-sm font-medium text-whiskey-600 bg-whiskey-50 rounded-md border-l-4 border-whiskey-600 group';
      const activeIcon = targetTab.querySelector('svg');
      if (activeIcon) {
        activeIcon.className = 'w-5 h-5 mr-3 text-whiskey-600';
      }
    }
    
    // Hide all content with fresh references
    currentContents.forEach(content => {
      content.classList.add('hidden');
    });
    
    // Show target content
    const targetContent = document.getElementById(tabName + '-content');
    if (targetContent) {
      targetContent.classList.remove('hidden');

      // Bring the newly shown panel into view. When scrolled deep into a long
      // panel (e.g. Billing History), swapping content above the fold looks
      // like the click did nothing. Only scroll when actually needed.
      const navClearance = 96;
      const panelTop = targetContent.getBoundingClientRect().top + window.scrollY - navClearance;
      if (window.scrollY > panelTop) {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({ top: Math.max(panelTop, 0), behavior: reduceMotion ? 'auto' : 'smooth' });
      }
    }
  }

  // Use event delegation instead of individual listeners
  document.addEventListener('click', function(e) {
    const tabElement = e.target.closest('[data-tab]');
    if (tabElement) {
      e.preventDefault();
      const targetTab = tabElement.getAttribute('data-tab');
      activateTab(targetTab);
      // The click handler suppresses native anchor navigation, so mirror the
      // tab into the hash by hand — keeps deep links and back/forward sane.
      history.replaceState(null, '', '#' + targetTab);
    }
  });
  
  // Restore the tab named in the URL (hash deep-link, or legacy ?subscription
  // param used by Stripe checkout return URLs).
  const urlParams = new URLSearchParams(window.location.search);
  const hash = window.location.hash.substring(1);

  if (urlParams.has('subscription')) {
    activateTab('subscription');
  } else if (hash && document.getElementById(hash + '-content')) {
    activateTab(hash);
  }
}

// Initialize on DOM ready and Turbo navigation
document.addEventListener('DOMContentLoaded', initializeAccountPage);
document.addEventListener('turbo:load', initializeAccountPage);

function showPlanSelector() {
  document.getElementById('plan-selector').classList.remove('hidden');
}

function hidePlanSelector(event) {
  if (!event || event.target === event.currentTarget) {
    document.getElementById('plan-selector').classList.add('hidden');
  }
}
</script>