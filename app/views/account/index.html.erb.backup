                    <div class="absolute -top-3 left-1/2 transform -translate-x-1/2">
                      <span class="bg-indigo-500 text-white px-3 py-1 text-xs font-medium rounded-full">Most Popular</span>
                    </div>
                    <div class="text-center flex-grow">
                      <h3 class="text-lg font-medium text-gray-900 mb-2">Quarterly</h3>
                      <p class="text-sm text-gray-500 mb-4">Great value</p>
                      <div class="mb-2">
                        <span class="text-3xl font-bold text-gray-900">$38.97</span>
                        <span class="text-gray-500">/quarter</span>
                      </div>
                      <p class="text-sm text-green-600 font-medium mb-4">$12.99/month • Save 35%</p>
                      <ul class="text-sm text-gray-600 space-y-2 mb-6">
                        <li>Everything in Monthly</li>
                        <li>Priority support</li>
                        <li>Early access to new features</li>
                        <li>Cancel anytime</li>
                      </ul>
                    </div>
                    <button class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition-colors subscription-btn" data-plan="quarterly">
                      Choose Quarterly
                    </button>
                  </div>

                  <!-- Annual Plan -->
                  <div class="bg-white border-2 border-gray-200 rounded-lg p-6 hover:border-indigo-300 transition-colors flex flex-col">
