                </div>

                <!-- Money-back guarantee -->
                <div class="text-center py-6">
                  <div class="inline-flex items-center text-sm text-gray-600">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    30-day money-back guarantee • Cancel anytime • Join 1,200+ members
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">My Societies</h2>
              <p class="text-gray-600">Manage your whiskey societies and memberships</p>
            </div>
            
            <% user_societies = current_user.member_societies.includes(:creator) %>
            <% if user_societies.any? %>
              <div class="grid gap-6">
                <% user_societies.each do |society| %>
                  <a href="<%= society_path(society) %>" class="block bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md hover:border-indigo-300 transition-all duration-200 group">
                    <div class="text-center">
                      <!-- Society Icon -->
                      <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-105 transition-transform">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                          </svg>
                      </div>
                      
                      <!-- Society Name & Role Badge -->
                      <div class="mb-3">
                        <h3 class="text-base font-semibold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors"><%= society.name %></h3>
                            <% membership = current_user.society_memberships.find_by(society: society) %>
                            <% if membership&.admin? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Creator</span>
                            <% elsif membership&.officer? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Officer</span>
                            <% end %>
                      </div>
                      
                      <!-- Society Description -->
                      <p class="text-sm text-gray-600 mb-4 line-clamp-2 leading-relaxed">
                        <%= truncate(society.description, length: 80) %>
                      </p>
                      
                      <!-- Society Stats -->
                      <div class="flex justify-center space-x-6 text-xs text-gray-500">
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                          </svg>
                          <span><%= society.society_memberships.active.count %></span>
                        </div>
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                              </svg>
                          <span><%= society.events.count %></span>
                      </div>
                    </div>
                  </a>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No societies yet</h3>
                <p class="text-gray-500 mb-4">You haven't joined any whiskey societies yet.</p>
                <a href="<%= societies_path %>" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                  Discover Societies
                </a>
              </div>
            <% end %>
          </div>
        </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Handle tab navigation - immediate execution for debugging
  console.log('🚀 Account page JavaScript loaded');
  
  function initializeAccountTabs() {
    console.log('🔧 Initializing account tabs...');
    
    const tabs = document.querySelectorAll('[data-tab]');
    const contents = document.querySelectorAll('.tab-content');
    
    console.log('📋 Found tabs:', tabs.length);
    console.log('📄 Found content sections:', contents.length);
    
    if (tabs.length === 0) {
      console.error('❌ No tabs found! Check [data-tab] selectors');
      return;
    }
    
    if (contents.length === 0) {
      console.error('❌ No content sections found! Check .tab-content elements');
      return;
    }
    
    tabs.forEach((tab, index) => {
      console.log(`🏷️  Tab ${index}: ${tab.getAttribute('data-tab')}`);
      tab.addEventListener('click', function(e) {
        e.preventDefault();
        console.log('🖱️  Tab clicked:', this.getAttribute('data-tab'));
        
        // Remove active states
        tabs.forEach(t => {
          t.classList.remove('text-indigo-600', 'bg-indigo-50', 'border-l-4', 'border-indigo-600');
          t.classList.add('text-gray-700', 'hover:text-indigo-600', 'hover:bg-gray-50');
        });
        
        // Add active state to clicked tab
        this.classList.remove('text-gray-700', 'hover:text-indigo-600', 'hover:bg-gray-50');
        this.classList.add('text-indigo-600', 'bg-indigo-50', 'border-l-4', 'border-indigo-600');
        
        // Hide all content
        contents.forEach(content => content.classList.add('hidden'));
        
        // Show selected content
        const tabName = this.getAttribute('data-tab');
        const targetContent = document.getElementById(tabName + '-content');
        console.log('🎯 Showing content for:', tabName, targetContent);
        
        if (targetContent) {
          targetContent.classList.remove('hidden');
          console.log('✅ Content shown successfully');
        } else {
          console.error('❌ Content element not found:', tabName + '-content');
        }
      });
    });
  }
  
  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    console.log('📅 DOM loaded, initializing account functionality');
    
    // Handle tag selection
    const tagCheckboxes = document.querySelectorAll('input[name="tag_ids[]"]');
    tagCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const label = this.nextElementSibling;
        if (this.checked) {
          label.classList.remove('border-gray-300', 'text-gray-700', 'hover:border-indigo-300');
          label.classList.add('border-indigo-500', 'text-white');
          label.style.backgroundColor = label.dataset.color || '#3B82F6';
          label.style.borderColor = label.dataset.color || '#3B82F6';
        } else {
          label.classList.remove('border-indigo-500', 'text-white');
          label.classList.add('border-gray-300', 'text-gray-700', 'hover:border-indigo-300');
          label.style.backgroundColor = 'white';
          label.style.borderColor = '';
        }
      });
    });
    
    // Handle file upload with preview
    const avatarUpload = document.getElementById('avatar-upload');
    const profileImagePreview = document.getElementById('profile-image-preview');
    const profileImagePlaceholder = document.getElementById('profile-image-placeholder');
    const uploadLoading = document.getElementById('upload-loading');
    const removeAvatarBtn = document.getElementById('remove-avatar-btn');
    
    if (avatarUpload) {
      avatarUpload.addEventListener('change', function() {
        console.log('Avatar upload change event triggered');
        if (this.files && this.files[0]) {
          const file = this.files[0];
          console.log('File selected:', file.name, file.type, file.size);
          
          // Validate file type
          if (!file.type.startsWith('image/')) {
            alert('Please select a valid image file.');
            this.value = ''; // Clear the file input
            return;
          }
          
          // Validate file size (5MB limit)
          if (file.size > 5 * 1024 * 1024) {
            alert('Please select an image smaller than 5MB.');
            this.value = ''; // Clear the file input
            return;
          }
          
          // Show loading indicator
          uploadLoading.classList.remove('hidden');
          
          // Create preview
          const reader = new FileReader();
          reader.onload = function(e) {
            if (profileImagePreview) {
              profileImagePreview.src = e.target.result;
            } else if (profileImagePlaceholder) {
              // Replace placeholder with image
              const img = document.createElement('img');
              img.src = e.target.result;
              img.alt = 'Profile picture';
              img.className = 'w-20 h-20 rounded-full object-cover border-2 border-gray-200';
              img.id = 'profile-image-preview';
              profileImagePlaceholder.parentNode.replaceChild(img, profileImagePlaceholder);
            }
          };
          reader.readAsDataURL(file);
          
          // Submit form automatically
          console.log('Submitting avatar upload form...');
          this.closest('form').submit();
        }
      });
    }
    
    // Handle avatar removal
    if (removeAvatarBtn) {
      removeAvatarBtn.addEventListener('click', function() {
        if (confirm('Are you sure you want to remove your profile picture?')) {
          // Create a form to handle the removal
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/account/remove_avatar';
          
          const methodInput = document.createElement('input');
          methodInput.type = 'hidden';
          methodInput.name = '_method';
          methodInput.value = 'DELETE';
          form.appendChild(methodInput);
          
          const csrfInput = document.createElement('input');
          csrfInput.type = 'hidden';
          csrfInput.name = 'authenticity_token';
          csrfInput.value = document.querySelector('[name="authenticity_token"]').value;
          form.appendChild(csrfInput);
          
          document.body.appendChild(form);
          form.submit();
        }
      });
    }
    
    // Handle email change form show/hide
    const changeEmailBtn = document.getElementById('change-email-btn');
    const emailChangeForm = document.getElementById('email-change-form');
    const cancelEmailChange = document.getElementById('cancel-email-change');
    
    if (changeEmailBtn && emailChangeForm) {
      changeEmailBtn.addEventListener('click', function() {
        emailChangeForm.classList.remove('hidden');
        changeEmailBtn.classList.add('hidden');
      });
    }
    
    if (cancelEmailChange && emailChangeForm) {
      cancelEmailChange.addEventListener('click', function() {
        emailChangeForm.classList.add('hidden');
        changeEmailBtn.classList.remove('hidden');
        // Clear form fields
        emailChangeForm.querySelector('input[type="email"]').value = '';
      });
    }
    
    // Handle password change/add form show/hide
    const changePasswordBtn = document.getElementById('change-password-btn');
    const addPasswordBtn = document.getElementById('add-password-btn');
    const passwordChangeForm = document.getElementById('password-change-form');
    const cancelPasswordChange = document.getElementById('cancel-password-change');
    
    // Handle change password button
    if (changePasswordBtn && passwordChangeForm) {
      changePasswordBtn.addEventListener('click', function() {
        passwordChangeForm.classList.remove('hidden');
        changePasswordBtn.classList.add('hidden');
      });
    }
    
    // Handle add password button  
    if (addPasswordBtn && passwordChangeForm) {
      addPasswordBtn.addEventListener('click', function() {
        passwordChangeForm.classList.remove('hidden');
        addPasswordBtn.classList.add('hidden');
      });
    }
    
    if (cancelPasswordChange && passwordChangeForm) {
      cancelPasswordChange.addEventListener('click', function() {
        passwordChangeForm.classList.add('hidden');
        // Show the correct button based on which one exists
        if (changePasswordBtn) changePasswordBtn.classList.remove('hidden');
        if (addPasswordBtn) addPasswordBtn.classList.remove('hidden');
        
        // Clear form fields
        const currentPasswordField = passwordChangeForm.querySelector('input[name="current_password"]');
        if (currentPasswordField) currentPasswordField.value = '';
        passwordChangeForm.querySelector('input[name="new_password"]').value = '';
        passwordChangeForm.querySelector('input[name="confirm_password"]').value = '';
      });
    }
    
    // Handle subscription button clicks
    const subscriptionButtons = document.querySelectorAll('.subscription-btn');
    subscriptionButtons.forEach(button => {
      button.addEventListener('click', function() {
        const plan = this.dataset.plan;
        console.log('🔔 Subscription button clicked:', plan);
        
        // Disable button and show loading state
        this.disabled = true;
        const originalText = this.textContent;
        this.textContent = 'Processing...';
        
        // Create checkout session
        fetch('/subscriptions/checkout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
          },
          body: JSON.stringify({ plan: plan })
        })
        .then(response => response.json())
        .then(data => {
          if (data.checkout_url) {
            // Redirect to Stripe checkout
            window.location.href = data.checkout_url;
          } else {
            throw new Error(data.error || 'Failed to create checkout session');
          }
        })
        .catch(error => {
          console.error('❌ Subscription error:', error);
          alert('Failed to start checkout process. Please try again.');
          
          // Re-enable button
          this.disabled = false;
          this.textContent = originalText;
        });
      });
    });
    
    // Initialize account tabs
    initializeAccountTabs();
  });
  
  // Also try to initialize immediately in case DOMContentLoaded already fired
  if (document.readyState === 'loading') {
    console.log('📅 Document still loading, waiting for DOMContentLoaded');
  } else {
    console.log('📅 Document already loaded, initializing tabs immediately');
    initializeAccountTabs();
  }
  
  // Handle Turbo navigation
  document.addEventListener('turbo:load', function() {
    console.log('🔄 Turbo load event, reinitializing tabs');
    initializeAccountTabs();
  });
  
  document.addEventListener('turbo:render', function() {
    console.log('🎨 Turbo render event, reinitializing tabs');
    initializeAccountTabs();
  });
</script>
