                  <div class="bg-white border-2 border-gray-200 rounded-lg p-6 hover:border-indigo-300 transition-colors flex flex-col">
                    <div class="text-center flex-grow">
                      <h3 class="text-lg font-medium text-gray-900 mb-2">Monthly</h3>
                      <p class="text-sm text-gray-500 mb-4">Perfect for trying it out</p>
                      <div class="mb-4">
                        <span class="text-3xl font-bold text-gray-900">$19.99</span>
                        <span class="text-gray-500">/month</span>
                      </div>
                      <ul class="text-sm text-gray-600 space-y-2 mb-6">
                        <li>Unlimited presentations</li>
                        <li>Access to public societies</li>
                        <li>Event RSVP & forums</li>
