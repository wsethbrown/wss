                  <h3 class="text-lg font-medium text-indigo-900 mb-4">What's included with a subscription:</h3>
                  <div class="grid md:grid-cols-2 gap-4">
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-indigo-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <div>
                        <p class="font-medium text-indigo-900">Unlimited Presentations</p>
                        <p class="text-sm text-indigo-700">Access to all 12+ professional whiskey presentations</p>
                      </div>
                    </div>
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-indigo-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <div>
                        <p class="font-medium text-indigo-900">Private Societies</p>
                        <p class="text-sm text-indigo-700">Apply to join exclusive, curated whiskey clubs</p>
                      </div>
                    </div>
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-indigo-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <div>
                        <p class="font-medium text-indigo-900">Monthly Credits</p>
                        <p class="text-sm text-indigo-700">1 credit per month for premium content</p>
                      </div>
                    </div>
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-indigo-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <div>
                        <p class="font-medium text-indigo-900">Premium Events</p>
                        <p class="text-sm text-indigo-700">RSVP to exclusive tastings and events</p>
                      </div>
                    </div>
                  </a>
                </div>

                <!-- Subscription plans -->
