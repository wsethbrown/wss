<% content_for :title, "Account - Whiskey Share Society" %>

<div class="min-h-screen">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex">
      <!-- Sidebar Navigation -->
      <div class="w-64 flex-shrink-0 sticky top-8 h-fit">
        <div class="pr-8">
          <h1 class="text-2xl font-bold text-gray-900 mb-6">Account</h1>
          <nav class="space-y-2">
            <a href="#profile" class="flex items-center px-3 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 rounded-md border-l-4 border-indigo-600 group" data-tab="profile">
              <svg class="w-5 h-5 mr-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              Profile
            </a>
            <a href="#account-details" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="account-details">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Account Details
            </a>
            <a href="#presentations" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="presentations">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              My Presentations
            </a>
            <a href="#societies" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="societies">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              My Societies
            </a>
            <a href="#subscription" class="flex items-center px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-md group" data-tab="subscription">
              <svg class="w-5 h-5 mr-3 text-gray-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
              </svg>
              Subscription
            </a>
          </nav>
        </div>
      </div>

      <!-- Main Content Area -->
      <div class="w-full ml-8 min-h-screen">
        <div class="w-[800px]">
        <!-- Profile Tab Content -->
        <div id="profile-content" class="tab-content min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Profile</h2>
              <p class="text-gray-600">Manage your public profile and whiskey preferences</p>
            </div>

            <!-- Profile Picture Section -->
            <div class="mb-8">
              <div class="flex items-center space-x-6">
                <div class="flex-shrink-0">
                  <div class="relative">
                    <% if current_user.has_profile_image? %>
                      <img src="<%= current_user.profile_image_url %>" alt="Profile picture" class="w-20 h-20 rounded-full object-cover border-2 border-gray-200" id="profile-image-preview">
                    <% else %>
                      <div class="w-20 h-20 rounded-full flex items-center justify-center text-white font-bold text-lg border-2 border-gray-200" 
                           id="profile-image-placeholder" 
                           style="background-color: <%= current_user.avatar_color %>;">
                        <%= current_user.initials %>
                      </div>
                    <% end %>
                    <!-- Loading indicator -->
                    <div class="absolute inset-0 rounded-full bg-black bg-opacity-50 flex items-center justify-center hidden" id="upload-loading">
                      <svg class="w-6 h-6 text-white animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                      </svg>
                    </div>
                  </a>
                </div>
                <div>
                  <h3 class="text-lg font-medium text-gray-900">Profile Picture</h3>
                  <p class="text-sm text-gray-500">Upload a photo to personalize your profile</p>
                  <div class="mt-2">
                    <%= form_with url: account_avatar_path, method: :patch, local: true, multipart: true, class: "flex items-center space-x-3", id: "avatar-upload-form" do |form| %>
                      <input type="file" accept="image/*" name="profile_image" class="hidden" id="avatar-upload">
                      <label for="avatar-upload" class="cursor-pointer inline-flex items-center px-3 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        Choose file
                      </label>
                      <span class="text-xs text-gray-400">JPG, PNG, GIF, WebP (max 5MB)</span>
                      <% if current_user.has_profile_image? %>
                        <button type="button" class="inline-flex items-center px-3 py-2 border border-red-300 rounded-md text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 transition-colors" id="remove-avatar-btn">
                          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                          </svg>
                          Remove
                        </button>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>

            <!-- Profile Form -->
            <%= form_with url: account_profile_path, method: :patch, local: true, class: "space-y-6" do |form| %>
              <!-- Name Fields -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">First Name</label>
                  <%= form.text_field :first_name, value: current_user.first_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Last Name</label>
                  <%= form.text_field :last_name, value: current_user.last_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
                </div>
              </div>

              <!-- Bio -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Bio</label>
                <%= form.text_area :bio, value: current_user.bio, rows: 4, placeholder: "Tell us about yourself and your whiskey journey...", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
              </div>

              <!-- Save Button -->
              <div class="flex justify-end pt-4">
                <%= form.submit "Save Changes", class: "px-6 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
              </div>
            <% end %>

            <!-- Tags Section -->
            <div class="mt-8 pt-8 border-t border-gray-200">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Your Tags</h3>
              <p class="text-sm text-gray-500 mb-6">Select tags that describe your whiskey interests, skills, and preferences</p>
              
              <%= form_with url: account_tags_path, method: :patch, local: true do |form| %>
                <% @available_tags.group_by(&:category).each do |category, tags| %>
                  <div class="mb-6">
                    <h4 class="text-sm font-medium text-gray-700 mb-3 capitalize"><%= category.humanize %></h4>
                    <div class="flex flex-wrap gap-2">
                      <% tags.each do |tag| %>
                        <% checked = current_user.tags.include?(tag) %>
                        <label class="inline-flex items-center cursor-pointer">
                          <input type="checkbox" name="tag_ids[]" value="<%= tag.id %>" <%= 'checked' if checked %> class="sr-only">
                          <span class="px-3 py-1 rounded-full text-sm font-medium border-2 transition-all duration-200 <%= checked ? 'border-indigo-500 text-white' : 'border-gray-300 text-gray-700 hover:border-indigo-300' %>" style="<%= checked ? "background-color: #{tag.color}; border-color: #{tag.color};" : "background-color: white;" %>">
                            <%= tag.display_name %>
                          </span>
                        </label>
                      <% end %>
                    </div>
                  </a>
                <% end %>
                
                <div class="flex justify-end pt-4">
                  <%= form.submit "Update Tags", class: "px-6 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Account Details Tab Content -->
        <div id="account-details-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Account Details</h2>
              <p class="text-gray-600">Manage your account settings and security preferences</p>
            </div>
            
            <!-- Email Change Section -->
            <div class="space-y-6">
              <div>
                <h3 class="text-lg font-medium text-gray-900 mb-4">Email Address</h3>
                <p class="text-sm text-gray-500 mb-4">Your current email address is used for login and important notifications</p>
                
                <div class="flex items-center justify-between py-3 px-4 bg-gray-50 rounded-lg">
                  <div>
                    <p class="font-medium text-gray-900"><%= current_user.email %></p>
                    <p class="text-sm text-gray-500">Current email address</p>
                    <% if current_user.has_pending_email_change? %>
                      <div class="mt-2 flex items-center">
                        <svg class="w-4 h-4 text-yellow-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                        </svg>
                        <p class="text-sm text-yellow-700">
                          Pending change to: <span class="font-medium"><%= current_user.unconfirmed_email %></span>
                        </p>
                      </div>
                    <% end %>
                  </div>
                  <% unless current_user.has_pending_email_change? %>
                    <button type="button" class="inline-flex items-center px-3 py-2 border border-indigo-300 rounded-md text-sm font-medium text-indigo-700 bg-indigo-50 hover:bg-indigo-100 transition-colors" id="change-email-btn">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                      Change Email
                    </button>
                  <% else %>
                    <div class="text-sm text-gray-500">
                      <p>Check your email for verification link</p>
                      <p class="text-xs">Expires: <%= current_user.email_change_token_expires_at.strftime("%m/%d at %I:%M %p") %></p>
                    </div>
                  <% end %>
                </div>
                
                <!-- Email Change Form (hidden by default) -->
                <div id="email-change-form" class="hidden mt-6 p-6 bg-blue-50 border border-blue-200 rounded-lg">
                  <%= form_with url: account_change_email_path, method: :patch, local: true, class: "space-y-4" do |form| %>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">New Email Address</label>
                      <%= form.email_field :new_email, placeholder: "Enter your new email address", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
                    </div>
                    
                    <div class="bg-yellow-50 border border-yellow-200 rounded-md p-3">
                      <div class="flex">
                        <svg class="w-5 h-5 text-yellow-400 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                        </svg>
                        <div>
                          <p class="text-sm text-yellow-800">
                            We'll send a verification link to your current email address (<strong><%= current_user.email %></strong>). You must click the link to confirm the email change.
                          </p>
                        </div>
                      </div>
                    </div>
                    
                    <div class="flex space-x-3">
                      <%= form.submit "Request Email Change", class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
                      <button type="button" class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors" id="cancel-email-change">
                        Cancel
                      </button>
                    </div>
                  <% end %>
                </div>
              </div>
              
              <!-- Account Security Section -->
              <div>
                <h3 class="text-lg font-medium text-gray-900 mb-4">Authentication & Security</h3>
                <p class="text-sm text-gray-500 mb-4">Manage your authentication methods and account security settings</p>
                
                <!-- Current Authentication Methods -->
                <div class="mb-6 p-4 bg-gray-50 rounded-lg">
                  <h4 class="text-sm font-medium text-gray-900 mb-3">Current Authentication Methods</h4>
                  <div class="flex flex-wrap gap-2">
                    <% current_user.authentication_methods.each do |method| %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                        <% case method %>
                        <% when "Magic Link" %>
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 7.89a2 2 0 002.83 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                          </svg>
                        <% when "Password" %>
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1721 9z"></path>
                          </svg>
                        <% when "2FA" %>
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                          </svg>
                        <% end %>
                        <%= method %>
                      </span>
                    <% end %>
                  </div>
                  <p class="text-xs text-gray-500 mt-2">Primary method: <%= current_user.primary_authentication_method %></p>
                </div>
                
                <div class="space-y-4">
                  <div class="flex items-center justify-between py-3 px-4 bg-gray-50 rounded-lg">
                    <div>
                      <p class="font-medium text-gray-900">Password Authentication</p>
                      <% if current_user.passwordless_only? %>
                        <p class="text-sm text-gray-500">Not set up yet</p>
                        <p class="text-xs text-yellow-600 mt-1">Add a password for enhanced security and additional login options</p>
                      <% else %>
                        <p class="text-sm text-gray-500">••••••••••••</p>
                        <p class="text-xs text-green-600 mt-1">Password is set up and ready to use</p>
                      <% end %>
                    </div>
                    <% if current_user.passwordless_only? %>
                      <button type="button" class="inline-flex items-center px-3 py-2 border border-indigo-300 rounded-md text-sm font-medium text-indigo-700 bg-indigo-50 hover:bg-indigo-100 transition-colors" id="add-password-btn">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        Add Password
                      </button>
                    <% else %>
                      <button type="button" class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors" id="change-password-btn">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1721 9z"></path>
                        </svg>
                        Change Password
                      </button>
                    <% end %>
                  </div>
                  
                  <!-- Password Add/Change Form (hidden by default) -->
                  <div id="password-change-form" class="hidden mt-6 p-6 bg-blue-50 border border-blue-200 rounded-lg">
                    <%= form_with url: account_change_password_path, method: :patch, local: true, class: "space-y-4" do |form| %>
                      <% if current_user.has_password? %>
                        <div>
                          <label class="block text-sm font-medium text-gray-700 mb-2">Current Password</label>
                          <%= form.password_field :current_password, placeholder: "Enter your current password", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
                        </div>
                      <% else %>
                        <div class="bg-green-50 border border-green-200 rounded-md p-4">
                          <div class="flex">
                            <svg class="w-5 h-5 text-green-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <div>
                              <p class="text-sm text-green-700 font-medium">Adding password authentication</p>
                              <p class="text-xs text-green-600 mt-1">You'll still be able to use magic links after adding a password. This gives you more login options!</p>
                            </div>
                          </div>
                        </div>
                      <% end %>
                      
                      <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2"><%= current_user.has_password? ? "New Password" : "Password" %></label>
                        <%= form.password_field :new_password, placeholder: current_user.has_password? ? "Enter your new password" : "Choose a password", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
                        <p class="text-xs text-gray-500 mt-1">Must be at least 8 characters long</p>
                      </div>
                      
                      <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2"><%= current_user.has_password? ? "Confirm New Password" : "Confirm Password" %></label>
                        <%= form.password_field :confirm_password, placeholder: current_user.has_password? ? "Confirm your new password" : "Confirm your password", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
                      </div>
                      
                      <div class="flex items-center justify-end space-x-3 pt-4">
                        <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" id="cancel-password-change">
                          Cancel
                        </button>
                        <%= form.submit current_user.has_password? ? "Update Password" : "Add Password", class: "px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Other tab contents would go here -->
        <div id="presentations-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">My Presentations</h2>
              <p class="text-gray-600">Access and manage your whiskey presentations</p>
            </div>
            <div class="text-center py-12">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <h3 class="text-lg font-medium text-gray-900 mb-2">No presentations yet</h3>
              <p class="text-gray-500">Your purchased presentations will appear here.</p>
            </div>
          </div>
        </div>

        <div id="societies-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">My Societies</h2>
              <p class="text-gray-600">Manage your whiskey societies and memberships</p>
            </div>
            
            <% user_societies = current_user.member_societies.includes(:creator) %>
            <% if user_societies.any? %>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% user_societies.each do |society| %>
                  <a href="<%= society_path(society) %>" class="block bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md hover:border-indigo-300 transition-all duration-200 group">
                    <div class="text-center">
                      <!-- Society Icon -->
                      <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-105 transition-transform">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                          </svg>
                      </div>
                      
                      <!-- Society Name & Role Badge -->
                      <div class="mb-3">
                        <h3 class="text-base font-semibold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors"><%= society.name %></h3>
                            <% membership = current_user.society_memberships.find_by(society: society) %>
                            <% if membership&.admin? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Creator</span>
                            <% elsif membership&.officer? %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Officer</span>
                            <% end %>
                      </div>
                      
                      <!-- Society Description -->
                      <p class="text-sm text-gray-600 mb-4 line-clamp-2 leading-relaxed">
                        <%= truncate(society.description, length: 80) %>
                      </p>
                      
                      <!-- Society Stats -->
                      <div class="flex justify-center space-x-6 text-xs text-gray-500">
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 515.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                          </svg>
                          <span><%= society.society_memberships.active.count %></span>
                        </div>
                        <div class="flex items-center">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                              </svg>
                          <span><%= society.events.count %></span>
                      </div>
                    </div>
                  </a>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 515.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 919.288 0M15 7a3 3 0 11-6 0 3 3 0 616 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No societies yet</h3>
                <p class="text-gray-500 mb-4">You haven't joined any whiskey societies yet.</p>
                <a href="<%= societies_path %>" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                  Discover Societies
                </a>
              </div>
            <% end %>
          </div>
        </div>

        <div id="subscription-content" class="tab-content hidden min-h-[600px]">
          <div class="space-y-8">
            <div class="pb-6 border-b border-gray-200">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Subscription</h2>
              <% if current_user.has_active_subscription? %>
                <p class="text-gray-600">Manage your subscription and billing preferences</p>
              <% else %>
                <p class="text-gray-600">Choose a subscription plan to unlock premium features and exclusive content</p>
              <% end %>
            </div>
            
            <% if current_user.has_active_subscription? %>
              <!-- Active subscription management -->
              <div class="space-y-6">
                <!-- Current plan section -->
                <div class="bg-white border border-gray-200 rounded-lg p-6">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center mr-4">
                        <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
                        </svg>
                      </div>
                      <div>
                        <h3 class="text-lg font-medium text-gray-900"><%= current_user.subscription_plan_display %></h3>
                        <p class="text-sm text-gray-500">
                          <% if current_user.subscription_ends_at %>
                            <% if current_user.subscription_status == 'cancelled' %>
                              Your subscription ends on <%= current_user.subscription_ends_at.strftime("%B %d, %Y") %>
                            <% else %>
                              Your subscription will auto renew on <%= current_user.subscription_ends_at.strftime("%b %d, %Y") %>
                            <% end %>
                          <% else %>
                            Active subscription
                          <% end %>
                        </p>
                      </div>
                    </div>
                    <div class="text-right">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <%= current_user.subscription_status_display %>
                      </span>
                      <a href="/subscriptions/portal" class="block mt-2 text-sm text-indigo-600 hover:text-indigo-800">Adjust plan</a>
                    </div>
                  </a>
