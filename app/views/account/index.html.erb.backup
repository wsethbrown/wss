                      </ul>
                    </div>
                    <button class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition-colors subscription-btn" data-plan="monthly">
                      Choose Monthly
                    </button>
                  </div>

                  <!-- Quarterly Plan -->
