                      </div>
                    </div>
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <div>
                        <p class="font-medium text-gray-900">Monthly Credits</p>
                        <p class="text-sm text-gray-500">1 credit per month for premium content</p>
                      </div>
                    </div>
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <div>
                        <p class="font-medium text-gray-900">Premium Events</p>
                        <p class="text-sm text-gray-500">RSVP to exclusive tastings</p>
                      </div>
                    </div>
                  </a>
                </div>

                <!-- Recent invoices section -->
                <div class="bg-white border border-gray-200 rounded-lg p-6">
                  <div class="flex items-center justify-between mb-4">
                    <h4 class="text-base font-medium text-gray-900">Invoices</h4>
                    <a href="/subscriptions/portal" class="text-sm text-indigo-600 hover:text-indigo-800">View all</a>
                  </div>
                  <div class="space-y-3">
                    <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-b-0">
                      <div>
                        <p class="text-sm font-medium text-gray-900">Jul 8, 2025</p>
                        <p class="text-sm text-gray-500">Payment succeeded</p>
                      </div>
                      <div class="text-right">
                        <p class="text-sm font-medium text-gray-900">$19.99</p>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Paid</span>
                      </div>
                    </div>
                    <!-- Add more invoice items as needed -->
                  </div>
                </div>
              </div>
            <% else %>
              <!-- Subscription options for non-subscribers -->
