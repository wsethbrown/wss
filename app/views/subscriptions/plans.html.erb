<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <%= link_to account_path(anchor: "subscription"), class: "text-gray-500 hover:text-gray-700" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
          <% end %>
          <h1 class="text-2xl font-semibold text-gray-900">Plans that grow with you</h1>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Current Plan Reminder -->
    <% if current_user.cancel_at_period_end? %>
      <div class="mb-8 p-4 bg-amber-50 border border-amber-200 rounded-lg">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
          </svg>
          <p class="text-sm text-amber-800">
            Your <strong><%= @current_plan.capitalize %></strong> plan is set to cancel on <%= current_user.subscription_ends_at.strftime('%B %d, %Y') %>. 
            Reactivate your subscription by selecting a plan below.
          </p>
        </div>
      </div>
    <% else %>
      <div class="mb-8 p-4 bg-blue-50 border border-blue-200 rounded-lg">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <p class="text-sm text-blue-800">
            You're currently on the <strong><%= @current_plan.capitalize %></strong> plan. Choose a different plan below to upgrade or downgrade.
          </p>
        </div>
      </div>
    <% end %>

    <!-- Plan Cards -->
    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <% @stripe_products.reject { |p| p[:id] == @current_plan }.each do |product| %>
        <div class="bg-white rounded-2xl shadow-lg border-2 <%= product[:popular] ? 'border-indigo-500' : 'border-gray-200' %> relative overflow-hidden flex flex-col h-full cursor-pointer" onclick="document.getElementById('plan-form-<%= product[:id] %>').submit()">
          <% if product[:popular] %>
            <div class="absolute top-0 right-0 bg-indigo-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">
              MOST POPULAR
            </div>
          <% end %>

          <div class="p-8 flex flex-col h-full">
            <div class="flex-grow">
              <h3 class="text-2xl font-bold text-gray-900 mb-2"><%= product[:name] %></h3>

              <div class="flex items-baseline gap-2 mb-6">
                <span class="text-4xl font-bold text-gray-900">$<%= sprintf('%.2f', product[:price] / 100.0) %></span>
                <span class="text-gray-500">/month</span>
                <% if product[:id] != 'monthly' %>
                  <span class="text-sm text-gray-500">
                    billed <%= product[:id] %>
                  </span>
                <% end %>
              </div>

              <% if product[:savings] %>
                <div class="inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-800 text-sm font-semibold mb-6">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  Save <%= product[:savings] %>
                </div>
              <% end %>

              <ul class="space-y-3 mb-8">
                <% product[:features].each do |feature| %>
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700"><%= feature %></span>
                  </li>
                <% end %>
              </ul>
            </div>

            <div class="mt-auto">
              <%
                action_text = if product[:price] < (@stripe_products.find { |p| p[:id] == @current_plan }&.dig(:price) || 1599)
                               "Update to #{product[:name].split(' ').first}"
                             else
                               "Update to #{product[:name].split(' ').first}"
                             end
              %>
              <button class="w-full px-6 py-3 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 transition-colors cursor-pointer">
                <%= action_text %>
              </button>
            </div>
          </div>
        </div>
        
        <!-- Hidden form for this plan -->
        <%= form_with url: subscriptions_change_plan_path, method: :post, local: true, id: "plan-form-#{product[:id]}", class: "hidden" do |f| %>
          <%= f.hidden_field :plan, value: product[:id] %>
        <% end %>
      <% end %>
    </div>

    <!-- Info Section -->
    <div class="bg-gray-100 rounded-lg p-6">
      <h4 class="font-semibold text-gray-900 mb-3 text-center">Good to know</h4>
      <ul class="space-y-2 text-sm text-gray-600 max-w-md mx-auto">
        <li class="flex items-start">
          <svg class="w-4 h-4 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>Plan changes take effect immediately</span>
        </li>
        <li class="flex items-start">
          <svg class="w-4 h-4 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>You'll be credited for any unused time when upgrading</span>
        </li>
        <li class="flex items-start">
          <svg class="w-4 h-4 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>Downgrading will apply at the end of your current billing period</span>
        </li>
        <li class="flex items-start">
          <svg class="w-4 h-4 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>All plans include 1 credit per month for presentation purchases</span>
        </li>
      </ul>
    </div>

    <!-- Cancel Link -->
    <% unless current_user.cancel_at_period_end? %>
      <div class="text-center mt-8">
        <p class="text-sm text-gray-600 mb-2">Want to cancel instead?</p>
        <%= button_to "Cancel subscription", subscriptions_cancel_path, 
            method: :post,
            class: "text-sm text-red-600 hover:text-red-700 font-medium underline",
            form: { data: { turbo_confirm: "Are you sure you want to cancel your subscription? You'll retain access until your current billing period ends." } } %>
      </div>
    <% end %>
  </div>
</div>