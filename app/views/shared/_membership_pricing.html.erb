<%# Plan cards + free-vs-member comparison. Shared by the homepage
    (#pricing) and the standalone /membership page. Needs @stripe_products. %>
<section id="pricing" class="w-full bg-whiskey-50 px-6 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4 text-whiskey-600">Membership</p>
      <h2 class="font-display text-4xl font-semibold text-gray-900 sm:text-5xl">Choose your pour.</h2>
      <p class="mt-6 text-lg text-gray-600">
        One membership, three ways to pay it. Every plan unlocks the same
        thing, a deck credit every month and a society of your own.
        Stay longer, pay less.
      </p>
    </div>

    <div id="plan-cards" class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      <% @stripe_products.each do |product| %>
        <div class="relative flex flex-col rounded-3xl bg-white p-8 shadow-xl transition hover:-translate-y-1 hover:shadow-2xl <%= product[:popular] ? 'border-2 border-whiskey-400' : 'border border-gray-200' %>">
          <% if product[:popular] %>
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="eyebrow rounded-full border border-whiskey-500 bg-whiskey-600 px-4 py-1.5 text-white shadow-sm">Best Value</span>
            </div>
          <% end %>

          <div class="text-center">
            <h3 class="font-display text-2xl font-semibold text-gray-900"><%= product[:name].gsub(' Membership', '') %></h3>
            <p class="mt-1 text-gray-500"><%=
              case product[:id]
              when 'monthly' then 'Pay as you go, cancel anytime'
              when 'quarterly' then 'Billed every three months'
              when 'yearly' then 'Billed once a year'
              else 'For committed members'
              end
            %></p>

            <div class="mt-6">
              <div class="flex items-end justify-center">
                <span class="font-display text-5xl font-semibold <%= product[:popular] ? 'text-whiskey-700' : 'text-gray-900' %>">$<%= sprintf('%.2f', product[:price] / 100.0) %></span>
                <span class="ml-1 pb-1 text-lg text-gray-400">/mo</span>
              </div>
              <% if product[:id] == 'quarterly' || product[:id] == 'yearly' %>
                <div class="mt-1 text-sm text-gray-500">billed <%= product[:id] == 'quarterly' ? 'quarterly' : 'annually' %></div>
              <% end %>
              <% if product[:savings] %>
                <div class="mt-3 inline-flex items-center rounded-full bg-whiskey-100 px-3 py-1 text-sm font-semibold text-whiskey-800">Save <%= product[:savings] %></div>
              <% end %>
            </div>
          </div>

          <%# mt-auto pins every card's CTA to the same baseline; the cards are
              different heights (only some have a billed-line and savings chip). %>
          <div class="mt-auto pt-8">
            <% if user_signed_in? && current_user.subscription_active? %>
              <%# Members don't need three checkout buttons. Mark their plan;
                  changes happen from the account page. %>
              <% if current_user.subscription_plan == product[:id] %>
                <div class="w-full rounded-xl border-2 border-whiskey-400 bg-whiskey-50 px-6 py-3 text-center text-base font-semibold text-whiskey-800">
                  Your current plan
                </div>
              <% else %>
                <%= link_to 'Manage in your account', account_path(anchor: 'subscription'),
                    class: "block w-full rounded-xl border border-gray-300 px-6 py-3 text-center text-base font-semibold text-gray-700 transition hover:bg-gray-50" %>
              <% end %>
            <% elsif user_signed_in? %>
              <%= form_with url: subscriptions_checkout_path, method: :post, local: true, data: { turbo: false } do |f| %>
                <%= f.hidden_field :price_id, value: product[:id] %>
                <%= f.submit "Get Started", class: "w-full cursor-pointer rounded-xl px-6 py-3 text-base font-semibold text-white transition focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2 #{product[:popular] ? 'bg-whiskey-600 hover:bg-whiskey-700' : 'bg-gray-900 hover:bg-gray-800'}" %>
              <% end %>
            <% else %>
              <%= link_to 'Get Started', auth_path,
                  class: "block w-full rounded-xl px-6 py-3 text-center text-base font-semibold text-white transition focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2 #{product[:popular] ? 'bg-whiskey-600 hover:bg-whiskey-700' : 'bg-gray-900 hover:bg-gray-800'}" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Founding Members: shown only while slots remain, and only to accounts
        that can still take the offer. Separate from #plan-cards on purpose;
        that DOM contract is pinned by tests. %>
    <% founding_slots = User.founding_slots_remaining %>
    <% if founding_slots.positive? && (!user_signed_in? || current_user.founding_eligible?) %>
      <% founding = SubscriptionProducts.founding %>
      <div class="mx-auto mt-14 max-w-4xl rounded-3xl border border-whiskey-300 bg-char p-8 sm:p-10">
        <p class="eyebrow text-whiskey-300/90">Founding members</p>
        <h3 class="mt-2 font-display text-3xl font-semibold text-cream">The first fifty</h3>
        <p class="mt-3 max-w-2xl text-cream/70">
          Fifty founding spots, then these offers are gone. Keep your founding rate for as long as
          your membership stays active. Pause anytime; cancel and it's gone for good.
        </p>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          <% founding.each do |offer| %>
            <div class="rounded-2xl border border-oak-edge bg-oak p-6">
              <h4 class="font-display text-xl font-semibold text-cream"><%= offer[:name] %></h4>
              <p class="mt-1 font-display text-3xl font-semibold text-whiskey-300">
                $<%= number_with_precision(offer[:price] / 100.0, precision: 2) %><span class="text-base text-cream/50">/mo</span>
              </p>
              <p class="mt-3 text-sm leading-relaxed text-cream/70">
                <% if offer[:id] == "founding_society" %>
                  Create and run your own society: events, RSVPs, invites, members. No monthly deck credit; buy any deck outright whenever you like.
                <% else %>
                  The full membership at $5 off, the same rate as the yearly plan, billed monthly. One deck credit every month.
                <% end %>
              </p>
              <% if user_signed_in? %>
                <%= form_with url: subscriptions_checkout_path, method: :post, local: true, data: { turbo: false } do |f| %>
                  <%= f.hidden_field :price_id, value: offer[:id] %>
                  <%= f.submit "Claim a founding spot", class: "mt-5 w-full cursor-pointer rounded-xl bg-whiskey-500 px-6 py-3 text-base font-semibold text-white transition hover:bg-whiskey-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char" %>
                <% end %>
              <% else %>
                <%= link_to "Sign in to claim a spot", auth_path,
                    class: "mt-5 block w-full rounded-xl bg-whiskey-500 px-6 py-3 text-center text-base font-semibold text-white transition hover:bg-whiskey-400" %>
              <% end %>
            </div>
          <% end %>
        </div>
        <p class="mt-6 text-center text-sm text-whiskey-300/80"><%= founding_slots %> of <%= User::FOUNDING_MEMBER_CAP %> founding spots left</p>
      </div>
    <% end %>

    <%# Free vs paid, side by side: the review section and joining societies
        are free (that's the everyday reason to have an account); membership
        adds deck credits and the ability to run your own society. %>
    <div class="mx-auto mt-14 grid max-w-4xl gap-6 md:grid-cols-2">
      <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
        <p class="eyebrow text-gray-400">Free with any account</p>
        <h3 class="mt-1 font-display text-lg font-semibold text-gray-900">No membership needed</h3>
        <ul class="mt-5 space-y-3 text-gray-700">
          <% Membership::FREE.each do |item| %>
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-4 w-4 flex-shrink-0 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span><%= item %></span>
            </li>
          <% end %>
        </ul>
      </div>
      <div class="rounded-3xl border-2 border-whiskey-200 bg-white p-8 shadow-sm">
        <p class="eyebrow text-whiskey-600">Membership adds</p>
        <h3 class="mt-1 font-display text-lg font-semibold text-gray-900">Everything above, plus</h3>
        <ul class="mt-5 space-y-3 text-gray-700">
          <% Membership::BENEFITS.each do |benefit| %>
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-4 w-4 flex-shrink-0 text-whiskey-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span><%= benefit %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-gray-500">
      Credits unlock any deck while your membership is active. Decks bought outright are yours for good.
    </p>
  </div>
</section>
