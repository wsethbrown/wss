<% 
  size_class = case local_assigns[:size]
               when 'large'
                 'w-full h-full'
               when 'small'
                 'w-3 h-3'
               else
                 'w-6 h-6'
               end
  
  icon_size_class = case local_assigns[:size]
                    when 'large'
                      'w-10 h-10 text-white'
                    when 'small'
                      'w-3 h-3 text-white'
                    else
                      'w-6 h-6 text-white'
                    end
%>

<% if society.profile_picture.attached? && society.profile_picture.blob.present? %>
  <!-- Custom Profile Picture -->
  <% begin %>
    <% content_type = society.profile_picture.blob.content_type&.downcase %>
    <% if content_type&.include?("heic") || content_type&.include?("heif") %>
      <!-- HEIC image detected, converting to JPEG -->
      <%= image_tag society.profile_picture.variant(resize_to_limit: [200, 200], format: :jpeg), 
          class: "w-full h-full object-cover rounded-xl" %>
    <% else %>
      <!-- Standard image format -->
      <%= image_tag society.profile_picture, 
          class: "w-full h-full object-cover rounded-xl" %>
    <% end %>
  <% rescue => e %>
    <!-- Error loading image: <%= e.message %> -->
    <div class="w-full h-full flex items-center justify-center text-white">
      <span class="text-4xl">🏛️</span>
    </div>
  <% end %>
<% else %>
  <!-- Default Emoji Icons Based on Privacy -->
  <div class="w-full h-full flex items-center justify-center text-white">
    <% if society.is_private %>
      <span class="<%= case local_assigns[:size]
                      when 'large' then 'text-4xl'
                      when 'small' then 'text-sm'
                      else 'text-2xl'
                      end %>">🔒</span>
    <% else %>
      <span class="<%= case local_assigns[:size]
                      when 'large' then 'text-4xl'
                      when 'small' then 'text-sm'
                      else 'text-2xl'
                      end %>">🏛️</span>
    <% end %>
  </div>
<% end %>