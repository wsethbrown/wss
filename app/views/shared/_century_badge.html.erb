<%# Century badge — 100+ followers (users and societies). Renders nothing
    below the threshold, so call sites don't need their own guard.
    locals: record (responds to #century?), tone (:light for paper
    surfaces, :dark for char). The CENTURY label's own text baseline keeps
    the pill aligned with the surrounding name in baseline contexts. %>
<% tone = local_assigns.fetch(:tone, :light) %>
<% if record.century? %>
  <span class="inline-flex items-baseline gap-1 rounded-full px-2 py-0.5 <%= tone == :dark ? 'border border-whiskey-300/40 bg-whiskey-500/20' : 'border border-whiskey-300 bg-whiskey-50' %>"
        title="Century — followed by 100+ members">
    <svg class="h-3 w-3 self-center <%= tone == :dark ? 'text-whiskey-300' : 'text-whiskey-600' %>" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M10 2a1 1 0 01.894.553l2.062 4.177 4.61.67a1 1 0 01.554 1.706l-3.335 3.251.787 4.591a1 1 0 01-1.451 1.054L10 15.835l-4.121 2.167a1 1 0 01-1.451-1.054l.787-4.59L1.88 9.106a1 1 0 01.554-1.706l4.61-.67L9.106 2.553A1 1 0 0110 2z" clip-rule="evenodd"></path>
    </svg>
    <span class="text-[10px] font-semibold uppercase tracking-wide <%= tone == :dark ? 'text-whiskey-200' : 'text-whiskey-700' %>">Century</span>
    <span class="sr-only">Century badge: followed by 100 or more members</span>
  </span>
<% end %>
