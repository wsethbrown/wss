<% content_for :title, "Credit Transactions" %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="font-display text-3xl font-semibold text-gray-900">Credit ledger</h1>
    <p class="mt-1 text-gray-600">Every grant, spend, expiry, and refund, the source of truth for balances.</p>
  </div>
  <%= link_to 'Back to credits', admin_credits_path, class: 'rounded-xl border border-whiskey-300 bg-white px-4 py-2.5 text-sm font-semibold text-whiskey-800 transition hover:bg-whiskey-50' %>
</div>

<div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">When</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Member</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Type</th>
          <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-500">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Detail</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if @transactions.any? %>
          <% @transactions.each do |txn| %>
            <tr class="hover:bg-whiskey-50/50">
              <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500">
                <%= txn.created_at.strftime("%b %-d, %Y %l:%M %p") %>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm">
                <%= link_to txn.user.email, admin_user_path(txn.user), class: 'font-medium text-whiskey-700 hover:text-whiskey-600' %>
              </td>
              <td class="whitespace-nowrap px-6 py-4">
                <% badge = {
                  'granted'  => 'bg-green-100 text-green-800',
                  'used'     => 'bg-whiskey-100 text-whiskey-800',
                  'expired'  => 'bg-gray-100 text-gray-600',
                  'refunded' => 'bg-blue-100 text-blue-800'
                }.fetch(txn.transaction_type, 'bg-gray-100 text-gray-600') %>
                <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold <%= badge %>"><%= txn.transaction_type %></span>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-semibold <%= txn.amount.negative? ? 'text-gray-900' : 'text-green-700' %>">
                <%= txn.amount.positive? ? "+#{txn.amount}" : txn.amount %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600">
                <%= txn.description %>
                <% if txn.presentation %>
, <%= link_to txn.presentation.title, admin_presentation_path(txn.presentation), class: 'text-whiskey-700 hover:text-whiskey-600' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">No credit transactions yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-6">
  <%= paginate @transactions if @transactions.respond_to?(:total_pages) %>
</div>
