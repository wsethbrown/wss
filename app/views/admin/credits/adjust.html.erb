<% content_for :title, "Adjust Credits - #{@user.full_name}" %>

<div class="max-w-2xl mx-auto">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
      <%= link_to "Admin", admin_root_path, class: "hover:text-gray-900" %>
      <span>/</span>
      <%= link_to "Credits", admin_credits_path, class: "hover:text-gray-900" %>
      <span>/</span>
      <span class="text-gray-900">Adjust Credits</span>
    </div>
    <h1 class="text-3xl font-bold text-gray-900">Adjust User Credits</h1>
    <p class="text-gray-600 mt-2">Add or remove credits for <%= @user.full_name %></p>
  </div>

  <!-- User Info Card -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <% if @user.profile_image.attached? %>
          <%= image_tag @user.profile_image, class: "h-16 w-16 rounded-full object-cover" %>
        <% else %>
          <div class="h-16 w-16 rounded-full flex items-center justify-center text-white text-2xl font-semibold" style="background-color: <%= @user.avatar_color %>">
            <%= @user.initials %>
          </div>
        <% end %>
        <div>
          <p class="text-xl font-semibold text-gray-900"><%= @user.full_name %></p>
          <p class="text-gray-600"><%= @user.email %></p>
        </div>
      </div>
      <div class="text-center">
        <p class="text-sm text-gray-600">Current Balance</p>
        <p class="text-4xl font-bold <%= @user.credits > 0 ? 'text-green-600' : @user.credits < 0 ? 'text-red-600' : 'text-gray-500' %>">
          <%= @user.credits %>
        </p>
      </div>
    </div>
  </div>

  <!-- Adjustment Form -->
  <%= form_with url: adjust_admin_credit_path(@user), method: :post, local: true do |form| %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-6">
      <!-- Adjustment Amount -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Credit Adjustment</label>
        <div class="flex gap-4 mb-4">
          <%= number_field_tag :adjustment, nil, 
              placeholder: "Enter positive or negative number",
              class: "flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg" %>
        </div>
        
        <!-- Quick Buttons -->
        <div class="flex gap-2">
          <p class="text-sm text-gray-600 mr-2">Quick actions:</p>
          <button type="button" 
                  onclick="document.getElementById('adjustment').value = 1"
                  class="px-3 py-1 bg-green-100 text-green-700 font-medium rounded hover:bg-green-200 transition">
            +1
          </button>
          <button type="button" 
                  onclick="document.getElementById('adjustment').value = 5"
                  class="px-3 py-1 bg-green-100 text-green-700 font-medium rounded hover:bg-green-200 transition">
            +5
          </button>
          <button type="button" 
                  onclick="document.getElementById('adjustment').value = 10"
                  class="px-3 py-1 bg-green-100 text-green-700 font-medium rounded hover:bg-green-200 transition">
            +10
          </button>
          <span class="text-gray-300 mx-2">|</span>
          <button type="button" 
                  onclick="document.getElementById('adjustment').value = -1"
                  class="px-3 py-1 bg-red-100 text-red-700 font-medium rounded hover:bg-red-200 transition">
            -1
          </button>
          <button type="button" 
                  onclick="document.getElementById('adjustment').value = -5"
                  class="px-3 py-1 bg-red-100 text-red-700 font-medium rounded hover:bg-red-200 transition">
            -5
          </button>
          <button type="button" 
                  onclick="document.getElementById('adjustment').value = -10"
                  class="px-3 py-1 bg-red-100 text-red-700 font-medium rounded hover:bg-red-200 transition">
            -10
          </button>
        </div>
      </div>

      <!-- Reason -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Reason for Adjustment</label>
        <%= text_area_tag :reason, nil, 
            rows: 4,
            placeholder: "Describe why you're adjusting credits (e.g., customer support, promotion, correction)...",
            class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <!-- Preview -->
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm font-medium text-gray-700 mb-2">Preview</p>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-600">Current Balance</p>
            <p class="text-xl font-semibold text-gray-900"><%= @user.credits %> credits</p>
          </div>
          <div class="text-center">
            <svg class="w-6 h-6 text-gray-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </div>
          <div>
            <p class="text-sm text-gray-600">New Balance</p>
            <p class="text-xl font-semibold text-gray-900" id="new-balance"><%= @user.credits %> credits</p>
          </div>
        </div>
      </div>

      <!-- Warning for negative balances -->
      <div id="negative-warning" class="hidden bg-amber-50 border border-amber-200 rounded-lg p-4">
        <div class="flex">
          <svg class="w-5 h-5 text-amber-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
          </svg>
          <p class="text-sm text-amber-800">This will result in a negative credit balance. Users cannot use credits when balance is negative.</p>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="flex items-center justify-between pt-6 border-t">
        <div>
          <%= link_to "Cancel", admin_credits_path, class: "px-6 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition" %>
        </div>
        <div>
          <%= form.submit "Apply Adjustment", 
              class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition cursor-pointer",
              data: { confirm: "Are you sure you want to adjust credits for this user?" } %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  // Update preview when adjustment value changes
  document.getElementById('adjustment').addEventListener('input', function() {
    const currentBalance = <%= @user.credits %>;
    const adjustment = parseInt(this.value) || 0;
    const newBalance = currentBalance + adjustment;
    
    document.getElementById('new-balance').textContent = newBalance + ' credits';
    
    // Show/hide negative warning
    const warningDiv = document.getElementById('negative-warning');
    if (newBalance < 0) {
      warningDiv.classList.remove('hidden');
    } else {
      warningDiv.classList.add('hidden');
    }
  });
</script>