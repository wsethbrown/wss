<% content_for :title, "Edit Subscription - #{@user.full_name}" %>

<div class="max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
      <%= link_to "Admin", admin_root_path, class: "hover:text-gray-900" %>
      <span>/</span>
      <%= link_to "Subscriptions", admin_subscriptions_path, class: "hover:text-gray-900" %>
      <span>/</span>
      <span class="text-gray-900"><%= @user.full_name %></span>
    </div>
    <h1 class="text-3xl font-bold text-gray-900">Edit Subscription</h1>
    <p class="text-gray-600 mt-2">Manage subscription and credits for <%= @user.full_name %></p>
  </div>

  <%= form_with model: @user, url: admin_subscription_path(@user), local: true do |form| %>
    <div class="space-y-6">
      <!-- Current Status -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Current Status</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <p class="text-sm text-gray-600">Customer</p>
            <div class="flex items-center gap-3 mt-2">
              <% if @user.profile_image.attached? %>
                <%= image_tag @user.profile_image, class: "h-10 w-10 rounded-full object-cover" %>
              <% else %>
                <div class="h-10 w-10 rounded-full flex items-center justify-center text-white font-semibold" style="background-color: <%= @user.avatar_color %>">
                  <%= @user.initials %>
                </div>
              <% end %>
              <div>
                <p class="font-medium text-gray-900"><%= @user.full_name %></p>
                <p class="text-sm text-gray-500"><%= @user.email %></p>
              </div>
            </div>
          </div>
          <div>
            <p class="text-sm text-gray-600">Stripe Customer ID</p>
            <p class="mt-2 font-mono text-sm text-gray-900"><%= @user.stripe_customer_id || "Not connected" %></p>
          </div>
        </div>
      </div>

      <!-- Subscription Details -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Subscription Details</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :subscription_status, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.select :subscription_status, 
                options_for_select([
                  ['No Subscription', ''],
                  ['Active', 'active'],
                  ['Canceled', 'canceled'],
                  ['Past Due', 'past_due']
                ], @user.subscription_status),
                {},
                { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
          </div>
          <div>
            <%= form.label :subscription_plan, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.select :subscription_plan, 
                options_for_select([
                  ['Monthly - $9.99/mo', 'monthly'],
                  ['Annual - $99.99/yr', 'annual']
                ], @user.subscription_plan),
                { include_blank: 'Select a plan' },
                { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
          </div>
          <div>
            <%= form.label :subscription_ends_at, "Billing Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.date_field :subscription_ends_at, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="text-sm text-gray-500 mt-1">Next billing or end date</p>
          </div>
        </div>
      </div>

      <!-- Credit Management -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Credit Management</h2>
        <div class="space-y-6">
          <div>
            <div class="flex items-center justify-between mb-4">
              <div>
                <p class="text-sm text-gray-600">Current Credits</p>
                <p class="text-3xl font-bold text-purple-600"><%= @user.credits %></p>
              </div>
              <div class="text-right">
                <p class="text-sm text-gray-600">Next Credit</p>
                <p class="text-sm font-medium text-gray-900">
                  <%= @user.next_credit_date&.strftime("%b %d, %Y") || "N/A" %>
                </p>
              </div>
            </div>
          </div>

          <div class="border-t pt-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Add Credits</label>
            <div class="flex gap-4">
              <%= number_field_tag :add_credits, nil, 
                  placeholder: "Number of credits to add",
                  min: 0,
                  class: "flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
              <button type="button" 
                      onclick="document.getElementById('add_credits').value = 1"
                      class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
                +1
              </button>
              <button type="button" 
                      onclick="document.getElementById('add_credits').value = 5"
                      class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
                +5
              </button>
              <button type="button" 
                      onclick="document.getElementById('add_credits').value = 10"
                      class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
                +10
              </button>
            </div>
            <p class="text-sm text-gray-500 mt-2">Credits will be added immediately upon saving</p>
          </div>

          <div>
            <%= form.label :credits, "Set Credit Balance", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.number_field :credits, 
                min: 0,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="text-sm text-gray-500 mt-1">Override the current credit balance</p>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Quick Actions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% if @user.subscription_status == 'active' %>
            <%= link_to pause_admin_subscription_path(@user), 
                method: :post,
                data: { confirm: "Pause subscription for #{@user.full_name}?" },
                class: "flex items-center justify-center gap-2 px-4 py-2 bg-yellow-600 text-white font-medium rounded-lg hover:bg-yellow-700 transition" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Pause Subscription
            <% end %>
            
            <%= button_to cancel_admin_subscription_path(@user), 
                method: :post,
                data: { turbo_confirm: "Cancel subscription for #{@user.full_name}? This will cancel immediately." },
                class: "flex items-center justify-center gap-2 px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition w-full" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Cancel Subscription
            <% end %>
          <% elsif @user.subscription_paused_at.present? %>
            <%= link_to resume_admin_subscription_path(@user), 
                method: :post,
                data: { confirm: "Resume subscription for #{@user.full_name}?" },
                class: "flex items-center justify-center gap-2 px-4 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition md:col-span-2" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Resume Subscription
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="flex items-center justify-between pt-6">
        <div>
          <%= link_to "Cancel", admin_subscriptions_path, class: "px-6 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition" %>
        </div>
        <div class="flex gap-4">
          <%= form.submit "Save Changes", class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
        </div>
      </div>
    </div>
  <% end %>
</div>