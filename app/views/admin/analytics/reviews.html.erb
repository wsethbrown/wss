<% content_for :title, "Reviews Analytics" %>

<div class="mb-8">
  <h1 class="font-display text-3xl font-semibold text-gray-900">Reviews</h1>
  <p class="mt-1 text-gray-500">The health of the tasting record at a glance.</p>
</div>

<!-- Stat cards -->
<div class="mb-8 grid grid-cols-2 gap-4 lg:grid-cols-4">
  <% [
    ["Total reviews", @total_reviews, "#{@reviews_this_week} in the last 7 days"],
    ["Reviewers", @total_reviewers, "distinct tasters"],
    ["Bottles reviewed", @bottles_reviewed, "in the catalog"],
    ["Average rating", (@avg_rating ? "#{@avg_rating} / 5" : "n/a"), "across all reviews"]
  ].each do |label, value, sub| %>
    <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-gray-500"><%= label %></p>
      <p class="mt-2 font-display text-3xl font-semibold text-gray-900"><%= value %></p>
      <p class="mt-1 text-xs text-gray-400"><%= sub %></p>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <!-- Most reviewed -->
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 font-semibold text-gray-900">Most reviewed bottles</h2>
    <% if @most_reviewed.any? %>
      <ol class="space-y-2">
        <% @most_reviewed.each_with_index do |bottle, i| %>
          <li class="flex items-center justify-between gap-3 text-sm">
            <span class="min-w-0 truncate">
              <span class="text-gray-400"><%= i + 1 %>.</span>
              <%= link_to bottle.display_name, bottle_path(bottle), class: "font-medium text-whiskey-700 hover:text-whiskey-900" %>
            </span>
            <span class="shrink-0 font-semibold text-gray-900"><%= bottle.reviews_count %></span>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="text-sm text-gray-500">No reviews yet.</p>
    <% end %>
  </div>

  <!-- Top rated -->
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-1 font-semibold text-gray-900">Top rated bottles</h2>
    <p class="mb-4 text-xs text-gray-400">Two or more reviewers.</p>
    <% if @top_rated.any? %>
      <ol class="space-y-2">
        <% @top_rated.each_with_index do |bottle, i| %>
          <li class="flex items-center justify-between gap-3 text-sm">
            <span class="min-w-0 truncate">
              <span class="text-gray-400"><%= i + 1 %>.</span>
              <%= link_to bottle.display_name, bottle_path(bottle), class: "font-medium text-whiskey-700 hover:text-whiskey-900" %>
            </span>
            <span class="shrink-0 font-semibold text-gray-900"><%= bottle.avg_rating.to_f.round(1) %> <span class="text-gray-400">(<%= bottle.reviewers %>)</span></span>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="text-sm text-gray-500">Not enough reviews yet.</p>
    <% end %>
  </div>

  <!-- Active reviewers -->
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 font-semibold text-gray-900">Most active reviewers</h2>
    <% if @active_reviewers.any? %>
      <ol class="space-y-2">
        <% @active_reviewers.each_with_index do |user, i| %>
          <li class="flex items-center justify-between gap-3 text-sm">
            <span class="min-w-0 truncate">
              <span class="text-gray-400"><%= i + 1 %>.</span>
              <span class="font-medium text-gray-800"><%= user.full_name.presence || user.email %></span>
            </span>
            <span class="shrink-0 font-semibold text-gray-900"><%= user.reviews_count %></span>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="text-sm text-gray-500">No reviewers yet.</p>
    <% end %>
  </div>

  <!-- Recent reviews -->
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 font-semibold text-gray-900">Recent reviews</h2>
    <% if @recent_reviews.any? %>
      <ul class="space-y-3">
        <% @recent_reviews.each do |review| %>
          <li class="flex items-start justify-between gap-3 border-b border-gray-100 pb-3 text-sm last:border-0 last:pb-0">
            <div class="min-w-0">
              <%= link_to review.bottle.display_name, review_path(review), class: "font-medium text-whiskey-700 hover:text-whiskey-900" %>
              <p class="truncate text-xs text-gray-500"><%= review.user.full_name.presence || review.user.email %> &middot; <%= time_ago_in_words(review.created_at) %> ago</p>
            </div>
            <span class="shrink-0 font-semibold text-gray-900"><%= review.rating %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">No reviews yet.</p>
    <% end %>
  </div>
</div>
