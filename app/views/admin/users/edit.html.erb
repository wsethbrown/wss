<% content_for :title, "Edit #{@user.full_name} - Admin" %>

<div class="max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
      <%= link_to "Admin", admin_root_path, class: "hover:text-gray-900" %>
      <span>/</span>
      <%= link_to "Users", admin_users_path, class: "hover:text-gray-900" %>
      <span>/</span>
      <%= link_to @user.full_name, admin_user_path(@user), class: "hover:text-gray-900" %>
      <span>/</span>
      <span class="text-gray-900">Edit</span>
    </div>
    <h1 class="text-3xl font-bold text-gray-900">Edit User</h1>
    <p class="text-gray-600 mt-2">Update user information and subscription details</p>
  </div>

  <!-- Form -->
  <%= form_with model: @user, url: admin_user_path(@user), local: true do |form| %>
    <% if @user.errors.any? %>
      <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
        <h3 class="text-sm font-medium text-red-800 mb-2">There were <%= pluralize(@user.errors.count, "error") %> with your submission:</h3>
        <ul class="list-disc list-inside text-sm text-red-700">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-6">
      <!-- Basic Information -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Basic Information</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :first_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :first_name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <%= form.label :last_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :last_name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div class="md:col-span-2">
            <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.email_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="text-sm text-gray-500 mt-1">Changing email will require user verification</p>
          </div>
          <div class="md:col-span-2">
            <%= form.label :bio, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_area :bio, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>
      </div>

      <!-- Credits Only (Subscription managed separately) -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Credits</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :credits, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.number_field :credits, 
                min: 0,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="text-sm text-gray-500 mt-1">Current: <%= @user.credits %> credits</p>
          </div>
        </div>
      </div>

      <!-- Admin Actions -->
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Admin Actions</h2>
        <div class="space-y-4">
          <label class="flex items-center gap-3">
            <%= check_box_tag :reset_password, '1', false, class: "h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <span class="text-sm text-gray-700">Send password reset email</span>
          </label>
          <label class="flex items-center gap-3">
            <%= check_box_tag :disable_2fa, '1', false, class: "h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <span class="text-sm text-gray-700">Disable two-factor authentication</span>
          </label>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="flex items-center justify-between pt-6">
        <div>
          <%= link_to "Cancel", admin_user_path(@user), class: "px-6 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition" %>
        </div>
        <div class="flex gap-4">
          <%= form.submit "Save Changes", class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Subscription Management (Outside Form) -->
  <div class="mt-8 space-y-6">
    <!-- Current Subscription Status -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Subscription Management</h2>
      
      <% if @user.stripe_customer_id.present? %>
        <% # Check Stripe for current subscription status %>
        <% begin %>
          <% active_subs = Stripe::Subscription.list(customer: @user.stripe_customer_id, status: 'active', limit: 1) %>
          <% trialing_subs = Stripe::Subscription.list(customer: @user.stripe_customer_id, status: 'trialing', limit: 1) %>
          <% current_sub = active_subs.data.first || trialing_subs.data.first %>
          
          <% if current_sub %>
            <!-- Active/Trial Subscription -->
            <% if current_sub.status == 'trialing' %>
              <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
                <p class="text-sm font-medium text-blue-800 mb-2">Trial Subscription</p>
                <p class="text-sm text-blue-700">ID: <%= current_sub.id %></p>
                <p class="text-sm text-blue-700">Status: <%= current_sub.status.capitalize %></p>
                <p class="text-sm text-blue-700">Plan: <%= @user.subscription_plan || 'Unknown' %></p>
                <p class="text-sm text-blue-700">Trial ends: <%= Time.at(current_sub.trial_end).strftime("%B %d, %Y at %I:%M %p") %></p>
              </div>
            <% else %>
              <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
                <p class="text-sm font-medium text-green-800 mb-2">Active Subscription</p>
                <p class="text-sm text-green-700">ID: <%= current_sub.id %></p>
                <p class="text-sm text-green-700">Status: <%= current_sub.status.capitalize %></p>
                <p class="text-sm text-green-700">Plan: <%= @user.subscription_plan || 'Unknown' %></p>
                <p class="text-sm text-green-700">Next billing: <%= Time.at(current_sub.current_period_end).strftime("%B %d, %Y") %></p>
              </div>
            <% end %>
            
            <!-- Action Buttons -->
            <div class="flex flex-wrap gap-3">
              <% if @user.subscription_can_be_paused? %>
                <%= button_to "Pause Subscription", pause_admin_subscription_path(@user), 
                    method: :post,
                    data: { turbo_confirm: "This will pause billing for this subscription. Are you sure?" },
                    class: "px-4 py-2 bg-yellow-600 text-white font-medium rounded-lg hover:bg-yellow-700 transition" %>
              <% elsif @user.subscription_can_be_resumed? %>
                <%= button_to "Resume Subscription", resume_admin_subscription_path(@user), 
                    method: :post,
                    data: { turbo_confirm: "This will resume billing for this subscription. Are you sure?" },
                    class: "px-4 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition" %>
              <% end %>
              
              <%= button_to "Cancel Subscription", cancel_admin_subscription_path(@user), 
                  method: :post,
                  data: { turbo_confirm: "This will immediately cancel the subscription. Are you sure?" },
                  class: "px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition" %>
              
              <%= button_to "Mark as Past Due", admin_user_path(@user),
                  method: :patch,
                  params: { user: { subscription_status: 'past_due' } },
                  data: { turbo_confirm: "This will only update the local status. Continue?" },
                  class: "px-4 py-2 bg-orange-600 text-white font-medium rounded-lg hover:bg-orange-700 transition" %>
            </div>
          <% else %>
            <!-- No Active Subscription -->
            <div class="mb-6 p-4 bg-gray-50 border border-gray-200 rounded-lg">
              <p class="text-sm font-medium text-gray-800 mb-2">No Active Subscription</p>
              <p class="text-sm text-gray-600">This user does not have an active Stripe subscription.</p>
            </div>
            
            <!-- Create Subscription -->
            <div>
              <p class="text-sm font-medium text-gray-700 mb-3">Create New Subscription:</p>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Monthly Plan -->
                <div class="border border-gray-200 rounded-lg p-4 hover:border-blue-500 transition">
                  <h3 class="font-medium text-gray-900 mb-2">Monthly</h3>
                  <p class="text-2xl font-bold text-gray-900 mb-3">$19.99<span class="text-sm font-normal text-gray-500">/mo</span></p>
                  <%= button_to "Create Monthly", admin_create_subscription_path,
                      method: :post,
                      params: { user_id: @user.id, plan: 'monthly' },
                      data: { turbo_confirm: "Create a monthly subscription for #{@user.full_name}?" },
                      class: "w-full px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition" %>
                </div>
                
                <!-- Quarterly Plan -->
                <div class="border border-blue-500 rounded-lg p-4 relative">
                  <div class="absolute -top-3 left-1/2 transform -translate-x-1/2">
                    <span class="bg-blue-500 text-white text-xs font-medium px-2 py-1 rounded">Popular</span>
                  </div>
                  <h3 class="font-medium text-gray-900 mb-2">Quarterly</h3>
                  <p class="text-2xl font-bold text-gray-900 mb-3">$38.97<span class="text-sm font-normal text-gray-500">/3mo</span></p>
                  <%= button_to "Create Quarterly", admin_create_subscription_path,
                      method: :post,
                      params: { user_id: @user.id, plan: 'quarterly' },
                      data: { turbo_confirm: "Create a quarterly subscription for #{@user.full_name}?" },
                      class: "w-full px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition" %>
                </div>
                
                <!-- Yearly Plan -->
                <div class="border border-gray-200 rounded-lg p-4 hover:border-blue-500 transition">
                  <h3 class="font-medium text-gray-900 mb-2">Yearly</h3>
                  <p class="text-2xl font-bold text-gray-900 mb-3">$131.88<span class="text-sm font-normal text-gray-500">/yr</span></p>
                  <%= button_to "Create Yearly", admin_create_subscription_path,
                      method: :post,
                      params: { user_id: @user.id, plan: 'yearly' },
                      data: { turbo_confirm: "Create a yearly subscription for #{@user.full_name}?" },
                      class: "w-full px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition" %>
                </div>
              </div>
            </div>
          <% end %>
        <% rescue Stripe::StripeError => e %>
          <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-sm font-medium text-red-800">Stripe Error</p>
            <p class="text-sm text-red-700"><%= e.message %></p>
          </div>
        <% end %>
      <% else %>
        <!-- No Stripe Customer -->
        <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
          <p class="text-sm font-medium text-yellow-800 mb-2">No Stripe Customer ID</p>
          <p class="text-sm text-yellow-700">This user needs to create a subscription through the normal checkout flow first.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>