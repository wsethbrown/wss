<%# The authoring flow mirrors the buyer page top to bottom, same sections,
    same order, same numbering. The right rail is the map: it shows what the
    buyer page will actually render given what's filled in, and is the fastest
    honest answer to "is this deck ready to sell?" %>
<%
  takeaways_count = presentation.parsed_what_youll_learn.size
  pours_count     = presentation.parsed_whiskey_recommendations.size
  story_words     = presentation.content.to_s.split.size
  tasting_notes_n = [presentation.nose_notes, presentation.palate_notes,
                     presentation.finish_notes, presentation.body_notes].count(&:present?)
  slides_count    = presentation.slide_images.attached? ? presentation.slide_images.count : 0
  extras_count    = [presentation.sneak_peek_file, presentation.speaker_notes,
                     presentation.outline_file, presentation.recommendations_sheet].count(&:attached?) +
                    (presentation.supplemental_materials.attached? ? presentation.supplemental_materials.count : 0)

  dot = ->(state) {
    color = { on: "bg-green-500", auto: "bg-whiskey-400", off: "bg-gray-300", need: "bg-red-400" }.fetch(state)
    %(<span class="mt-1.5 h-2 w-2 flex-shrink-0 rounded-full #{color}"></span>).html_safe
  }
%>

<%= form_with model: [:admin, presentation], local: true, html: { id: "deck-form" } do |form| %>
  <% if presentation.errors.any? %>
    <div class="mb-6 rounded-lg bg-red-50 border border-red-200 text-red-800 px-4 py-3">
      <h4 class="font-bold">Please fix the following errors:</h4>
      <ul class="list-disc list-inside mt-2">
        <% presentation.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_19rem] lg:items-start lg:gap-6">
    <div class="min-w-0 space-y-6">

      <!-- ═══ 1 · THE COVER ═══ -->
      <section id="f-cover" class="scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="font-display text-xl font-semibold text-gray-900">1 · The cover</h3>
        <p class="mb-5 mt-1 text-sm text-gray-500">Appears on: the library card, the deck page hero, and search filters.</p>

        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          <div class="md:col-span-2">
            <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500", placeholder: "e.g., Introduction to Scotch Whisky" %>
          </div>

          <div class="md:col-span-2">
            <%= form.label :description, "Description, the one-line pitch", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_area :description, rows: 2, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500", placeholder: "One or two sentences under the title, why THIS deck, in the buyer's language." %>
            <p class="mt-1 text-xs text-gray-500">Shows under the title on the hero and on every library card. This line does the most selling per word on the site.</p>
          </div>

          <div data-controller="category-picker">
            <%= form.label :category, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%# A real dropdown (datalist looked like one but filtered against the
                current value, so it never appeared to open). "+ New category…"
                swaps in a text field; the disabled control doesn't submit. %>
            <% categories = (Presentation.distinct.pluck(:category).compact +
                ['Scotch Whisky', 'Bourbon', 'Irish Whiskey', 'Japanese Whisky',
                 'Rye Whiskey', 'Canadian Whisky', 'Cocktails', 'General Education']).uniq.sort %>
            <%= form.select :category,
                options_for_select(categories, presentation.category) + options_for_select([['+ New category…', '__new__']]),
                { include_blank: 'No category' },
                { class: "w-full px-3 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-whiskey-500",
                  data: { category_picker_target: "select", action: "change->category-picker#change" } } %>
            <div class="hidden" data-category-picker-target="inputWrapper">
              <div class="flex gap-2">
                <%= form.text_field :category, value: "", disabled: true, id: "presentation_category_new",
                    placeholder: "Name the new category",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500",
                    data: { category_picker_target: "input" } %>
                <button type="button" data-action="click->category-picker#backToList"
                        class="whitespace-nowrap rounded-lg bg-gray-100 px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-200"
                        title="Back to the category list">↩ list</button>
              </div>
            </div>
          </div>

          <div>
            <%= form.label :difficulty, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.select :difficulty,
                options_for_select([['Beginner', 'Beginner'], ['Intermediate', 'Intermediate'], ['Advanced', 'Advanced']], presentation.difficulty),
                { include_blank: 'Select difficulty level' },
                { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" } %>
          </div>

          <div>
            <%= form.label :price, "Price (USD)", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.number_field :price, step: 0.01, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500", placeholder: "9.99" %>
            <p class="mt-1 text-xs text-gray-500">0 makes the deck free to claim.</p>
          </div>

          <div>
            <%= form.label :duration, "Running time", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :duration, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500", placeholder: "45 min" %>
            <p class="mt-1 text-xs text-gray-500">How long the night runs when presented. A bare number reads as minutes.</p>
          </div>

          <div class="md:col-span-2">
            <%= form.label :tag_names, "Tags", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :tag_names, placeholder: "smoky, islay, blind tasting",
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
            <p class="mt-1 text-xs text-gray-500">Comma-separated, up to 10. Lowercased automatically; buyers can filter the library by tag.</p>
          </div>

          <div class="md:col-span-2 rounded-xl border border-whiskey-100 bg-whiskey-50/60 p-4">
            <label class="flex items-start gap-3">
              <%= form.check_box :featured, class: "mt-0.5 h-5 w-5 rounded border-gray-300 text-whiskey-600 focus:ring-whiskey-500" %>
              <span>
                <span class="block text-sm font-medium text-gray-900">Feature this deck</span>
                <span class="block text-xs text-gray-500">Spotlights it on the homepage, pins it to the top of the library, and adds a Featured badge. Use it to push a timely deck (a Derby Mint Julep, a Christmas eggnog). The most recently featured published deck becomes the homepage spotlight.</span>
              </span>
            </label>
          </div>

          <div class="md:col-span-2">
            <%= form.label :featured_image, "Banner image", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <% if presentation.featured_image.attached? %>
              <div class="mb-3">
                <%= image_tag presentation.featured_image, class: "h-32 w-auto rounded-lg border border-gray-200" %>
              </div>
            <% end %>
            <%= form.file_field :featured_image, accept: "image/jpeg,image/jpg,image/png,image/gif,image/webp", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
            <p class="mt-1 text-xs text-gray-500">Sits behind the hero title. Landscape works best (JPEG, PNG, GIF, or WebP, max 15MB).</p>
          </div>
        </div>
      </section>

      <!-- ═══ 2 · THE TAKEAWAYS ═══ -->
      <section id="f-pitch" class="scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm" data-controller="what-youll-learn">
        <h3 class="font-display text-xl font-semibold text-gray-900">2 · The takeaways, what you'll learn</h3>
        <p class="mb-5 mt-1 text-sm text-gray-500">Appears on: the "What you'll learn" grid, right under the hero. Three or four concrete points sell better than six vague ones. Empty = the section is hidden.</p>

        <%= form.hidden_field :what_youll_learn, id: 'what_youll_learn_hidden' %>
        <input type="hidden" id="existing-what-youll-learn" value="<%= presentation.what_youll_learn %>" />

        <div data-what-youll-learn-target="container" class="space-y-4 mb-4"></div>

        <button type="button"
                data-action="click->what-youll-learn#addLearningPoint"
                class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
          Add takeaway
        </button>

        <template data-what-youll-learn-target="template">
          <div class="learning-point-item p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="flex justify-between items-start mb-3">
              <h4 class="text-sm font-medium text-gray-700">Takeaway</h4>
              <button type="button"
                      data-action="click->what-youll-learn#removeLearningPoint"
                      class="text-red-600 hover:text-red-800 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Title</label>
                <input type="text"
                       class="learning-title w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500 text-sm"
                       placeholder="e.g., Rye Whiskey Foundations"
                       data-action="input->what-youll-learn#fieldChanged">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Description</label>
                <textarea
                       class="learning-description w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500 text-sm"
                       rows="2"
                       placeholder="e.g., What sets rye apart, mash bills, legal definitions, and signature character."
                       data-action="input->what-youll-learn#fieldChanged"></textarea>
              </div>
            </div>
          </div>
        </template>
      </section>

      <!-- ═══ 3 · THE STORY ═══ -->
      <section id="f-story" class="scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm" data-controller="story-chapters">
        <h3 class="font-display text-xl font-semibold text-gray-900">3 · The story</h3>
        <p class="mb-5 mt-1 text-sm text-gray-500">
          Appears on: the "A taste of the writing" section of the deck page, one chapter at a time.
          Buyers read it all; <span class="font-semibold">non-buyers only get the free teaser</span>,
          the marker below shows exactly where it fades into the purchase prompt.
          Imported decks land here as one rough block per slide: rewrite each chapter as prose, cut the fragments.
        </p>

        <%= form.hidden_field :content, data: { story_chapters_target: "hidden" } %>

        <div data-story-chapters-target="chaptersUi">
          <div data-story-chapters-target="container" class="space-y-4"></div>

          <button type="button"
                  data-action="click->story-chapters#addChapter"
                  class="mt-4 inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
            Add chapter
          </button>
        </div>

        <div data-story-chapters-target="rawWrapper" class="hidden">
          <textarea data-story-chapters-target="raw" data-action="input->story-chapters#rawChanged"
                    rows="18" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500"></textarea>
          <p class="mt-1 text-xs text-gray-500"><code>## Heading</code> lines become chapters when you switch back.</p>
        </div>

        <div class="mt-3 text-right">
          <button type="button" data-story-chapters-target="toggle"
                  data-action="click->story-chapters#toggleRaw"
                  class="text-xs font-medium text-gray-400 underline-offset-2 hover:text-whiskey-700 hover:underline">Edit as raw Markdown</button>
        </div>

        <template data-story-chapters-target="template">
          <div class="chapter-item rounded-lg border border-gray-200 bg-gray-50 p-4">
            <div class="mb-3 flex items-center justify-between">
              <h4 class="chapter-label text-sm font-semibold text-whiskey-700">Chapter</h4>
              <div class="flex items-center gap-1">
                <button type="button" data-action="click->story-chapters#moveUp"
                        class="rounded p-1.5 text-gray-400 hover:bg-gray-200 hover:text-gray-700 transition" aria-label="Move up">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"></path></svg>
                </button>
                <button type="button" data-action="click->story-chapters#moveDown"
                        class="rounded p-1.5 text-gray-400 hover:bg-gray-200 hover:text-gray-700 transition" aria-label="Move down">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path></svg>
                </button>
                <button type="button" data-action="click->story-chapters#removeChapter"
                        class="rounded p-1.5 text-red-500 hover:bg-red-50 hover:text-red-700 transition" aria-label="Remove chapter">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
              </div>
            </div>
            <div class="space-y-3">
              <input type="text"
                     class="chapter-title w-full px-3 py-2 border border-gray-300 rounded-lg font-display text-base font-semibold focus:outline-none focus:ring-2 focus:ring-whiskey-500"
                     placeholder="Chapter heading, leave empty for the opening"
                     data-action="input->story-chapters#fieldChanged">
              <textarea class="chapter-body w-full px-3 py-2 border border-gray-300 rounded-lg text-sm leading-relaxed focus:outline-none focus:ring-2 focus:ring-whiskey-500"
                        rows="4"
                        placeholder="The chapter, as prose. Markdown works: **bold**, *italics*, lists, > quotes."
                        data-action="input->story-chapters#fieldChanged"></textarea>
            </div>
          </div>
        </template>
      </section>

      <!-- ═══ 4 · WHAT YOU'LL TASTE ═══ -->
      <section id="f-tasting" class="scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="font-display text-xl font-semibold text-gray-900">4 · What you'll taste <span class="ml-1 align-middle text-xs font-sans font-medium uppercase tracking-wide text-gray-400">optional</span></h3>
        <p class="mb-5 mt-1 text-sm text-gray-500">
          Appears on: the tasting section, set like a back label. One profile for the whole flight,
          works the same for whiskey, cocktails, or wine. Leave all four empty to hide the section.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <% {
            nose_notes:   ["Nose",   "e.g., Vanilla, honey, light oak, subtle fruit", "Aromas, before the first sip"],
            palate_notes: ["Palate", "e.g., Smooth and balanced, caramel, then spice", "Flavors on the tongue"],
            finish_notes: ["Finish", "e.g., Medium length, warming oak, gentle smoke", "The aftertaste, and how long it lasts"],
            body_notes:   ["Body",   "e.g., Medium-bodied, smooth, approachable", "Mouthfeel and texture"]
          }.each do |field, (label, placeholder, hint)| %>
            <div>
              <%= form.label field, label, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.text_area field, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500", placeholder: placeholder %>
              <p class="mt-1 text-xs text-gray-500"><%= hint %></p>
            </div>
          <% end %>
        </div>
      </section>

      <!-- ═══ 5 · THE SLIDES ═══ -->
      <section id="f-slides" class="scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="font-display text-xl font-semibold text-gray-900">5 · The slides &amp; the deck file</h3>
        <p class="mb-5 mt-1 text-sm text-gray-500">
          Appears on: the full-slide preview strip and the slide count in the hero.
          <span class="font-semibold">Nothing to write here</span>, slides render automatically
          from the deck file, and re-render whenever you replace it.
        </p>

        <div class="mb-6">
          <%= form.label :pdf_file, "The deck file, required to publish", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <% if presentation.pdf_file.attached? %>
            <p class="mb-2 text-sm text-gray-600">Current file: <span class="font-medium"><%= presentation.pdf_file.filename %></span></p>
          <% end %>
          <%= form.file_field :pdf_file, accept: "application/pdf,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.ms-powerpoint", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
          <p class="mt-1 text-xs text-gray-500">This is what buyers download. PDF or PowerPoint, max 50MB.</p>
        </div>

        <% if presentation.slide_images.attached? %>
          <% slides = presentation.slide_images.order(:id) %>
          <div class="grid grid-cols-4 gap-3">
            <% slides.first(8).each_with_index do |slide, i| %>
              <figure>
                <%= image_tag slide, class: "aspect-video w-full rounded-lg border border-gray-200 object-cover" %>
                <figcaption class="mt-1 text-center text-xs text-gray-400"><%= i + 1 %></figcaption>
              </figure>
            <% end %>
          </div>
          <% if slides.size > 8 %>
            <p class="mt-2 text-xs text-gray-500">+ <%= slides.size - 8 %> more, buyers see all <%= slides.size %> full-size.</p>
          <% end %>
        <% elsif presentation.slide_render_pending? %>
          <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            <span class="font-semibold">Rendering slide previews&hellip;</span> usually under a minute. Reload to see them.
          </div>
        <% elsif presentation.pdf_file.attached? %>
          <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
            <span class="font-semibold">No slide previews yet.</span> Use "Re-render slide previews"
            on the deck's admin page, or re-upload the file above.
          </div>
        <% end %>

        <div class="mt-6 border-t border-gray-100 pt-5">
          <%= form.label :preview_slide_count, "Free preview, slides shown before the buy prompt", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="flex items-center gap-3">
            <%= form.number_field :preview_slide_count, min: 1, value: presentation.preview_slide_count || 3, class: "w-24 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
            <span class="text-sm text-gray-500">of <%= presentation.slide_images.attached? ? presentation.slide_images.count : ", ".html_safe %> rendered slides</span>
          </div>
          <p class="mt-1 text-xs text-gray-500">Non-buyers see the first N slides on the deck page; the last one fades into a &ldquo;get this deck&rdquo; prompt. Slide 1 is usually your title, so this replaces the old free-sample upload.</p>
        </div>
      </section>

      <!-- ═══ 6 · THE POUR LIST ═══ -->
      <section id="f-pours" class="scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm" data-controller="whiskey-recommendations">
        <h3 class="font-display text-xl font-semibold text-gray-900">6 · The pour list <span class="ml-1 align-middle text-xs font-sans font-medium uppercase tracking-wide text-gray-400">optional</span></h3>
        <p class="mb-5 mt-1 text-sm text-gray-500">
          Appears on: the "What to pour" cards, and in the buyer's "what you get" manifest with a count.
          Bottles, cocktails, or anything else the night pours, one card each, with where to find it
          and what it costs. Empty = the section is hidden.
        </p>

        <%= form.hidden_field :whiskey_recommendations, id: 'whiskey_recommendations_hidden' %>
        <input type="hidden" id="existing-recommendations" value="<%= presentation.whiskey_recommendations %>" />

        <div data-whiskey-recommendations-target="container" class="space-y-4 mb-4"></div>

        <button type="button"
                data-action="click->whiskey-recommendations#addRecommendation"
                class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
          Add a pour
        </button>

        <template data-whiskey-recommendations-target="template">
          <div class="recommendation-item p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="flex justify-between items-start mb-3">
              <h4 class="text-sm font-medium text-gray-700">Pour</h4>
              <button type="button"
                      data-action="click->whiskey-recommendations#removeRecommendation"
                      class="text-red-600 hover:text-red-800 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Name</label>
                <input type="text"
                       class="whiskey-name w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500 text-sm"
                       placeholder="e.g., Glenfiddich 12, or Mint Julep"
                       data-action="input->whiskey-recommendations#fieldChanged">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Origin</label>
                <input type="text"
                       class="whiskey-region w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500 text-sm"
                       placeholder="e.g., Speyside, or Kentucky, 1803"
                       data-action="input->whiskey-recommendations#fieldChanged">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Price</label>
                <input type="text"
                       class="whiskey-price w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500 text-sm"
                       placeholder="e.g., $45"
                       data-action="input->whiskey-recommendations#fieldChanged">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Style</label>
                <input type="text"
                       class="whiskey-style w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500 text-sm"
                       placeholder="e.g., Light &amp; Fruity"
                       data-action="input->whiskey-recommendations#fieldChanged">
              </div>
              <div class="md:col-span-2">
                <label class="block text-xs font-medium text-gray-600 mb-1">Notes</label>
                <input type="text"
                       class="whiskey-notes w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500 text-sm"
                       placeholder="e.g., Pear, oak, subtle spice, pour it for the 1820s chapter"
                       data-action="input->whiskey-recommendations#fieldChanged">
              </div>
            </div>
          </div>
        </template>
      </section>

      <!-- ═══ 7 · WHAT BUYERS DOWNLOAD ═══ -->
      <section id="f-files" class="scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="font-display text-xl font-semibold text-gray-900">7 · What buyers download</h3>
        <p class="mb-5 mt-1 text-sm text-gray-500">
          Appears on: the buyer's "what you get" list before purchase, and their downloads after.
          The deck file lives in section 5; everything here is optional extras.
        </p>

        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          <% {
            speaker_notes:         ["Speaker notes", "application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document", "How to present each chapter (PDF or Word)."],
            outline_file:          ["Outline", "application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document", "The one-page run of show (PDF or Word)."]
          }.each do |field, (label, accept, hint)| %>
            <div>
              <%= form.label field, label, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <% if presentation.public_send(field).attached? %>
                <p class="mb-2 text-sm text-gray-600">Current: <span class="font-medium"><%= presentation.public_send(field).filename %></span></p>
              <% end %>
              <%= form.file_field field, accept: accept, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
              <p class="mt-1 text-xs text-gray-500"><%= hint %></p>
            </div>
          <% end %>

          <div class="md:col-span-2">
            <%= form.label :supplemental_materials, "Anything else", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <% if presentation.supplemental_materials.attached? %>
              <ul class="mb-2 list-inside list-disc text-sm text-gray-500">
                <% presentation.supplemental_materials.each do |material| %>
                  <li><%= material.filename %></li>
                <% end %>
              </ul>
            <% end %>
            <%= form.file_field :supplemental_materials, multiple: true, accept: "application/pdf,image/jpeg,image/jpg,image/png,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
            <p class="mt-1 text-xs text-gray-500">Tasting mats, score sheets, blind-tasting wraps, each shows up by name in the buyer's downloads (max 25MB each).</p>
          </div>

          <div class="md:col-span-2">
            <%= form.label :scorecard, "Custom tasting scorecard (PDF)", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <% if presentation.scorecard.attached? %>
              <p class="mb-2 text-sm text-gray-600">Current: <span class="font-medium"><%= presentation.scorecard.filename %></span>
                &middot; <%= link_to "download", scorecard_presentation_downloads_path(presentation), target: "_blank", rel: "noopener", class: "text-whiskey-700 underline" %></p>
            <% end %>
            <%= form.file_field :scorecard, accept: "application/pdf", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
            <p class="mt-1 text-xs text-gray-500">Upload a scorecard tailored to this deck&rsquo;s pours. Optional, buyers always get the standard blank WSS scorecard to fill in either way.</p>
          </div>
        </div>
      </section>

      <div class="flex items-center gap-4 pb-2">
        <%= form.submit submit_text, class: "cursor-pointer px-6 py-3 bg-whiskey-600 text-white font-semibold rounded-xl hover:bg-whiskey-700 transition" %>
        <%= link_to "Cancel", presentation.persisted? ? admin_presentation_path(presentation) : admin_presentations_path,
            class: "px-6 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-gray-200 transition" %>
      </div>
    </div>

    <!-- ═══ THE MAP: what the buyer page will render ═══ -->
    <aside class="mt-6 lg:sticky lg:top-8 lg:mt-0">
      <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
        <p class="eyebrow text-gray-400">The buyer page</p>
        <h4 class="mt-1 font-display text-lg font-semibold text-gray-900">What renders now</h4>

        <ol class="mt-4 space-y-3 text-sm">
          <li class="flex gap-2.5">
            <%= dot.call(presentation.title.present? && presentation.description.present? ? :on : :need) %>
            <span><a href="#f-cover" data-turbo="false" class="font-medium text-gray-900 hover:text-whiskey-700">The cover</a><br>
              <span class="text-gray-500"><%= presentation.description.present? ? "title, pitch line & price" : "needs the one-line pitch" %></span></span>
          </li>
          <li class="flex gap-2.5">
            <%= dot.call(takeaways_count.positive? ? :on : :off) %>
            <span><a href="#f-pitch" data-turbo="false" class="font-medium text-gray-900 hover:text-whiskey-700">The takeaways</a><br>
              <span class="text-gray-500"><%= takeaways_count.positive? ? pluralize(takeaways_count, "point") : "hidden, none yet" %></span></span>
          </li>
          <li class="flex gap-2.5">
            <%= dot.call(story_words > 40 ? :on : :need) %>
            <span><a href="#f-story" data-turbo="false" class="font-medium text-gray-900 hover:text-whiskey-700">The story</a><br>
              <span class="text-gray-500"><%= story_words > 40 ? "#{number_with_delimiter(story_words)} words · ~#{presentation.reading_time} min read" : "too short, the teaser is the pitch" %></span></span>
          </li>
          <li class="flex gap-2.5">
            <%= dot.call(tasting_notes_n.positive? ? :on : :off) %>
            <span><a href="#f-tasting" data-turbo="false" class="font-medium text-gray-900 hover:text-whiskey-700">What you'll taste</a><br>
              <span class="text-gray-500"><%= tasting_notes_n.positive? ? "#{tasting_notes_n} of 4 notes" : "hidden, empty" %></span></span>
          </li>
          <li class="flex gap-2.5">
            <%= dot.call(slides_count.positive? ? :auto : :need) %>
            <span><a href="#f-slides" data-turbo="false" class="font-medium text-gray-900 hover:text-whiskey-700">The slides</a><br>
              <span class="text-gray-500">
                <% if slides_count.positive? %><%= slides_count %> rendered · automatic
                <% elsif presentation.persisted? && presentation.slide_render_pending? %>rendering&hellip;
                <% elsif presentation.pdf_file.attached? %>not rendered yet
                <% else %>needs the deck file<% end %>
              </span></span>
          </li>
          <li class="flex gap-2.5">
            <%= dot.call(pours_count.positive? ? :on : :off) %>
            <span><a href="#f-pours" data-turbo="false" class="font-medium text-gray-900 hover:text-whiskey-700">The pour list</a><br>
              <span class="text-gray-500"><%= pours_count.positive? ? pluralize(pours_count, "pour") : "hidden, empty" %></span></span>
          </li>
          <li class="flex gap-2.5">
            <%= dot.call(presentation.pdf_file.attached? ? :on : :need) %>
            <span><a href="#f-files" data-turbo="false" class="font-medium text-gray-900 hover:text-whiskey-700">What you get</a><br>
              <span class="text-gray-500">
                <% if presentation.pdf_file.attached? %>the deck<%= extras_count.positive? ? " + #{pluralize(extras_count, 'extra')}" : "" %>
                <% else %>no deck file, required to publish<% end %>
              </span></span>
          </li>
        </ol>

        <div class="mt-5 space-y-2 border-t border-gray-100 pt-4">
          <%= form.submit submit_text, class: "block w-full cursor-pointer rounded-xl bg-whiskey-600 px-4 py-2.5 text-center font-semibold text-white transition hover:bg-whiskey-700" %>
          <% if presentation.persisted? %>
            <%= link_to "Preview as buyer ↗", presentation_path(presentation), target: "_blank",
                class: "block w-full rounded-xl bg-gray-100 px-4 py-2.5 text-center font-medium text-gray-700 transition hover:bg-gray-200" %>
            <p class="text-center text-xs text-gray-400">
              <%= presentation.published? ? "Live in the library" : "Draft, publish from the deck's admin page" %>
            </p>
          <% end %>
        </div>
      </div>
    </aside>
  </div>
<% end %>
