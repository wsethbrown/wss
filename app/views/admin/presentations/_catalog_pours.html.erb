<%# locals: presentation
    The catalog half of section 6: this deck's pours linked to real Bottle
    records, which is what lets the deck page show what rooms scored them and
    a bottle page name the decks that call for it.

    These controls sit INSIDE the deck form visually but are owned by
    #link-pour-form (rendered after the deck form in edit.html.erb) via the
    HTML5 `form` attribute. A nested <form> would be invalid HTML, and this
    section has to live next to the written cards it replaces. Same reason
    "Remove" is a turbo_method link rather than button_to: button_to emits a
    form.

    Edit-only, since the rows need a persisted deck. %>
<div class="mt-8 border-t border-gray-200 pt-6">
  <h4 class="font-semibold text-gray-900">Linked to the catalog</h4>
  <p class="mb-4 mt-1 text-sm text-gray-500">
    Link each pour to its catalog bottle and the deck page shows real tasting scores instead of
    plain text, while each bottle's page names this deck. Linking even one bottle replaces the
    written cards above, so a deck never shows two pour lists.
    <span class="text-gray-400">Linking saves right away, so save the rest of your edits first.</span>
  </p>

  <% pours = presentation.presentation_bottles.includes(:bottle) %>
  <% if pours.any? %>
    <div class="mb-5 divide-y divide-gray-100 rounded-xl border border-gray-200">
      <% pours.each do |pour| %>
        <div class="flex items-center justify-between gap-4 px-4 py-3">
          <div class="min-w-0">
            <%= link_to pour.bottle.display_name, bottle_path(pour.bottle), target: "_blank", rel: "noopener",
                class: "truncate font-medium text-gray-900 hover:text-whiskey-700" %>
            <% if pour.label.present? %>
              <span class="ml-2 text-sm text-gray-500"><%= pour.label %></span>
            <% end %>
          </div>
          <%# Owned by the matching hidden form in edit.html.erb. A data-turbo-method
              link was tried here first and silently never issued the DELETE. %>
          <button type="submit" form="unlink-pour-<%= pour.id %>"
                  data-turbo-confirm="Remove <%= pour.bottle.name %> from this deck's pour list?"
                  class="shrink-0 cursor-pointer text-sm font-semibold text-red-600 hover:text-red-500">
            Remove
          </button>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mb-5 text-sm text-gray-500">No catalog bottles linked yet.</p>
  <% end %>

  <div class="space-y-3">
    <div class="relative" data-controller="bottle-search"
         data-bottle-search-url-value="<%= search_bottles_path %>"
         data-bottle-search-return-to-value="<%= edit_admin_presentation_path(presentation) %>">
      <input type="search" placeholder="Link a pour, search bottles or distilleries…" autocomplete="off"
             form="link-pour-form"
             data-bottle-search-target="input" data-action="input->bottle-search#query"
             class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-whiskey-500">
      <input type="hidden" name="presentation_bottle[bottle_id]" form="link-pour-form"
             data-bottle-search-target="bottleId">
      <div data-bottle-search-target="results"
           class="absolute inset-x-0 top-full z-20 mt-1 hidden overflow-hidden rounded-xl border border-gray-200 bg-white shadow-lg"></div>
    </div>
    <div class="flex items-center gap-3">
      <input type="text" name="presentation_bottle[label]" form="link-pour-form"
             placeholder='How it appears on the pour list, e.g. "the opener" (optional)'
             class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500">
      <button type="submit" form="link-pour-form"
              class="cursor-pointer shrink-0 rounded-xl bg-whiskey-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-whiskey-700">
        Link pour
      </button>
    </div>
  </div>
</div>
