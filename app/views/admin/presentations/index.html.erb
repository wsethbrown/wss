<% content_for :title, "Admin - Presentations" %>

<div class="flex justify-between items-center mb-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Presentations</h1>
    <p class="mt-2 text-gray-600"><%= @presentations.count %> presentations total</p>
  </div>
  <%= link_to new_admin_presentation_path, class: "inline-flex items-center gap-2 px-4 py-3 bg-whiskey-600 text-white font-semibold rounded-xl hover:bg-whiskey-700 transition shadow-sm" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
    </svg>
    New Presentation
  <% end %>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
  <% if @presentations.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Author</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Purchases</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @presentations.each do |presentation| %>
            <tr>
              <td class="max-w-xs px-4 py-4">
                <div class="truncate text-sm font-medium text-gray-900"><%= presentation.title %></div>
                <div class="truncate text-sm text-gray-500"><%= presentation.description %></div>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= presentation.author&.full_name || 'N/A' %>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-semibold rounded-full bg-whiskey-100 text-whiskey-800">
                  <%= presentation.category || 'Uncategorized' %>
                </span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                $<%= presentation.price || '0.00' %>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= presentation.user_presentations.count %>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <% if presentation.published? %>
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Published</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">Draft</span>
                <% end %>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm font-medium">
                <div class="flex items-center gap-2">
                  <%= link_to "View", admin_presentation_path(presentation), class: "text-whiskey-600 hover:text-whiskey-900" %>
                  <%= link_to "Edit", edit_admin_presentation_path(presentation), class: "text-whiskey-600 hover:text-whiskey-900" %>
                  <%= button_to "Delete", admin_presentation_path(presentation), 
                      method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this presentation?" }, 
                      class: "text-red-600 hover:text-red-900 cursor-pointer" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12">
      <div class="text-gray-500 mb-4">
        <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No presentations yet</h3>
      <p class="text-gray-500 mb-6">Get started by creating your first presentation.</p>
      <%= link_to new_admin_presentation_path, class: "inline-flex items-center gap-2 px-4 py-3 bg-whiskey-600 text-white font-semibold rounded-xl hover:bg-whiskey-700 transition shadow-sm" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Create Your First Presentation
      <% end %>
    </div>
  <% end %>
</div>