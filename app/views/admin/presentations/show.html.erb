<% content_for :title, "#{@presentation.title} - Admin" %>

<% content_for :breadcrumbs do %>
  <li class="flex items-center">
    <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <%= link_to "Presentations", admin_presentations_path, class: "text-gray-500 hover:text-gray-700" %>
  </li>
  <li class="flex items-center">
    <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <span class="text-gray-900 font-medium"><%= @presentation.title %></span>
  </li>
<% end %>

<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-4 mb-4">
        <%= link_to admin_presentations_path, class: "text-gray-500 hover:text-gray-700" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
        <h1 class="text-3xl font-bold text-gray-900"><%= @presentation.title %></h1>
      </div>
      <p class="text-gray-600">Created by <%= @presentation.author&.full_name %> on <%= @presentation.created_at.strftime("%B %d, %Y") %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_admin_presentation_path(@presentation), 
          class: "px-4 py-2 bg-whiskey-600 text-white font-medium rounded-lg hover:bg-whiskey-700" %>
      <%= button_to "Delete", admin_presentation_path(@presentation), 
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this presentation?" },
          class: "px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 cursor-pointer" %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Description -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Description</h2>
      <p class="text-gray-700"><%= @presentation.description.presence || "No description provided." %></p>
    </div>

    <!-- The Story, rendered exactly as buyers read it -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="text-lg font-semibold text-gray-900">The story</h2>
        <span class="text-xs text-gray-400"><%= pluralize(@presentation.content.to_s.lines.count, 'source line') %> · rendered as on the deck page</span>
      </div>
      <% if @presentation.content.present? %>
        <div class="prose-deck">
          <%= render_markdown(@presentation.content) %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No story yet, add it in the editor.</p>
      <% end %>
    </div>

    <!-- Rendered slides -->
    <% if @presentation.slide_images.attached? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Slides (<%= @presentation.slide_images.count %>)</h2>
        <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
          <% @presentation.slide_images.order(:id).each_with_index do |slide, i| %>
            <figure>
              <%= image_tag slide, alt: "Slide #{i + 1}", loading: 'lazy', class: 'w-full rounded-lg border border-gray-200' %>
              <figcaption class="mt-1 text-center text-xs text-gray-400"><%= i + 1 %></figcaption>
            </figure>
          <% end %>
        </div>
      </div>
    <% elsif @presentation.pdf_file.attached? %>
      <div class="rounded-2xl border border-whiskey-200 bg-whiskey-50 p-6 text-sm text-whiskey-900">
        Slide previews are rendering in the background, refresh in a moment.
      </div>
    <% end %>

    <!-- Bottle list, parsed -->
    <% recs = @presentation.parsed_whiskey_recommendations %>
    <% if recs.any? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Whiskey recommendations</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
                <th class="pb-2 pr-4">Bottle</th><th class="pb-2 pr-4">Region</th>
                <th class="pb-2 pr-4">Price</th><th class="pb-2 pr-4">Style</th><th class="pb-2">Notes</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% recs.each do |r| %>
                <tr>
                  <td class="py-2 pr-4 font-medium text-gray-900"><%= r[:name] %></td>
                  <td class="py-2 pr-4 text-gray-600"><%= r[:region] %></td>
                  <td class="py-2 pr-4 text-gray-600"><%= r[:price] %></td>
                  <td class="py-2 pr-4 text-gray-600"><%= r[:style] %></td>
                  <td class="py-2 text-gray-600"><%= r[:notes] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <!-- Tasting notes -->
    <% tasting = { 'Nose' => @presentation.nose_notes, 'Palate' => @presentation.palate_notes,
                   'Finish' => @presentation.finish_notes, 'Body' => @presentation.body_notes }.compact_blank %>
    <% if tasting.any? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Tasting notes</h2>
        <dl class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <% tasting.each do |label, notes| %>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-wider text-whiskey-700"><%= label %></dt>
              <dd class="mt-1 text-gray-700"><%= notes %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>

    <!-- Complete file inventory -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Files</h2>

      <% file_rows = [
        ['Deck file (buyers download)', @presentation.pdf_file],
        ['Sneak peek',                  @presentation.sneak_peek_file],
        ['Speaker notes',               @presentation.speaker_notes],
        ['Outline',                     @presentation.outline_file],
        ['Recommendations sheet',       @presentation.recommendations_sheet]
      ] %>
      <ul class="space-y-2">
        <% file_rows.each do |label, attachment| %>
          <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2 text-sm">
            <span class="font-medium text-gray-700"><%= label %></span>
            <% if attachment.attached? %>
              <span class="text-gray-600"><%= attachment.filename %> <span class="text-xs text-gray-400">(<%= number_to_human_size(attachment.byte_size) %>)</span></span>
            <% else %>
              <span class="text-xs text-gray-400">not uploaded</span>
            <% end %>
          </li>
        <% end %>
        <% @presentation.supplemental_materials.each do |m| %>
          <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2 text-sm">
            <span class="font-medium text-gray-700">Extra</span>
            <span class="text-gray-600"><%= m.filename %> <span class="text-xs text-gray-400">(<%= number_to_human_size(m.byte_size) %>)</span></span>
          </li>
        <% end %>
      </ul>

      <!-- Images -->
      <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
        <% if @presentation.featured_image.attached? %>
          <figure>
            <%= image_tag @presentation.featured_image, class: 'aspect-video w-full rounded-lg border border-gray-200 object-cover' %>
            <figcaption class="mt-1 text-center text-xs text-gray-400">Cover</figcaption>
          </figure>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Details -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Details</h2>
      <dl class="space-y-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Category</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @presentation.category || "Uncategorized" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Price</dt>
          <dd class="mt-1 text-sm text-gray-900">$<%= @presentation.price || "0.00" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Duration</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @presentation.duration_label || "Not specified" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Difficulty</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @presentation.difficulty || "Not specified" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-1">
            <% if @presentation.published? %>
              <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Published</span>
            <% else %>
              <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">Draft</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Purchase Stats -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Purchase Statistics</h2>
      <dl class="space-y-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Total Purchases</dt>
          <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @purchases.count %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Revenue</dt>
          <dd class="mt-1 text-xl font-semibold text-gray-900">
            $<%= @purchases.where(purchase_type: 'direct').sum(:purchase_price) || 0 %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Credit Purchases</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @purchases.where(purchase_type: 'credit').count %></dd>
        </div>
      </dl>
    </div>

    <!-- Actions -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Actions</h2>
      <div class="space-y-3">
        <%# Publishing is explicit and gated on the deck file + rendered slide previews. %>
        <% if @presentation.published? %>
          <%= button_to "Unpublish (back to draft)", unpublish_admin_presentation_path(@presentation), method: :post,
              class: "block w-full cursor-pointer text-center px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200" %>
        <% elsif !@presentation.pdf_file.attached? %>
          <div class="rounded-lg border border-whiskey-200 bg-whiskey-50 px-4 py-3 text-sm text-whiskey-900">
            <span class="font-semibold">Draft.</span> Attach the deck file
            (the presentation buyers download) in the editor to enable publishing.
          </div>
        <% elsif @presentation.slides_rendered? %>
          <%= button_to "Publish to the library", publish_admin_presentation_path(@presentation), method: :post,
              class: "block w-full cursor-pointer text-center px-4 py-2 bg-whiskey-600 text-white font-semibold rounded-lg hover:bg-whiskey-700" %>
        <% elsif @presentation.slide_render_pending? %>
          <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            <span class="font-semibold">Rendering slide previews&hellip;</span>
            Usually under a minute. Publishing unlocks when they're ready, refresh to check.
          </div>
        <% else %>
          <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
            <span class="font-semibold">No slide previews.</span> The render didn't run
            or failed. Re-render below, then publish.
          </div>
        <% end %>

        <% if @presentation.pdf_file.attached? && !@presentation.slide_render_pending? %>
          <%= button_to "Re-render slide previews", render_slides_admin_presentation_path(@presentation), method: :post,
              class: "block w-full cursor-pointer text-center px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200" %>
        <% end %>
        <%= link_to "View on Site", presentation_path(@presentation), 
            target: "_blank",
            class: "block w-full text-center px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200" %>
        <%= link_to "View Purchases", "#", 
            class: "block w-full text-center px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200" %>
        <%= link_to "Download Analytics", admin_presentation_downloads_analytics_path(@presentation), 
            class: "block w-full text-center px-4 py-2 bg-blue-100 text-blue-700 font-medium rounded-lg hover:bg-blue-200" %>
      </div>
    </div>
  </div>
</div>

<!-- Recent Purchases -->
<% if @purchases.any? %>
  <div class="mt-8">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Recent Purchases</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Purchase Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @purchases.limit(10).each do |purchase| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= purchase.user.full_name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if purchase.purchase_type == 'credit' %>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800">Credit</span>
                  <% else %>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Direct</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <% if purchase.purchase_type == 'direct' %>
                    $<%= purchase.purchase_price || @presentation.price %>
                  <% else %>
                    1 Credit
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= purchase.created_at.strftime("%b %d, %Y") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>