<% content_for :title, "#{@presentation.title} - Admin" %>

<% content_for :breadcrumbs do %>
  <li class="flex items-center">
    <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <%= link_to "Presentations", admin_presentations_path, class: "text-gray-500 hover:text-gray-700" %>
  </li>
  <li class="flex items-center">
    <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <span class="text-gray-900 font-medium"><%= @presentation.title %></span>
  </li>
<% end %>

<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-4 mb-4">
        <%= link_to admin_presentations_path, class: "text-gray-500 hover:text-gray-700" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
        <h1 class="text-3xl font-bold text-gray-900"><%= @presentation.title %></h1>
      </div>
      <p class="text-gray-600">Created by <%= @presentation.author&.full_name %> on <%= @presentation.created_at.strftime("%B %d, %Y") %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_admin_presentation_path(@presentation), 
          class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700" %>
      <%= button_to "Delete", admin_presentation_path(@presentation), 
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this presentation?" },
          class: "px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 cursor-pointer" %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Description -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Description</h2>
      <p class="text-gray-700"><%= @presentation.description || "No description provided." %></p>
    </div>

    <!-- Content Preview -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Content Preview</h2>
      <div class="prose prose-sm max-w-none text-gray-700">
        <%= simple_format(truncate(@presentation.content || "No content yet.", length: 500)) %>
      </div>
    </div>

    <!-- Whiskey Recommendations -->
    <% if @presentation.whiskey_recommendations.present? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">Whiskey Recommendations</h2>
        <div class="prose prose-sm max-w-none text-gray-700">
          <%= simple_format(@presentation.whiskey_recommendations) %>
        </div>
      </div>
    <% end %>

    <!-- Tasting Notes -->
    <% if @presentation.tasting_notes.present? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">Tasting Notes</h2>
        <div class="prose prose-sm max-w-none text-gray-700">
          <%= simple_format(@presentation.tasting_notes) %>
        </div>
      </div>
    <% end %>

    <!-- Uploaded Files -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Uploaded Files</h2>
      
      <% if @presentation.featured_image.attached? %>
        <div class="mb-4">
          <h3 class="text-sm font-medium text-gray-700 mb-2">Featured Image</h3>
          <%= image_tag @presentation.featured_image, class: "w-full rounded-lg shadow-sm" %>
        </div>
      <% end %>
      
      <% if @presentation.pdf_file.attached? %>
        <div class="mb-4">
          <h3 class="text-sm font-medium text-gray-700 mb-2">Presentation PDF</h3>
          <div class="flex items-center gap-2 p-3 bg-gray-50 rounded-lg">
            <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8l4 4v10a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-gray-700"><%= @presentation.pdf_file.filename %></span>
            <span class="text-xs text-gray-500">(<%= number_to_human_size(@presentation.pdf_file.byte_size) %>)</span>
          </div>
        </div>
      <% end %>
      
      <% if @presentation.supplemental_materials.attached? %>
        <div>
          <h3 class="text-sm font-medium text-gray-700 mb-2">Supplemental Materials</h3>
          <ul class="space-y-2">
            <% @presentation.supplemental_materials.each do |material| %>
              <li class="flex items-center gap-2 p-3 bg-gray-50 rounded-lg">
                <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 01-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm text-gray-700"><%= material.filename %></span>
                <span class="text-xs text-gray-500">(<%= number_to_human_size(material.byte_size) %>)</span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
      
      <% unless @presentation.featured_image.attached? || @presentation.pdf_file.attached? || @presentation.supplemental_materials.attached? %>
        <p class="text-sm text-gray-500">No files uploaded yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Details -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Details</h2>
      <dl class="space-y-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Category</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @presentation.category || "Uncategorized" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Price</dt>
          <dd class="mt-1 text-sm text-gray-900">$<%= @presentation.price || "0.00" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Duration</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @presentation.duration || "Not specified" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Difficulty</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @presentation.difficulty || "Not specified" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-1">
            <% if @presentation.published? %>
              <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Published</span>
            <% else %>
              <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">Draft</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Purchase Stats -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Purchase Statistics</h2>
      <dl class="space-y-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Total Purchases</dt>
          <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @purchases.count %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Revenue</dt>
          <dd class="mt-1 text-xl font-semibold text-gray-900">
            $<%= @purchases.where(purchase_type: 'direct').sum(:purchase_price) || 0 %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Credit Purchases</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @purchases.where(purchase_type: 'credit').count %></dd>
        </div>
      </dl>
    </div>

    <!-- Actions -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Actions</h2>
      <div class="space-y-3">
        <%= link_to "View on Site", presentation_path(@presentation), 
            target: "_blank",
            class: "block w-full text-center px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200" %>
        <%= link_to "View Purchases", "#", 
            class: "block w-full text-center px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200" %>
        <%= link_to "Download Analytics", admin_presentation_downloads_analytics_path(@presentation), 
            class: "block w-full text-center px-4 py-2 bg-blue-100 text-blue-700 font-medium rounded-lg hover:bg-blue-200" %>
      </div>
    </div>
  </div>
</div>

<!-- Recent Purchases -->
<% if @purchases.any? %>
  <div class="mt-8">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Recent Purchases</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Purchase Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @purchases.limit(10).each do |purchase| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= purchase.user.full_name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if purchase.purchase_type == 'credit' %>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800">Credit</span>
                  <% else %>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Direct</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <% if purchase.purchase_type == 'direct' %>
                    $<%= purchase.purchase_price || @presentation.price %>
                  <% else %>
                    1 Credit
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= purchase.created_at.strftime("%b %d, %Y") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>