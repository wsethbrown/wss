<%# locals: f (a fields_for builder for one PresentationBottle)
    One row of the deck's pour list. Two shapes in one card:
      - linked: bottle_id is set, so the name follows the catalog and the deck
        picks up that bottle's reviews.
      - free text: no bottle, just a name, for a cocktail or an uncatalogued
        bottle.
    The written fields belong to the deck author either way, so they show for
    both. Destroy is a checkbox, not a request: the row goes when the deck is
    saved, like everything else on this form. %>
<%# bottle-search is scoped to the WHOLE row, not just the search box, so that
    picking a bottle can prefill this row's origin and style fields
    ([data-bottle-fill]). They have to be inside the controller's element to be
    in scope. %>
<div class="pour-row rounded-lg border border-gray-200 bg-gray-50 p-4" data-pour-list-target="row"
     data-controller="bottle-search" data-bottle-search-url-value="<%= search_bottles_path %>">
  <div class="mb-3 flex items-start justify-between gap-3">
    <h4 class="text-sm font-medium text-gray-700">Pour</h4>
    <label class="flex cursor-pointer items-center gap-1.5 text-sm text-red-600 hover:text-red-800">
      <%= f.check_box :_destroy, class: "h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-500",
          data: { action: "change->pour-list#toggleDestroy" } %>
      Remove
    </label>
  </div>

  <%# The catalog link. bottle-search writes the id into the hidden field; the
      visible field is only a picker, so it is deliberately unnamed. %>
  <div class="relative mb-3">
    <label class="mb-1 block text-xs font-medium text-gray-600">
      Catalog bottle <span class="text-gray-400">optional, but it is what earns this deck real scores</span>
    </label>
    <% linked = f.object.bottle %>
    <input type="search" autocomplete="off" data-bottle-search-target="input"
           data-action="input->bottle-search#query"
           value="<%= linked&.display_name %>"
           placeholder="Search bottles or distilleries…"
           class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500">
    <%= f.hidden_field :bottle_id, data: { bottle_search_target: "bottleId" } %>
    <div data-bottle-search-target="results"
         class="absolute inset-x-0 top-full z-20 mt-1 hidden overflow-hidden rounded-xl border border-gray-200 bg-white shadow-lg"></div>
  </div>

  <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
    <div>
      <%= f.label :name, "Name", class: "mb-1 block text-xs font-medium text-gray-600" %>
      <%= f.text_field :name, placeholder: "e.g., Glenfiddich 12, or Mint Julep",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
      <p class="mt-1 text-xs text-gray-500">Leave blank when a catalog bottle is linked; the catalog name is used.</p>
    </div>
    <div>
      <%= f.label :origin, "Origin", class: "mb-1 block text-xs font-medium text-gray-600" %>
      <%= f.text_field :origin, placeholder: "e.g., Speyside, or Kentucky, 1803",
          data: { bottle_fill: "origin" },
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
      <p class="mt-1 text-xs text-gray-500">Filled in from the catalog when you link a bottle; edit freely.</p>
    </div>
    <div>
      <%= f.label :price, "Price", class: "mb-1 block text-xs font-medium text-gray-600" %>
      <%= f.text_field :price, placeholder: "e.g., $45",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
    </div>
    <div>
      <%= f.label :label, "Role on the night", class: "mb-1 block text-xs font-medium text-gray-600" %>
      <%= f.text_field :label, placeholder: 'e.g., "the opener"',
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :style, "Style", class: "mb-1 block text-xs font-medium text-gray-600" %>
      <%= f.text_area :style, rows: 2, placeholder: "e.g., Light and fruity. How it's made, how it's matured.",
          data: { bottle_fill: "style" },
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :notes, "Tasting notes", class: "mb-1 block text-xs font-medium text-gray-600" %>
      <%= f.text_area :notes, rows: 2, placeholder: "e.g., Pear, oak, subtle spice. Pour it for the 1820s chapter.",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
    </div>
  </div>

  <%= f.hidden_field :position, value: f.object.position %>
</div>
