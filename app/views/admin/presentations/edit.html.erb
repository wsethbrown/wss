<% content_for :title, "Edit Presentation - Admin" %>

<% content_for :breadcrumbs do %>
  <li class="flex items-center">
    <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <%= link_to "Presentations", admin_presentations_path, class: "text-gray-500 hover:text-gray-700" %>
  </li>
  <li class="flex items-center">
    <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <%= link_to @presentation.title, admin_presentation_path(@presentation), class: "text-gray-500 hover:text-gray-700" %>
  </li>
  <li class="flex items-center">
    <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <span class="text-gray-900 font-medium">Edit</span>
  </li>
<% end %>

<div class="mb-8">
  <div class="flex items-center gap-4 mb-4">
    <%= link_to admin_presentation_path(@presentation), class: "text-gray-500 hover:text-gray-700" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
    <% end %>
    <h1 class="text-3xl font-bold text-gray-900">Edit Presentation</h1>
  </div>
  <p class="text-gray-600">Each section mirrors the buyer page, top to bottom, the rail on the right shows what will actually render.</p>
</div>

<%= render 'form', presentation: @presentation, submit_text: 'Save deck' %>
<%# The catalog link for this deck's pours (Phase 3 "deck ties"). Lives
    OUTSIDE the deck form on purpose: it posts to its own controller, and a
    nested <form> would be invalid HTML. Edit-only, since the rows need a
    persisted deck. The text pour cards above stay as they are — this adds
    the link to real bottles, which is what lets the deck show what rooms
    thought of these pours and lets a bottle page name the decks using it. %>
<section id="pours" class="mt-8 scroll-mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <h3 class="font-display text-xl font-semibold text-gray-900">
    Pours in the catalog
    <span class="ml-1 align-middle text-xs font-sans font-medium uppercase tracking-wide text-gray-400">optional</span>
  </h3>
  <p class="mb-5 mt-1 text-sm text-gray-500">
    Appears on: the deck page, showing what societies scored these bottles, and on each bottle's own
    page as "poured in this deck". Linking is what connects a deck to real tasting notes; the cards
    above stay the deck's own written recommendations.
  </p>

  <% pours = @presentation.presentation_bottles.includes(:bottle) %>
  <% if pours.any? %>
    <div class="mb-5 divide-y divide-gray-100 rounded-xl border border-gray-200">
      <% pours.each do |pour| %>
        <div class="flex items-center justify-between gap-4 px-4 py-3">
          <div class="min-w-0">
            <%= link_to pour.bottle.display_name, bottle_path(pour.bottle), target: "_blank", rel: "noopener",
                class: "truncate font-medium text-gray-900 hover:text-whiskey-700" %>
            <% if pour.label.present? %>
              <span class="ml-2 text-sm text-gray-500"><%= pour.label %></span>
            <% end %>
          </div>
          <%= button_to "Remove", admin_presentation_presentation_bottle_path(@presentation, pour), method: :delete,
              form: { data: { turbo_confirm: "Remove #{pour.bottle.name} from this deck's pour list?" } },
              class: "shrink-0 cursor-pointer text-sm font-semibold text-red-600 hover:text-red-500" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mb-5 text-sm text-gray-500">No catalog bottles linked yet.</p>
  <% end %>

  <%= form_with url: admin_presentation_presentation_bottles_path(@presentation), method: :post, class: "space-y-3" do %>
    <div class="relative" data-controller="bottle-search"
         data-bottle-search-url-value="<%= search_bottles_path %>"
         data-bottle-search-return-to-value="<%= edit_admin_presentation_path(@presentation) %>">
      <input type="search" placeholder="Link a pour, search bottles or distilleries…" autocomplete="off"
             data-bottle-search-target="input" data-action="input->bottle-search#query"
             class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-whiskey-500">
      <input type="hidden" name="presentation_bottle[bottle_id]" data-bottle-search-target="bottleId">
      <div data-bottle-search-target="results"
           class="absolute inset-x-0 top-full z-20 mt-1 hidden overflow-hidden rounded-xl border border-gray-200 bg-white shadow-lg"></div>
    </div>
    <div class="flex items-center gap-3">
      <input type="text" name="presentation_bottle[label]" placeholder='How it appears on the pour list, e.g. "the opener" (optional)'
             class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-whiskey-500">
      <%= submit_tag "Link pour", class: "cursor-pointer shrink-0 rounded-xl bg-whiskey-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-whiskey-700" %>
    </div>
  <% end %>
</section>
