<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Invite a member</h1>
    <p class="text-gray-600 mt-2">
      Creates their account and emails a claim link. Once they accept, they sign in
      like anyone else with a magic link or Google.
    </p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
    <%= form_with url: admin_invitations_path, scope: :invitation, local: true, html: { class: "space-y-6" } do |form| %>
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <%= form.label :first_name, "First name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :first_name, value: (@invitation || {})[:first_name], required: true,
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <div>
          <%= form.label :last_name, "Last name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :last_name, value: (@invitation || {})[:last_name], required: true,
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
      </div>
      <div>
        <%= form.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.email_field :email, value: (@invitation || {})[:email], required: true,
            class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
      <div class="flex items-center gap-4 pt-2">
        <%= form.submit "Send invitation", class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
        <%= link_to "Cancel", admin_users_path, class: "px-6 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition" %>
      </div>
      <p class="text-xs text-gray-500">
        The claim link works for 14 days. You can re-send it from the member's page if it lapses.
      </p>
    <% end %>
  </div>
</div>
