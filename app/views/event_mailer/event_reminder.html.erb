<%= render "mailers/layout_open" %>
      <h2 style="margin-top:0;">Tomorrow: <%= @event.title %></h2>
      <p class="meta"><strong>When:</strong> <%= @event.start_time.strftime("%A, %B %-d at %-l:%M %p") %></p>
      <% if @event.location.present? %><p class="meta"><strong>Where:</strong> <%= @event.location %></p><% end %>
      <% if @event.event_bottles.any? %>
        <p class="meta"><%= pluralize(@event.event_bottles.count, "pour") %> on the list.</p>
      <% end %>
      <a class="btn" href="<%= society_event_url(@event.society, @event) %>">See the event</a>
      <div class="rsvp">
        <a class="btn" style="background:#047857;" href="<%= @rsvp_urls["yes"] %>">RSVP yes</a>
        <a class="btn" style="background:#b45309;" href="<%= @rsvp_urls["maybe"] %>">Maybe</a>
        <a class="btn" style="background:#6a5a48;" href="<%= @rsvp_urls["no"] %>">Can't make it</a>
      </div>
      <p class="meta" style="margin-top: 10px;">One click records your answer. You can change it any time on the event page.</p>
<%= render "mailers/layout_close", footer_note: "You can turn off event emails any time in your account settings at whiskeysharesociety.com." %>
