<div class="mx-auto max-w-2xl px-4 pt-8 pb-16">
  <div class="mb-8 text-center">
    <p class="eyebrow mb-3 text-whiskey-600">Your bell</p>
    <h1 class="font-display text-4xl font-semibold leading-tight text-gray-900">Notifications</h1>
    <div class="rule-double mx-auto mt-6 w-20 text-whiskey-800"></div>
  </div>

  <% rows = @notifications.filter_map { |n| text = notification_text(n); [n, text] if text } %>
  <% if rows.empty? %>
    <p class="text-center text-gray-500">Nothing yet. When someone follows you, likes a tasting, or your societies schedule a night, it lands here.</p>
  <% else %>
    <div class="divide-y divide-whiskey-100 rounded-2xl border border-whiskey-200 bg-white shadow-sm">
      <% rows.each do |notification, text| %>
        <div class="flex items-start gap-3 p-4 <%= "bg-whiskey-50/60" if @unread_ids.include?(notification.id) %>">
          <% if notification.actor %>
            <%= link_to profile_path(notification.actor), class: "shrink-0" do %>
              <% if notification.actor.has_profile_image? %>
                <img src="<%= notification.actor.profile_image_url %>" alt="" class="h-9 w-9 rounded-full object-cover">
              <% else %>
                <div class="flex h-9 w-9 items-center justify-center rounded-full text-sm font-medium text-white" style="background-color: <%= notification.actor.avatar_color %>;"><%= notification.actor.initials %></div>
              <% end %>
            <% end %>
          <% else %>
            <div class="h-9 w-9 shrink-0 rounded-full bg-whiskey-100"></div>
          <% end %>
          <div class="min-w-0 flex-1">
            <% url = notification_url(notification) %>
            <p class="text-sm text-gray-900">
              <% if url %>
                <%= link_to text, url, class: "hover:text-whiskey-700" %>
              <% else %>
                <%= text %>
              <% end %>
            </p>
            <p class="mt-0.5 text-xs text-gray-500"><%= time_ago_in_words(notification.created_at) %> ago</p>
            <% if notification.action == "society_invite" && notification.notifiable&.pending? %>
              <div class="mt-3 flex gap-2">
                <%= button_to "Accept", accept_society_invitation_path(notification.notifiable), method: :patch,
                    class: "rounded-lg bg-whiskey-600 px-4 py-1.5 text-sm font-medium text-white hover:bg-whiskey-700 transition cursor-pointer" %>
                <%= button_to "Decline", decline_society_invitation_path(notification.notifiable), method: :patch,
                    class: "rounded-lg bg-gray-100 px-4 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-200 transition cursor-pointer" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
