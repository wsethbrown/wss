<!DOCTYPE html>
<html>
  <head>
    <title>WSS Admin Panel</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <!-- Admin Navigation -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to admin_root_path, class: "flex items-center gap-3" do %>
              <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-sm">A</span>
              </div>
              <span class="text-xl font-bold text-gray-900">WSS Admin</span>
            <% end %>
          </div>
          
          <div class="flex items-center gap-6">
            <%= link_to "Presentations", admin_presentations_path, class: "text-gray-700 hover:text-black font-medium transition-colors" %>
            <%= link_to "Users", admin_users_path, class: "text-gray-700 hover:text-black font-medium transition-colors" %>
            <%= link_to "Back to Site", root_path, class: "text-blue-600 hover:text-blue-700 font-medium transition-colors" %>
            <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "text-red-600 hover:text-red-700 font-medium transition-colors cursor-pointer" %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 px-4 py-3">
          <%= notice %>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-800 px-4 py-3">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>