<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Whiskey Share Society" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Brand type: Fraunces (display), Instrument Sans (UI), Source Serif 4 (deck reading) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..700&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..600&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Detect and store user's timezone -->
    <script>
      (function() {
        const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
        document.cookie = "browser_timezone=" + timezone + "; path=/; max-age=31536000; SameSite=Lax";
      })();
    </script>

    <style>
      /* Sticky-footer layout. NOTE: keep body free of `height: 100%` and of any
         overflow that creates a scroll container (overflow-x: hidden would),
         or position: sticky descendants stop sticking. `clip` is safe. */
      body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: clip;
      }
      main {
        flex: 1 0 auto;
      }
      footer {
        flex-shrink: 0;
      }
    </style>
  </head>

  <body class="bg-white text-black min-h-screen font-sans">
    <!-- Top Navigation Bar -->
    <nav class="fixed top-0 left-0 w-full z-50 bg-char/95 backdrop-blur border-b border-oak-edge">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-3">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 text-cream hover:text-whiskey-200 transition">
          <%= image_tag "wss-logo.jpg", alt: "Whiskey Share Society", class: "h-10 w-auto rounded-lg" %>
          <span class="hidden sm:inline font-display text-xl font-semibold tracking-tight">Whiskey Share Society</span>
        </a>
        <!-- Navigation Links -->
        <div class="hidden md:flex gap-2 items-center">
          <%= nav_link_to 'Societies', societies_path %>
          <%= nav_link_to 'Decks', presentations_path %>
          <% if user_signed_in? %>
            <% if current_user.subscription_active? && current_user.credits > 0 %>
              <div class="ml-2 flex items-center gap-2 rounded-full border border-whiskey-500/40 bg-whiskey-500/10 px-3 py-1">
                <svg class="w-4 h-4 text-whiskey-300" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                </svg>
                <span class="text-sm font-semibold text-whiskey-200"><%= current_user.credits %> Credit<%= 's' if current_user.credits != 1 %></span>
              </div>
            <% end %>
            <div class="ml-3 flex items-center gap-4">
              <%= link_to account_path, class: "flex items-center gap-2 text-cream/90 hover:text-cream transition" do %>
                <% if current_user.profile_image.attached? %>
                  <%= image_tag current_user.profile_image, class: "h-8 w-8 rounded-full object-cover border border-oak-edge", alt: current_user.full_name %>
                <% else %>
                  <div class="h-8 w-8 rounded-full flex items-center justify-center text-white font-semibold text-sm border border-oak-edge" style="background-color: <%= current_user.avatar_color %>">
                    <%= current_user.initials %>
                  </div>
                <% end %>
                <span class="hidden sm:inline font-medium">Account</span>
              <% end %>
              <div class="h-6 w-px bg-oak-edge"></div>
              <%= link_to 'Sign Out', destroy_user_session_path, data: { 'turbo-method': :delete, 'turbo-confirm': 'Are you sure you want to sign out?' }, class: 'text-cream/50 hover:text-red-400 transition' %>
            </div>
          <% else %>
            <%= nav_link_to 'Sign in', auth_path %>
            <%= link_to 'Join the Society', auth_path, class: 'ml-2 inline-flex items-center rounded-xl bg-whiskey-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-whiskey-400' %>
          <% end %>
        </div>

        <!-- Mobile menu -->
        <details class="relative md:hidden">
          <summary class="flex cursor-pointer list-none items-center rounded-lg p-2 text-cream hover:bg-oak [&::-webkit-details-marker]:hidden" aria-label="Menu">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
            </svg>
          </summary>
          <div class="absolute right-0 mt-2 w-56 rounded-2xl border border-oak-edge bg-char p-2 shadow-xl">
            <%= link_to 'Societies', societies_path, class: 'block rounded-xl px-4 py-2.5 font-medium text-cream/90 hover:bg-oak' %>
            <%= link_to 'Decks', presentations_path, class: 'block rounded-xl px-4 py-2.5 font-medium text-cream/90 hover:bg-oak' %>
            <% if user_signed_in? %>
              <%= link_to 'Account', account_path, class: 'block rounded-xl px-4 py-2.5 font-medium text-cream/90 hover:bg-oak' %>
              <%= link_to 'Sign Out', destroy_user_session_path, data: { 'turbo-method': :delete, 'turbo-confirm': 'Are you sure you want to sign out?' }, class: 'block rounded-xl px-4 py-2.5 font-medium text-cream/60 hover:bg-oak' %>
            <% else %>
              <%= link_to 'Sign in', auth_path, class: 'block rounded-xl px-4 py-2.5 font-medium text-cream/90 hover:bg-oak' %>
              <%= link_to 'Join the Society', auth_path, class: 'mt-1 block rounded-xl bg-whiskey-500 px-4 py-2.5 text-center font-semibold text-white hover:bg-whiskey-400' %>
            <% end %>
          </div>
        </details>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice || alert %>
      <div class="max-w-2xl mx-auto pt-20 px-4">
        <% if notice %>
          <div class="flash-notice mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 px-4 py-3 text-center shadow">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="flash-alert mb-4 rounded-lg bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-center shadow">
            <%= alert %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Main Content -->
    <% if controller_name == 'home' && action_name == 'index' %>
      <main class="min-h-[80vh] w-full">
        <%= yield %>
      </main>
    <% elsif controller_name == 'societies' && action_name == 'index' %>
      <main class="min-h-[80vh] w-full">
        <%= yield %>
      </main>
    <% elsif controller_name == 'presentations' %>
      <main class="min-h-[80vh] w-full <%= 'pt-20' unless notice || alert %>">
        <%= yield %>
      </main>
    <% else %>
      <main class="max-w-6xl mx-auto px-4 min-h-[80vh] <%= 'pt-20' unless notice || alert %>">
        <%= yield %>
      </main>
    <% end %>

    <!-- Footer -->
    <footer class="relative w-full bg-char text-cream py-16 px-4 mt-0 border-t border-oak-edge" style="margin-bottom:0;">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
          <div class="lg:col-span-2">
            <div class="flex items-center gap-3 mb-5">
              <%= image_tag "wss-logo.jpg", alt: "Whiskey Share Society", class: "h-12 w-auto rounded-lg" %>
              <span class="font-display text-2xl font-semibold">Whiskey Share Society</span>
            </div>
            <p class="eyebrow text-whiskey-300/80 mb-3">Discover &middot; Share &middot; Savor</p>
            <p class="text-cream/60 max-w-md leading-relaxed">
              Narrative tasting decks and the societies that gather around them.
              Born from a monthly ritual among friends, est. 2019.
            </p>
          </div>
          <div>
            <h3 class="eyebrow text-cream/50 mb-5">Explore</h3>
            <ul class="space-y-3">
              <li><%= link_to 'Societies', societies_path, class: 'text-cream/80 hover:text-cream transition-colors' %></li>
              <li><%= link_to 'Decks', presentations_path, class: 'text-cream/80 hover:text-cream transition-colors' %></li>
              <li><%= link_to 'Membership', root_path(anchor: 'pricing'), class: 'text-cream/80 hover:text-cream transition-colors' %></li>
            </ul>
          </div>
          <div>
            <h3 class="eyebrow text-cream/50 mb-5">Account</h3>
            <ul class="space-y-3">
              <% if user_signed_in? %>
                <li><%= link_to 'My account', account_path, class: 'text-cream/80 hover:text-cream transition-colors' %></li>
              <% else %>
                <li><%= link_to 'Sign in', auth_path, class: 'text-cream/80 hover:text-cream transition-colors' %></li>
                <li><%= link_to 'Join the Society', auth_path, class: 'text-cream/80 hover:text-cream transition-colors' %></li>
              <% end %>
            </ul>
          </div>
        </div>
        <div class="rule-double text-cream/60 mb-6"></div>
        <div class="flex flex-col md:flex-row justify-between items-center gap-3">
          <p class="text-cream/40 text-sm">
            © <%= Date.current.year %> Whiskey Share Society. All rights reserved.
          </p>
          <p class="eyebrow text-cream/30">Est. 2019</p>
        </div>
      </div>
    </footer>
  </body>
</html>
