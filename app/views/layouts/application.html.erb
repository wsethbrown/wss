<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Whiskey Share Society" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      html, body {
        height: 100%;
        margin: 0;
        padding: 0;
      }
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      main {
        flex: 1 0 auto;
      }
      footer {
        flex-shrink: 0;
      }
    </style>
  </head>

  <body class="bg-white text-black min-h-screen font-sans">
    <!-- Top Navigation Bar -->
    <nav class="fixed top-0 left-0 w-full z-50 bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-3">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 font-bold text-2xl tracking-tight text-black hover:text-indigo-600 transition">
          <%= image_tag "wss-logo.jpg", alt: "Whiskey Share Society", class: "h-10 w-auto rounded-lg" %>
          <span class="hidden sm:inline">Whiskey Share Society</span>
        </a>
        <!-- Navigation Links -->
        <div class="hidden md:flex gap-6 text-lg font-medium items-center">
          <%= nav_link_to 'Societies', societies_path %>
          <%= nav_link_to 'Presentations', presentations_path %>
          <% if user_signed_in? %>
            <% if current_user.subscription_active? && current_user.credits > 0 %>
              <div class="flex items-center gap-2 px-3 py-1 bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-full">
                <svg class="w-4 h-4 text-amber-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                </svg>
                <span class="text-sm font-semibold text-amber-700"><%= current_user.credits %> Credit<%= 's' if current_user.credits != 1 %></span>
              </div>
            <% end %>
            <%= nav_link_to 'Account', account_path %>
            <%= link_to 'Sign Out', destroy_user_session_path, data: { 'turbo-method': :delete, 'turbo-confirm': 'Are you sure you want to sign out?' }, class: 'ml-4 text-gray-400 hover:text-red-500 transition' %>
          <% else %>
            <%= nav_link_to 'Sign In', auth_path %>
          <% end %>
        </div>
        <!-- Mobile Menu (optional, can add later) -->
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice || alert %>
      <div class="max-w-2xl mx-auto pt-20 px-4">
        <% if notice %>
          <div class="mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 px-4 py-3 text-center shadow">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-center shadow">
            <%= alert %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Main Content -->
    <% if controller_name == 'home' && action_name == 'index' %>
      <main class="min-h-[80vh] w-full">
        <%= yield %>
      </main>
    <% elsif controller_name == 'societies' && action_name == 'index' %>
      <main class="min-h-[80vh] w-full">
        <%= yield %>
      </main>
    <% elsif controller_name == 'presentations' %>
      <main class="min-h-[80vh] w-full <%= 'pt-20' unless notice || alert %>">
        <%= yield %>
      </main>
    <% else %>
      <main class="max-w-6xl mx-auto px-4 min-h-[80vh] <%= 'pt-20' unless notice || alert %>">
        <%= yield %>
      </main>
    <% end %>

    <!-- Modern Footer (moved from home/index.html.erb) -->
    <footer class="relative w-full bg-gray-900 text-white py-16 px-4 overflow-hidden mt-0" style="margin-bottom:0;">
      <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"0.1\"%3E%3Ccircle cx=\"30\" cy=\"30\" r=\"2\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      </div>
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
          <div class="lg:col-span-2">
            <div class="flex items-center gap-3 mb-6">
              <%= image_tag "wss-logo.jpg", alt: "Whiskey Share Society", class: "h-12 w-auto rounded-lg shadow-sm" %>
              <span class="text-2xl font-bold">Whiskey Share Society</span>
            </div>
            <p class="text-gray-300 text-lg mb-6 max-w-md">
              Discover, share, and savor whiskey together. Join exclusive clubs, RSVP to tastings, and connect with passionate whiskey enthusiasts worldwide.
            </p>
            <div class="flex gap-4">
              <a href="#" class="w-10 h-10 rounded-full bg-gray-800 hover:bg-indigo-600 flex items-center justify-center transition-colors duration-200">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
              </a>
              <a href="#" class="w-10 h-10 rounded-full bg-gray-800 hover:bg-indigo-600 flex items-center justify-center transition-colors duration-200">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
              </a>
              <a href="#" class="w-10 h-10 rounded-full bg-gray-800 hover:bg-indigo-600 flex items-center justify-center transition-colors duration-200">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001 12.017.001z"/></svg>
              </a>
            </div>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-6">Quick Links</h3>
            <ul class="space-y-3">
              <li><%= link_to 'Societies', societies_path, class: 'text-gray-300 hover:text-white transition-colors' %></li>
              <li><%= link_to 'Presentations', presentations_path, class: 'text-gray-300 hover:text-white transition-colors' %></li>
              <li><%= link_to 'About Us', '#', class: 'text-gray-300 hover:text-white transition-colors' %></li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-6">Support</h3>
            <ul class="space-y-3">
              <li><%= link_to 'Help Center', '#', class: 'text-gray-300 hover:text-white transition-colors' %></li>
              <li><%= link_to 'Contact Us', '#', class: 'text-gray-300 hover:text-white transition-colors' %></li>
              <li><%= link_to 'Privacy Policy', '#', class: 'text-gray-300 hover:text-white transition-colors' %></li>
              <li><%= link_to 'Terms of Service', '#', class: 'text-gray-300 hover:text-white transition-colors' %></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center">
          <p class="text-gray-400 text-sm">
            © 2025 Whiskey Share Society. All rights reserved.
          </p>
          <div class="flex gap-6 mt-4 md:mt-0">
            <a href="#" class="text-gray-400 hover:text-white text-sm transition-colors">Privacy</a>
            <a href="#" class="text-gray-400 hover:text-white text-sm transition-colors">Terms</a>
            <a href="#" class="text-gray-400 hover:text-white text-sm transition-colors">Cookies</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
