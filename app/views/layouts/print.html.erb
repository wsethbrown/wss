<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Whiskey Share Society" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..700&family=Instrument+Sans:ital,wght@0,400..700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <style>
      /* Screen: a soft desk so the white sheet reads as paper. Print: pure
         white, tight margins, and the on-screen toolbar removed entirely. */
      @media screen {
        body { background: #f4f1ec; }
        .sheet { box-shadow: 0 10px 40px rgba(0,0,0,.12); }
      }
      @page { size: letter portrait; margin: 0.5in; }
      @media print {
        .no-print { display: none !important; }
        /* Let @page margins own the paper edges; drop the on-screen frame. */
        .sheet { box-shadow: none !important; margin: 0 !important; max-width: none !important;
                 padding-left: 0 !important; padding-right: 0 !important; }
        .page-break { break-before: page; }
      }
      /* Fillable 1–5 dots: crisp outlines that cost no ink to print. */
      .pip { width: .62rem; height: .62rem; border: 1.25px solid #7a5c34; border-radius: 9999px; display: inline-block; }
    </style>
  </head>
  <body class="text-gray-900">
    <%= yield %>
  </body>
</html>
