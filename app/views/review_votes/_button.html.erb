<%# Quiet inline like: outline thumb + count. Turbo-framed so clicking swaps
    the button in place, never navigates. Amber-filled when you've liked it;
    plain muted count for guests and the review's own author. %>
<%= turbo_frame_tag dom_id(review, :vote) do %>
  <% thumb = "M7 11v9m0-9l3.4-6.8A1.8 1.8 0 0 1 12 3.4c1 .3 1.5 1.2 1.3 2.2L12.6 9H18a2 2 0 0 1 2 2c0 .3 0 .5-.1.8l-1.8 6a2 2 0 0 1-1.9 1.4H9.5c-.5 0-1-.1-1.4-.3L7 18.4M7 11H4v9h3" %>
  <% if user_signed_in? && review.user_id != current_user.id %>
    <% existing = current_user.review_votes.find_by(review: review) %>
    <%= button_to existing ? review_vote_path(existing) : review_votes_path(review_id: review.id),
        method: existing ? :delete : :post, form_class: "inline-block",
        class: "group inline-flex cursor-pointer items-center gap-1.5 text-sm font-semibold transition #{existing ? 'text-whiskey-600 hover:text-whiskey-700' : 'text-gray-400 hover:text-whiskey-600'}",
        "aria-label": existing ? "Remove your like" : "Like this tasting" do %>
      <svg class="h-4 w-4" fill="<%= existing ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="<%= thumb %>"></path>
      </svg>
      <%= review.votes_count %>
    <% end %>
  <% elsif review.votes_count.positive? %>
    <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gray-400">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="<%= thumb %>"></path>
      </svg>
      <%= review.votes_count %>
    </span>
  <% end %>
<% end %>
