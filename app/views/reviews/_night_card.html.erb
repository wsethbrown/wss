<%# One tasting night: the society as the author, the event as the story,
    the pours with the room's scores as the substance. Society and event
    are separate links (the card is a div, not one big anchor).
    locals: event, pours (hash of bottle => that night's reviews) %>
<article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <p class="eyebrow mb-1 text-whiskey-600">
    <%= link_to event.society.name, society_path(event.society), class: "hover:text-whiskey-700" %>
    <%= render "shared/century_badge", record: event.society %>
  </p>
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <%= link_to event.title, society_event_path(event.society, event), class: "font-display text-lg font-semibold text-gray-900 hover:text-whiskey-700" %>
    <span class="text-sm text-gray-500"><%= event.start_time.strftime("%B %-d, %Y") %></span>
  </div>

  <div class="mt-4 space-y-2 border-t border-gray-100 pt-4">
    <% pours.sort_by { |_bottle, reviews| -reviews.sum(&:rating) / reviews.size } .each do |bottle, reviews| %>
      <% mean = (reviews.sum(&:rating) / reviews.size).to_f.round(2) %>
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <%= link_to bottle.display_name, bottle_path(bottle), class: "min-w-0 truncate font-medium text-gray-900 hover:text-whiskey-700" %>
        <span class="flex shrink-0 items-center gap-2 text-sm text-gray-500">
          <span class="font-semibold text-gray-900"><%= number_with_precision(mean, precision: 2, strip_insignificant_zeros: true) %></span>
          <%= render "bottles/rating", value: mean %>
          <%= pluralize(reviews.map(&:user_id).uniq.size, "taster") %>
        </span>
      </div>
    <% end %>
  </div>

  <%= link_to "See the night →", society_event_path(event.society, event), class: "mt-4 inline-block text-sm font-semibold text-whiskey-700 hover:text-whiskey-600" %>
</article>
