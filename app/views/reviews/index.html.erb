<% content_for :title, "Reviews - Whiskey Share Society" %>

<section class="w-full bg-char px-4 pb-12 pt-28 text-center">
  <p class="eyebrow mb-4 text-whiskey-300/90">The pours, on the record</p>
  <h1 class="font-display text-4xl font-semibold text-cream sm:text-5xl">The tasting record</h1>
  <p class="mx-auto mt-4 max-w-2xl text-cream/80">
    Every bottle we've tasted and rated, and the societies doing the tasting —
    search either, and say what you found in the glass.
  </p>
</section>

<section class="w-full bg-white px-4 py-14">
  <div class="mx-auto max-w-6xl <%= 'grid gap-8 lg:grid-cols-3' if user_signed_in? %>">
    <div class="<%= 'lg:col-span-2' if user_signed_in? %>">
    <div class="mb-10 flex flex-wrap items-center justify-between gap-4"
         data-controller="bottle-search" data-bottle-search-url-value="<%= search_reviews_path %>" data-bottle-search-grouped-value="true">
      <%= form_with url: reviews_path, method: :get, class: "flex flex-1 items-start gap-3" do %>
        <div class="relative w-full max-w-xl">
        <input type="search" name="q" value="<%= params[:q] %>" placeholder="Search bottles, distilleries, or societies…"
               autocomplete="off"
               data-bottle-search-target="input" data-action="input->bottle-search#query"
               class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-whiskey-500">
        <div data-bottle-search-target="results"
             class="absolute inset-x-0 top-full z-20 mt-1 hidden overflow-hidden rounded-xl border border-gray-200 bg-white shadow-lg"></div>
        </div>
        <%= select_tag :sort,
            options_for_select([["Top rated", "top"], ["Most reviewed", "reviewed"], ["A–Z", "az"], ["Recently added", "newest"]], @sort),
            onchange: "this.form.requestSubmit()", "aria-label": "Sort bottles",
            class: "rounded-xl border border-gray-300 bg-white px-3 py-3 text-sm font-medium text-gray-700 focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
      <% end %>
      <%= link_to "Add a review", start_reviews_path, class: "whitespace-nowrap rounded-xl bg-whiskey-600 px-5 py-3 font-semibold text-white transition hover:bg-whiskey-700" %>
    </div>

    <div class="mb-8 flex flex-wrap items-center gap-2 text-gray-600">
      <span><%= pluralize(@bottles.count(:all), "bottle") %><%= " matching \"#{params[:q]}\"" if params[:q].present? %></span>
      <% @tags.each do |tag| %>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-whiskey-600 py-1 pl-3 pr-1.5 text-sm font-medium text-white">
          tasting of <%= tag %>
          <%= link_to reviews_path(request.query_parameters.merge("tags" => (@tags - [tag]).join(",")).compact_blank),
              class: "rounded-full p-0.5 transition hover:bg-whiskey-500", "aria-label": "Remove #{tag}" do %>
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
          <% end %>
        </span>
      <% end %>
      <% if @distillery %>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-whiskey-600 py-1 pl-3 pr-1.5 text-sm font-medium text-white">
          from <%= @distillery %>
          <%= link_to reviews_path(request.query_parameters.except("distillery")),
              class: "rounded-full p-0.5 transition hover:bg-whiskey-500", "aria-label": "Remove distillery filter" do %>
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
          <% end %>
        </span>
      <% end %>
      <% if @tags.any? %>
        <%= link_to "Clear tags", reviews_path(request.query_parameters.except("tags")), class: "text-sm font-semibold text-whiskey-700 hover:text-whiskey-600" %>
      <% end %>
    </div>

    <div class="divide-y divide-gray-100 rounded-2xl border border-gray-200 bg-white shadow-sm">
      <% @bottles.each do |bottle| %>
        <%= link_to bottle_path(bottle), class: "flex items-center justify-between gap-4 px-5 py-4 transition hover:bg-whiskey-50" do %>
          <div class="min-w-0">
            <h2 class="truncate font-display text-lg font-semibold text-gray-900"><%= bottle.name %></h2>
            <p class="mt-1 truncate text-sm">
              <% meta = [] %>
              <% if [bottle.style, bottle.region].compact_blank.any? %>
                <% meta << content_tag(:span, [bottle.style, bottle.region].compact_blank.join(" · "), class: "text-whiskey-700 font-medium") %>
              <% end %>
              <% meta << content_tag(:span, bottle.distillery, class: "text-gray-500") if bottle.distillery.present? %>
              <%= safe_join(meta, " · ") %>
            </p>
          </div>
          <div class="shrink-0 whitespace-nowrap text-right">
            <% if bottle.average_rating %>
              <div>
                <span class="font-semibold text-gray-900"><%= number_with_precision(bottle.avg_rating, precision: 2, strip_insignificant_zeros: true) %></span>
                <%= render "bottles/rating", value: bottle.avg_rating&.to_f %>
              </div>
              <p class="text-sm text-gray-400"><%= pluralize(bottle.reviewers, "reviewer") %></p>
            <% else %>
              <%= render "bottles/rating", value: nil %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <% if @societies.any? %>
      <div class="mt-12">
        <p class="eyebrow text-whiskey-600">The company</p>
        <h2 class="mb-6 mt-1 font-display text-2xl font-semibold text-gray-900">Societies</h2>
        <div class="divide-y divide-gray-100 rounded-2xl border border-gray-200 bg-white shadow-sm">
          <% @societies.each do |society| %>
            <%= link_to society_path(society), class: "flex items-center justify-between px-5 py-4 transition hover:bg-whiskey-50" do %>
              <span>
                <span class="block font-display text-lg font-semibold text-gray-900"><%= society.name %></span>
                <span class="block text-sm text-gray-500">
                  <%= [society.location.presence, pluralize(society.members.count, "member")].compact.join(" · ") %>
                </span>
              </span>
              <% if society.is_private? %>
                <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gray-500">Private</span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="mt-16">
      <div class="mb-4 flex items-center gap-2">
        <% { "Latest" => nil, "Circle" => "circle", "Hot" => "hot" }.each do |label, key| %>
          <% next if key == "circle" && !user_signed_in? %>
          <%= link_to label, reviews_path(request.query_parameters.merge(feed: key).compact_blank),
              class: "rounded-full px-4 py-1.5 text-sm font-semibold transition #{@feed == key ? 'bg-whiskey-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
        <% end %>
      </div>

      <% if @feed == "hot" %>
        <p class="eyebrow text-whiskey-600">Getting thumbs</p>
        <h2 class="mb-6 mt-1 font-display text-2xl font-semibold text-gray-900">Hot tastings</h2>
        <div class="grid gap-4 sm:grid-cols-2"><%= render partial: "reviews/review_card", collection: @hot_reviews, as: :review %></div>
      <% elsif @recent_reviews.any? && (params[:q].blank? || @tags.any? || @distillery) %>
        <p class="eyebrow text-whiskey-600">Fresh pours</p>
        <h2 class="mb-6 mt-1 font-display text-2xl font-semibold text-gray-900"><%= if @tags.any? then "Tastings of #{@tags.join(" + ")}" elsif @distillery then "Tastings from #{@distillery}" else "Latest tastings" end %></h2>
        <div class="grid gap-4 sm:grid-cols-2"><%= render partial: "reviews/review_card", collection: @recent_reviews, as: :review %></div>
      <% end %>
    </div>
    </div>
    <% if user_signed_in? %>
      <div class="mt-10 lg:mt-0">
        <% if @feed == "circle" %>
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
            <p class="eyebrow text-whiskey-600">From your circle</p>
            <h2 class="mb-4 mt-1 font-display text-lg font-semibold text-gray-900">Your full circle feed</h2>
            <% if @circle_feed_reviews.any? %>
              <div class="space-y-4"><%= render partial: "reviews/circle_row", collection: @circle_feed_reviews, as: :review %></div>
            <% else %>
              <p class="text-sm text-gray-500">Favorite a society or a fellow taster to see their pours here.</p>
            <% end %>
            <%= link_to "← Back to all tastings", reviews_path, class: "mt-4 block text-sm font-semibold text-whiskey-700 hover:text-whiskey-600" %>
          </div>
        <% else %>
          <%= render "reviews/circle_sidebar", circle_reviews: @circle_reviews %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
