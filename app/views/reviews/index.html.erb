<% content_for :title, "Reviews - Whiskey Share Society" %>

<section class="w-full bg-char px-4 py-16 text-center">
  <p class="eyebrow mb-4 text-whiskey-300/90">The pours, on the record</p>
  <h1 class="font-display text-4xl font-semibold text-cream sm:text-5xl">The tasting record</h1>
  <p class="mx-auto mt-4 max-w-2xl text-cream/80">
    Every bottle we've tasted and rated, and the societies doing the tasting —
    search either, and say what you found in the glass.
  </p>
</section>

<section class="w-full bg-white px-4 py-14">
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-wrap items-center justify-between gap-4"
         data-controller="bottle-search" data-bottle-search-url-value="<%= search_reviews_path %>" data-bottle-search-grouped-value="true">
      <%= form_with url: reviews_path, method: :get, class: "relative w-full max-w-xl" do %>
        <input type="search" name="q" value="<%= params[:q] %>" placeholder="Search bottles, distilleries, or societies…"
               autocomplete="off"
               data-bottle-search-target="input" data-action="input->bottle-search#query"
               class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-whiskey-500">
        <div data-bottle-search-target="results"
             class="absolute inset-x-0 top-full z-20 mt-1 hidden overflow-hidden rounded-xl border border-gray-200 bg-white shadow-lg"></div>
        <%= select_tag :sort,
            options_for_select([["Top rated", "top"], ["Most reviewed", "reviewed"], ["A–Z", "az"], ["Recently added", "newest"]], @sort),
            onchange: "this.form.requestSubmit()", "aria-label": "Sort bottles",
            class: "mt-3 rounded-xl border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 focus:outline-none focus:ring-2 focus:ring-whiskey-500" %>
      <% end %>
      <%= link_to "Add a review", start_reviews_path, class: "rounded-xl bg-whiskey-600 px-5 py-3 font-semibold text-white transition hover:bg-whiskey-700" %>
    </div>

    <p class="mb-8 text-gray-600">
      <%= pluralize(@bottles.count(:all), "bottle") %><%= " matching \"#{params[:q]}\"" if params[:q].present? %>
    </p>

    <div class="divide-y divide-gray-100 rounded-2xl border border-gray-200 bg-white shadow-sm">
      <% @bottles.each do |bottle| %>
        <%= link_to bottle_path(bottle), class: "flex items-center justify-between gap-4 px-5 py-4 transition hover:bg-whiskey-50" do %>
          <div class="min-w-0">
            <h2 class="truncate font-display text-lg font-semibold text-gray-900"><%= bottle.name %></h2>
            <p class="mt-1 truncate text-sm">
              <% meta = [] %>
              <% if [bottle.style, bottle.region].compact_blank.any? %>
                <% meta << content_tag(:span, [bottle.style, bottle.region].compact_blank.join(" · "), class: "text-whiskey-700 font-medium") %>
              <% end %>
              <% meta << content_tag(:span, bottle.distillery, class: "text-gray-500") if bottle.distillery.present? %>
              <%= safe_join(meta, " · ") %>
            </p>
          </div>
          <div class="shrink-0 whitespace-nowrap text-right">
            <% if bottle.average_rating %>
              <div>
                <span class="font-semibold text-gray-900"><%= number_with_precision(bottle.avg_rating, precision: 2, strip_insignificant_zeros: true) %></span>
                <%= render "bottles/rating", value: bottle.avg_rating&.to_f %>
              </div>
              <p class="text-sm text-gray-400"><%= pluralize(bottle.reviewers, "reviewer") %></p>
            <% else %>
              <%= render "bottles/rating", value: nil %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <% if @societies.any? %>
      <div class="mt-12">
        <p class="eyebrow text-whiskey-600">The company</p>
        <h2 class="mb-6 mt-1 font-display text-2xl font-semibold text-gray-900">Societies</h2>
        <div class="divide-y divide-gray-100 rounded-2xl border border-gray-200 bg-white shadow-sm">
          <% @societies.each do |society| %>
            <%= link_to society_path(society), class: "flex items-center justify-between px-5 py-4 transition hover:bg-whiskey-50" do %>
              <span>
                <span class="block font-display text-lg font-semibold text-gray-900"><%= society.name %></span>
                <span class="block text-sm text-gray-500">
                  <%= [society.location.presence, pluralize(society.members.count, "member")].compact.join(" · ") %>
                </span>
              </span>
              <% if society.is_private? %>
                <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gray-500">Private</span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @recent_reviews.any? && params[:q].blank? %>
      <div class="mt-16">
        <p class="eyebrow text-whiskey-600">Fresh pours</p>
        <h2 class="mb-6 mt-1 font-display text-2xl font-semibold text-gray-900">Latest tastings</h2>
        <div class="space-y-4">
          <% @recent_reviews.each do |review| %>
            <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <%= link_to review.bottle.display_name, bottle_path(review.bottle), class: "font-display text-lg font-semibold text-gray-900 hover:text-whiskey-700" %>
                <%= render "bottles/rating", value: review.rating.to_f %>
              </div>
              <% if review.notes.present? %><p class="mt-2 text-gray-600"><%= truncate(review.notes, length: 200) %></p><% end %>
              <p class="mt-2 text-sm text-gray-400"><%= review.user.first_name %> · <%= time_ago_in_words(review.created_at) %> ago</p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
