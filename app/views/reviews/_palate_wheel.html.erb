<%# locals: review — nine flavor families around a wheel; segments lit by how
    hard this tasting hits each family; every lit segment clicks through to
    the tag view. Renders nothing when the tasting text has no descriptors. %>
<% profile = review.flavor_profile %>
<% if profile.any? %>
  <% families = Review::DESCRIPTOR_LEXICON.keys %>
  <% max = profile.values.max.to_f %>
  <% step = 360.0 / families.size %>
  <figure class="mx-auto max-w-xs">
    <svg viewBox="-110 -110 220 220" role="img" aria-label="Palate wheel for this tasting">
      <% families.each_with_index do |family, i| %>
        <% a0 = (-90 + i * step) * Math::PI / 180 %>
        <% a1 = (-90 + (i + 1) * step) * Math::PI / 180 %>
        <% hits = profile[family].to_i %>
        <% r = 96 %>
        <% path = "M0,0 L#{(r * Math.cos(a0)).round(2)},#{(r * Math.sin(a0)).round(2)} " \
                  "A#{r},#{r} 0 0 1 #{(r * Math.cos(a1)).round(2)},#{(r * Math.sin(a1)).round(2)} Z" %>
        <% mid = (a0 + a1) / 2 %>
        <% lx, ly = (66 * Math.cos(mid)).round(1), (66 * Math.sin(mid)).round(1) %>
        <% if hits.positive? %>
          <a href="<%= reviews_path(tags: family) %>">
            <path d="<%= path %>" fill="#a05c28" fill-opacity="<%= (0.25 + 0.6 * (hits / max)).round(2) %>"
                  stroke="#fff" stroke-width="1.5">
              <title><%= family %> — <%= pluralize(hits, "note") %>. See tastings like this.</title>
            </path>
            <text x="<%= lx %>" y="<%= ly %>" text-anchor="middle" dominant-baseline="middle"
                  font-size="9" font-weight="600" fill="#4b2e12"><%= family %></text>
          </a>
        <% else %>
          <path d="<%= path %>" fill="#f2e8dc" stroke="#fff" stroke-width="1.5"></path>
          <text x="<%= lx %>" y="<%= ly %>" text-anchor="middle" dominant-baseline="middle"
                font-size="9" fill="#c9b8a4"><%= family %></text>
        <% end %>
      <% end %>
      <circle r="26" fill="#fff"></circle>
      <text text-anchor="middle" dominant-baseline="middle" font-size="8" letter-spacing="1.5"
            fill="#a05c28" font-weight="600">PALATE</text>
    </svg>
    <figcaption class="mt-1 text-center text-xs text-gray-400">The wheel reads this tasting's own words — click a family to find whiskeys like it.</figcaption>
  </figure>
<% end %>
