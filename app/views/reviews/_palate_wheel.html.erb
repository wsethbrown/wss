<%# The palate wheel, drawn with the SAME geometry the input uses: spoke
    length = intensity. Lit segments click through to the family's tag view.
    Renders nothing without descriptors or dial values.
    locals: review (one tasting) OR profile (a pre-blended family=>0..1
    hash, e.g. Review.blended_wheel for a society verdict). %>
<% profile = local_assigns[:profile] || review.wheel_display_profile %>
<% if profile.any? %>
  <% families = Review::DESCRIPTOR_LEXICON.keys %>
  <% step = 360.0 / families.size %>
  <% hub, rmax = 22, 96 %>
  <figure class="mx-auto max-w-xs">
    <svg viewBox="-110 -110 220 220" role="img" aria-label="Palate wheel for this tasting">
      <% families.each_with_index do |family, i| %>
        <% a0 = (-90 + i * step) * Math::PI / 180 %>
        <% a1 = (-90 + (i + 1) * step) * Math::PI / 180 %>
        <% v = profile[family].to_f.clamp(0, 1) %>
        <% mid = (a0 + a1) / 2 %>
        <% lx, ly = (66 * Math.cos(mid)).round(1), (66 * Math.sin(mid)).round(1) %>
        <%# faint full segment as the track %>
        <path d="M0,0 L<%= (rmax * Math.cos(a0)).round(2) %>,<%= (rmax * Math.sin(a0)).round(2) %> A<%= rmax %>,<%= rmax %> 0 0 1 <%= (rmax * Math.cos(a1)).round(2) %>,<%= (rmax * Math.sin(a1)).round(2) %> Z"
              fill="#f2e8dc" stroke="#fff" stroke-width="1.5"></path>
        <% if v.positive? %>
          <% r = (hub + (rmax - hub) * v).round(2) %>
          <% sector = "M#{(hub * Math.cos(a0)).round(2)},#{(hub * Math.sin(a0)).round(2)} " \
                      "L#{(r * Math.cos(a0)).round(2)},#{(r * Math.sin(a0)).round(2)} " \
                      "A#{r},#{r} 0 0 1 #{(r * Math.cos(a1)).round(2)},#{(r * Math.sin(a1)).round(2)} " \
                      "L#{(hub * Math.cos(a1)).round(2)},#{(hub * Math.sin(a1)).round(2)} " \
                      "A#{hub},#{hub} 0 0 0 #{(hub * Math.cos(a0)).round(2)},#{(hub * Math.sin(a0)).round(2)} Z" %>
          <a href="<%= reviews_path(tags: family) %>">
            <path d="<%= sector %>" fill="#a05c28" fill-opacity="0.85" stroke="#fff" stroke-width="1">
              <title><%= family %>. See tastings like this.</title>
            </path>
            <text x="<%= lx %>" y="<%= ly %>" text-anchor="middle" dominant-baseline="middle"
                  font-size="9" font-weight="700" fill="#4b2e12"><%= family %></text>
          </a>
        <% else %>
          <text x="<%= lx %>" y="<%= ly %>" text-anchor="middle" dominant-baseline="middle"
                font-size="9" fill="#c9b8a4"><%= family %></text>
        <% end %>
      <% end %>
      <circle r="<%= hub %>" fill="#fff"></circle>
      <text text-anchor="middle" dominant-baseline="middle" font-size="8" letter-spacing="1.5"
            fill="#a05c28" font-weight="600">PALATE</text>
    </svg>
    <figcaption class="mt-1 text-center text-xs text-gray-400">Spoke length is strength, click a family to find whiskeys like it.</figcaption>
  </figure>
<% end %>
