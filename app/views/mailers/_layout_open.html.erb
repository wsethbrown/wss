<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #33271c; max-width: 560px; margin: 0 auto; padding: 24px 16px; background: #f6efe3; }
    .card { background: #fffdf8; border: 1px solid #e8cca7; border-radius: 14px; overflow: hidden; }
    .header { background: #191009; padding: 26px 24px 20px; text-align: center; }
    .header h1 { margin: 10px 0 0; font-size: 13px; font-weight: 600; color: #f6edda; letter-spacing: 3px; text-transform: uppercase; }
    .body { padding: 30px 28px; }
    .eyebrow { color: #a15825; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin: 0 0 10px; }
    .title { font-family: Georgia, 'Times New Roman', serif; font-size: 27px; font-weight: 700; line-height: 1.25; color: #191009; margin: 0 0 20px; }
    .details { border-top: 1px solid #e8cca7; border-bottom: 1px solid #e8cca7; padding: 14px 2px; margin: 0 0 18px; }
    .details p { margin: 3px 0; color: #6a5a48; font-size: 15px; }
    .details strong { color: #33271c; }
    .meta { color: #6a5a48; font-size: 14px; margin: 4px 0; }
    .note { background: #fbf6ef; border-left: 3px solid #c9884a; padding: 10px 14px; margin: 16px 0; color: #33271c; }
    .btn { display: inline-block; background: #a15825; color: #ffffff !important; text-decoration: none; padding: 12px 24px; border-radius: 10px; font-weight: 600; margin-top: 16px; white-space: nowrap; }
    .rsvp { margin-top: 6px; }
    .rsvp a { padding: 11px 18px; margin: 10px 8px 0 0; }
    .hint { color: #6a5a48; font-size: 13px; margin: 12px 0 0; }
    .see { margin: 22px 0 0; font-size: 14px; }
    .see a { color: #a15825; font-weight: 600; }
    .footer { text-align: center; color: #b4a58e; font-size: 12px; padding: 18px 16px 6px; }
    @media only screen and (max-width: 480px) {
      body { padding: 12px 8px !important; }
      .body { padding: 24px 18px !important; }
      .title { font-size: 24px !important; }
      .btn { display: block !important; margin: 12px 0 0 0 !important; text-align: center !important; }
      .rsvp a { margin: 10px 0 0 0 !important; }
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <img src="https://whiskeysharesociety.com/icon.png" width="48" height="48" alt="" style="border-radius: 10px;">
      <h1>Whiskey Share Society</h1>
    </div>
    <div class="body">
