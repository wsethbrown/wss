<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #33271c; max-width: 600px; margin: 0 auto; padding: 20px; background: #fbf6ef; }
    .card { background: #ffffff; border: 1px solid #e8cca7; border-radius: 12px; overflow: hidden; }
    .header { background: #191009; color: #f6edda; padding: 24px; text-align: center; }
    .header h1 { margin: 0; font-size: 20px; }
    .body { padding: 24px; }
    .meta { color: #6a5a48; font-size: 14px; margin: 4px 0; }
    .note { background: #fbf6ef; border-left: 3px solid #c9884a; padding: 10px 14px; margin: 16px 0; color: #33271c; }
    .btn { display: inline-block; background: #a15825; color: #ffffff !important; text-decoration: none; padding: 12px 24px; border-radius: 10px; font-weight: 600; margin-top: 16px; white-space: nowrap; }
    .rsvp { margin-top: 8px; }
    .rsvp a { padding: 11px 18px; margin: 8px 8px 0 0; }
    .footer { text-align: center; color: #b4a58e; font-size: 12px; padding: 16px; }
    @media only screen and (max-width: 480px) {
      body { padding: 10px !important; }
      .body { padding: 20px 16px !important; }
      .btn { display: block !important; margin: 12px 0 0 0 !important; text-align: center !important; }
      .rsvp a { margin: 10px 0 0 0 !important; }
    }
  </style>
</head>
