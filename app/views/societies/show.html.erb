<% content_for :title, "#{@society.name} - Whiskey Share Society" %>

<div class="min-h-screen bg-gray-50">
  <!-- Full Width Banner Section -->
  <% if @society.banner_image.attached? %>
    <div class="relative h-64 md:h-80 w-full overflow-hidden">
      <!-- Banner Image -->
      <%= image_tag @society.banner_image, 
          class: "absolute inset-0 w-full h-full object-cover", 
          style: "object-position: #{@society.banner_position || 'center center'}; transform: scale(1.1);" %>
      <!-- Strong dark overlay for text readability -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/80 to-black/70"></div>
      <!-- Additional overlay for extra contrast -->
      <div class="absolute inset-0 bg-black/40"></div>
      
      <!-- Banner Content -->
      <div class="relative z-10 h-full flex items-end">
        <div class="w-full px-4 sm:px-6 lg:px-8 py-8">
          <div class="flex items-start justify-between">
            <div class="flex items-start space-x-6">
              <!-- Society Icon -->
              <% if @society.profile_picture.attached? %>
                <div class="w-20 h-20 rounded-xl border-4 border-white/20 backdrop-blur-sm overflow-hidden">
                  <%= render 'shared/society_icon', society: @society, size: 'large' %>
                </div>
              <% else %>
                <div class="w-20 h-20 bg-gradient-to-br from-whiskey-500 to-whiskey-500 rounded-xl flex items-center justify-center border-4 border-white/20 backdrop-blur-sm">
                  <%= render 'shared/society_icon', society: @society, size: 'large' %>
                </div>
              <% end %>
              
              <div class="flex-1">
                <div class="flex items-center space-x-3 mb-2">
                  <h1 class="text-3xl font-bold text-white" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8), 1px 1px 2px rgba(0,0,0,0.9);"><%= @society.name %></h1>
                  <% if @society.private? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-900/80 backdrop-blur-md border border-white/40 text-white shadow-lg">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                      </svg>
                      Private
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500 border border-yellow-400 text-black shadow-lg">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      Public
                    </span>
                  <% end %>
                </div>
                
                <p class="text-white mb-4 leading-relaxed font-medium" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.8);"><%= @society.description %></p>
                
                <div class="flex items-center space-x-6 text-sm text-white font-medium" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                      <span class="text-lg">👥</span>
                    </div>
                    <%= @society.member_count %> members
                  </div>
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                      <span class="text-lg">📅</span>
                    </div>
                    <%= @society.events.count %> events
                  </div>
                  <% if @society.location.present? %>
                    <div class="flex items-center">
                      <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                        <span class="text-lg">📍</span>
                      </div>
                      <%= @society.location %>
                    </div>
                  <% end %>
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                      <span class="text-lg">👤</span>
                    </div>
                    Created by <%= link_to @society.creator.full_name, profile_path(@society.creator), class: "text-white hover:text-yellow-300 font-bold underline", style: "text-shadow: 1px 1px 2px rgba(0,0,0,0.8);" %>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Action Buttons -->
            <div class="flex items-center space-x-3">
              <% if user_signed_in? %>
                <% if @society.has_member?(current_user) %>
                  <% membership = current_user.society_memberships.find_by(society: @society) %>
                  <% if membership&.admin? %>
                    <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium bg-whiskey-600 border border-whiskey-500 text-white shadow-lg">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 713.138-3.138z"></path>
                      </svg>
                      Admin
                    </span>
                    <%= link_to "Edit Society", edit_society_path(@society), 
                        class: "inline-flex items-center px-4 py-2 bg-black/50 backdrop-blur-md border border-white/40 rounded-md shadow-lg text-sm font-medium text-white hover:bg-black/70 hover:shadow-xl transition-all" %>
                  <% elsif membership&.officer? %>
                    <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium bg-blue-900/80 backdrop-blur-md border border-white/40 text-white shadow-lg">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 713.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 713.138-3.138z"></path>
                      </svg>
                      Society Officer
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium bg-yellow-500 border border-yellow-400 text-black shadow-lg">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      Member
                    </span>
                  <% end %>
                <% else %>
                  <% if @society.public? %>
                    <%= button_to "Join Society", join_society_path(@society), 
                        method: :post,
                        class: "inline-flex items-center px-4 py-2 bg-green-600 border-2 border-green-400 rounded-md shadow-xl text-sm font-bold text-white hover:bg-green-700 hover:border-green-300 transition-all",
                        style: "text-shadow: 1px 1px 2px rgba(0,0,0,0.5);" %>
                  <% else %>
                    <%= link_to "Apply to Join", "#", 
                        class: "inline-flex items-center px-4 py-2 bg-yellow-600 border-2 border-yellow-400 rounded-md shadow-xl text-sm font-bold text-white hover:bg-yellow-700 hover:border-yellow-300 transition-all",
                        style: "text-shadow: 1px 1px 2px rgba(0,0,0,0.5);" %>
                  <% end %>
                <% end %>
              <% else %>
                <%= link_to "Sign In to Join", new_user_session_path, 
                    class: "inline-flex items-center px-4 py-2 bg-blue-600 border-2 border-blue-400 rounded-md shadow-xl text-sm font-bold text-white hover:bg-blue-700 hover:border-blue-300 transition-all",
                    style: "text-shadow: 1px 1px 2px rgba(0,0,0,0.5);" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Default Header without Banner -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="bg-white shadow-sm rounded-lg overflow-hidden mb-8">
        <div class="px-6 py-8">
          <div class="flex items-start justify-between">
            <div class="flex items-start space-x-6">
              <!-- Society Icon -->
              <% if @society.profile_picture.attached? %>
                <div class="w-20 h-20 rounded-xl overflow-hidden">
                  <%= render 'shared/society_icon', society: @society, size: 'large' %>
                </div>
              <% else %>
                <div class="w-20 h-20 bg-gradient-to-br from-whiskey-500 to-whiskey-500 rounded-xl flex items-center justify-center">
                  <%= render 'shared/society_icon', society: @society, size: 'large' %>
                </div>
              <% end %>
              
              <div class="flex-1">
                <div class="flex items-center space-x-3 mb-2">
                  <h1 class="text-3xl font-bold text-gray-900"><%= @society.name %></h1>
                  <% if @society.private? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                      </svg>
                      Private
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      Public
                    </span>
                  <% end %>
                </div>
                
                <p class="text-gray-600 mb-4 leading-relaxed"><%= @society.description %></p>
                
                <div class="flex items-center space-x-6 text-sm text-gray-500">
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                      <span class="text-lg">👥</span>
                    </div>
                    <%= @society.member_count %> members
                  </div>
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                      <span class="text-lg">📅</span>
                    </div>
                    <%= @society.events.count %> events
                  </div>
                  <% if @society.location.present? %>
                    <div class="flex items-center">
                      <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                        <span class="text-lg">📍</span>
                      </div>
                      <%= @society.location %>
                    </div>
                  <% end %>
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center mr-2 shadow-lg border-2 border-white">
                      <span class="text-lg">👤</span>
                    </div>
                    Created by <%= link_to @society.creator.full_name, profile_path(@society.creator), class: "text-whiskey-600 hover:text-whiskey-500 font-medium" %>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Action Buttons -->
            <div class="flex items-center space-x-3">
              <% if user_signed_in? %>
                <% if @society.has_member?(current_user) %>
                  <% membership = current_user.society_memberships.find_by(society: @society) %>
                  <% if membership&.admin? %>
                    <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium bg-whiskey-100 text-whiskey-800">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 714.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 713.138-3.138z"></path>
                      </svg>
                      Admin
                    </span>
                    <%= link_to "Edit Society", edit_society_path(@society), 
                        class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
                  <% elsif membership&.officer? %>
                    <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium bg-blue-100 text-blue-800">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 714.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 713.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 713.138-3.138z"></path>
                      </svg>
                      Society Officer
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium bg-green-100 text-green-800">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 714.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 713.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 713.138-3.138z"></path>
                      </svg>
                      Member
                    </span>
                  <% end %>
                <% else %>
                  <% if @society.private? %>
                    <%= button_to "Request to Join", join_society_path(@society), method: :post,
                        class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-whiskey-600 hover:bg-whiskey-700" %>
                  <% else %>
                    <%= button_to "Join Society", join_society_path(@society), method: :post,
                        class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-whiskey-600 hover:bg-whiskey-700" %>
                  <% end %>
                <% end %>
              <% else %>
                <%= link_to "Sign In to Join", auth_path,
                    class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-whiskey-600 hover:bg-whiskey-700" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Main Content Section -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Upcoming Events -->
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-gray-900">Upcoming Events</h2>
            <% if user_signed_in? && @society.has_member?(current_user) %>
              <% membership = current_user.society_memberships.find_by(society: @society) %>
              <% if membership&.admin? || membership&.officer? %>
                <%= link_to "Create New Event", new_society_event_path(@society), 
                    class: "inline-flex items-center px-4 py-2 bg-whiskey-600 border border-transparent rounded-md font-semibold text-xs text-white uppercase tracking-widest hover:bg-whiskey-700 focus:bg-whiskey-700 active:bg-whiskey-900 focus:outline-none focus:ring-2 focus:ring-whiskey-500 focus:ring-offset-2 transition ease-in-out duration-150" %>
              <% end %>
            <% end %>
          </div>
          <div class="p-6">
            <% if @upcoming_events.any? %>
              <div class="space-y-4">
                <% @upcoming_events.each do |event| %>
                  <%= link_to society_event_path(@society, event), class: "block" do %>
                    <div class="flex items-start space-x-4 p-4 border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-whiskey-300 transition-all duration-200 cursor-pointer">
                      <div class="w-12 h-12 bg-whiskey-100 rounded-lg flex items-center justify-center">
                        <svg class="w-6 h-6 text-whiskey-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <h3 class="text-sm font-semibold text-gray-900 group-hover:text-whiskey-600"><%= event.title %></h3>
                        <p class="text-sm text-gray-600 mt-1"><%= truncate(event.description, length: 100) if event.description.present? %></p>
                        <div class="flex items-center mt-2 text-xs text-gray-500">
                          <span><%= event.start_time.strftime("%B %d, %Y at %I:%M %p") %></span>
                          <% if event.location.present? %>
                            <span class="mx-2">•</span>
                            <span><%= event.location %></span>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-shrink-0">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-8">
                <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No upcoming events</h3>
                <p class="text-gray-500">Check back later for new events.</p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Past Events -->
        <% if @past_events.any? %>
          <div class="bg-white shadow-sm rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
              <h2 class="text-lg font-semibold text-gray-900">Past Events</h2>
            </div>
            <div class="p-6">
              <div class="space-y-4">
                <% @past_events.each do |event| %>
                  <%= link_to society_event_path(@society, event), class: "block" do %>
                    <div class="flex items-start space-x-4 p-4 border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition-all duration-200 cursor-pointer opacity-75">
                      <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center">
                        <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <h3 class="text-sm font-semibold text-gray-700"><%= event.title %></h3>
                        <p class="text-sm text-gray-600 mt-1"><%= truncate(event.description, length: 100) if event.description.present? %></p>
                        <div class="flex items-center mt-2 text-xs text-gray-500">
                          <span><%= event.start_time.strftime("%B %d, %Y at %I:%M %p") %></span>
                          <% if event.location.present? %>
                            <span class="mx-2">•</span>
                            <span><%= event.location %></span>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-shrink-0">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Recent Activity or Society Description -->
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">About This Society</h2>
          </div>
          <div class="p-6">
            <% if @society.description.present? %>
              <p class="text-gray-700 leading-relaxed"><%= @society.description %></p>
            <% else %>
              <p class="text-gray-500 italic">No description provided.</p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Members -->
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">Members</h2>
          </div>
          <div class="p-6">
            <% if @recent_members.any? %>
              <div class="space-y-3">
                <% @recent_members.each do |member| %>
                  <%= link_to profile_path(member), class: "flex items-center space-x-3 hover:bg-gray-50 rounded-lg p-2 -m-2 transition-colors" do %>
                    <% if member.has_profile_image? %>
                      <img src="<%= member.profile_image_url %>" alt="<%= member.full_name %>" class="w-8 h-8 rounded-full">
                    <% else %>
                      <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-medium" style="background-color: <%= member.avatar_color %>;">
                        <%= member.initials %>
                      </div>
                    <% end %>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate"><%= member.full_name %></p>
                      <% membership = member.society_memberships.find_by(society: @society) %>
                      <% if membership %>
                        <p class="text-xs text-gray-500 capitalize"><%= membership.role %></p>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              </div>
              <% if @society.member_count > @recent_members.count %>
                <div class="mt-4 pt-4 border-t border-gray-200">
                  <p class="text-sm text-gray-500 text-center">
                    And <%= @society.member_count - @recent_members.count %> more members
                  </p>
                </div>
              <% end %>
            <% else %>
              <p class="text-gray-500 text-sm">No members yet.</p>
            <% end %>
          </div>
        </div>

        <!-- Society Stats -->
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">Society Stats</h2>
          </div>
          <div class="p-6">
            <div class="space-y-4">
              <div class="flex justify-between">
                <span class="text-sm text-gray-600">Total Members</span>
                <span class="text-sm font-semibold text-gray-900"><%= @society.member_count %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600">Total Events</span>
                <span class="text-sm font-semibold text-gray-900"><%= @society.events.count %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600">Admins</span>
                <span class="text-sm font-semibold text-gray-900"><%= @society.admin_count %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600">Officers</span>
                <span class="text-sm font-semibold text-gray-900"><%= @society.officer_count %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600">Created</span>
                <span class="text-sm font-semibold text-gray-900"><%= @society.created_at.strftime("%B %Y") %></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Leave Society Button (for members only) -->
        <% if user_signed_in? && @society.has_member?(current_user) %>
          <% membership = current_user.society_memberships.find_by(society: @society) %>
          <% unless membership&.admin? %>
            <div class="bg-white shadow-sm rounded-lg overflow-hidden">
              <div class="p-6">
                <%= button_to "Leave Society", leave_society_path(@society), 
                    method: :delete, 
                    data: { confirm: "Are you sure you want to leave this society? This action cannot be undone." },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-red-300 rounded-md shadow-sm text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 hover:border-red-400 transition-colors" %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>