<!-- Hero Section -->
<div class="relative min-h-[60vh] flex flex-col items-center justify-center text-center overflow-hidden bg-gradient-to-br from-blue-100 via-blue-200 to-blue-300 w-full">
  <div class="absolute inset-0 pointer-events-none">
    <div class="w-full h-full rounded-[3rem] bg-white/30 blur-3xl opacity-80 mx-auto mt-16"></div>
  </div>
  <div class="relative z-10 px-4 py-24 w-full flex flex-col items-center justify-center">
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-black mb-6 leading-tight">
      <span class="block">Whiskey Societies</span>
      <span class="block text-blue-700">Where Community Meets Craft</span>
    </h1>
    <p class="text-xl md:text-2xl text-gray-700 mb-10 font-medium max-w-3xl">
      Join exclusive clubs, discover rare bottles, and share your passion with fellow connoisseurs.<br>
      From public meetups to private tastings, find your perfect whiskey community.
    </p>
    <% if user_signed_in? %>
      <%= link_to 'Your Societies', '#your-societies', class: 'inline-flex items-center gap-2 px-8 py-4 rounded-full bg-black text-white text-lg font-bold shadow-lg hover:bg-blue-800 transition focus:outline-none focus:ring-2 focus:ring-blue-400' %>
    <% else %>
      <%= link_to 'Join the Community', new_user_registration_path, class: 'inline-flex items-center gap-2 px-8 py-4 rounded-full bg-black text-white text-lg font-bold shadow-lg hover:bg-blue-800 transition focus:outline-none focus:ring-2 focus:ring-blue-400' %>
    <% end %>
  </div>
</div>

<!-- How Societies Work Section -->
<section class="relative w-full bg-white py-24 px-4">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <!-- Sticky Left Column -->
    <div class="md:sticky md:top-32 flex flex-col justify-center h-full">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6">How Societies Work</h2>
      <p class="text-lg text-gray-600 font-medium max-w-md">Three types of whiskey communities, each with their own unique experience.</p>
    </div>
    <!-- Vertically Snap-Scrolling Right Column -->
    <div class="relative h-[60vh] overflow-y-auto snap-y snap-mandatory hide-scrollbar bg-white">
      <!-- Step 1 -->
      <div class="flex flex-col justify-center items-start h-[45vh] min-h-[45vh] w-full snap-center mb-8">
        <div class="flex items-center gap-4">
          <span class="text-3xl md:text-4xl">🌐</span>
          <span class="text-2xl md:text-3xl font-bold text-gray-900">Public Societies</span>
        </div>
        <div class="text-gray-600 text-base md:text-lg font-medium mt-2 ml-12">Join instantly with a single click. Perfect for meeting new people and discovering different whiskey styles together.</div>
      </div>
      <!-- Step 2 -->
      <div class="flex flex-col justify-center items-start h-[45vh] min-h-[45vh] w-full snap-center mb-8">
        <div class="flex items-center gap-4">
          <span class="text-3xl md:text-4xl">🔒</span>
          <span class="text-2xl md:text-3xl font-bold text-gray-900">Private Societies</span>
        </div>
        <div class="text-gray-600 text-base md:text-lg font-medium mt-2 ml-12">Apply to join exclusive clubs. Admins review applications to maintain quality and create curated experiences.</div>
      </div>
      <!-- Step 3 -->
      <div class="flex flex-col justify-center items-start h-[45vh] min-h-[45vh] w-full snap-center">
        <div class="flex items-center gap-4">
          <span class="text-3xl md:text-4xl">👥</span>
          <span class="text-2xl md:text-3xl font-bold text-gray-900">Friends-Only</span>
        </div>
        <div class="text-gray-600 text-base md:text-lg font-medium mt-2 ml-12">Create your own private society for friends and family. Perfect for regular whiskey nights with your inner circle.</div>
      </div>
    </div>
  </div>
</section>

<!-- Example Societies Section -->
<section class="relative w-full py-24 px-4 bg-gradient-to-br from-slate-50 via-white to-blue-50 overflow-hidden">
  <!-- Animated background elements -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 left-10 w-32 h-32 bg-blue-200/30 rounded-full blur-xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 w-24 h-24 bg-indigo-200/40 rounded-full blur-xl animate-pulse delay-1000"></div>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6">Featured Societies</h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Discover some of the most vibrant whiskey communities in our network.</p>
    </div>

    <!-- Societies Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      <% [
        { name: 'Single Malt Enthusiasts', desc: 'A club for lovers of single malt whiskey. Monthly tastings featuring different regions and distilleries.', public: true, members: 42, events: 5, location: 'New York, NY' },
        { name: 'Women Who Whiskey', desc: 'Empowering women in the whiskey world. Private, invite-only events with expert-led tastings.', public: false, members: 18, events: 2, location: 'Los Angeles, CA' },
        { name: 'Urban Whiskey Collective', desc: 'City-based meetups for urban whiskey fans. Casual atmosphere, serious whiskey appreciation.', public: true, members: 31, events: 3, location: 'Chicago, IL' },
        { name: 'Rare Bottles Society', desc: 'For collectors and connoisseurs of rare and limited-edition whiskey. Exclusive access to hard-to-find bottles.', public: false, members: 12, events: 1, location: 'San Francisco, CA' },
        { name: 'Whiskey & Jazz', desc: 'Pairing jazz nights with curated whiskey flights. Music, conversation, and exceptional spirits.', public: true, members: 27, events: 4, location: 'New Orleans, LA' },
        { name: 'Cask Strength Crew', desc: 'For those who like their whiskey bold and unfiltered. High-proof tastings and barrel-strength experiences.', public: true, members: 22, events: 2, location: 'Austin, TX' }
      ].each do |society| %>
        <div class="group relative bg-white/60 backdrop-blur-xl rounded-3xl shadow-xl border border-white/20 p-8 hover:bg-white/80 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 cursor-pointer">
          <!-- Glassmorphism overlay -->
          <div class="absolute inset-0 rounded-3xl pointer-events-none bg-gradient-to-br from-blue-50/50 via-white/30 to-indigo-50/50 opacity-80 group-hover:opacity-100 transition-opacity duration-500"></div>
          <!-- Animated border -->
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-blue-400/20 via-purple-400/20 to-indigo-400/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm"></div>

          <div class="relative z-10 flex flex-col gap-4">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-3xl font-bold"><%= society[:public] ? '🌐' : '🔒' %></span>
              <span class="text-2xl font-extrabold text-gray-900"><%= society[:name] %></span>
              <span class="ml-auto px-3 py-1 rounded-full text-xs font-semibold <%= society[:public] ? 'bg-blue-100 text-blue-700' : 'bg-gray-200 text-gray-700' %>">
                <%= society[:public] ? 'Public' : 'Private' %>
              </span>
            </div>
            <p class="text-gray-700 text-lg mb-2"><%= society[:desc] %></p>
            <div class="flex items-center gap-1 text-gray-500 text-sm mb-4">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <%= society[:location] %>
            </div>
            <div class="flex items-center gap-6 text-gray-500 text-base mb-4">
              <span class="flex items-center gap-1">
                <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a4 4 0 00-3-3.87"></path>
                </svg>
                <%= society[:members] %> Members
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <%= society[:events] %> Events
              </span>
            </div>
            <div class="flex gap-2 mt-auto">
              <% if user_signed_in? %>
                <span class="px-6 py-2 rounded-full font-bold text-white bg-indigo-600 shadow text-lg group-hover:bg-indigo-700 transition">
                  Join Society
                </span>
              <% else %>
                <span class="px-6 py-2 rounded-full font-bold text-gray-600 bg-gray-100 shadow text-lg">
                  Sign up to join
                </span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Society Features Section -->
<section class="relative w-full py-24 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6">Everything You Need</h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Societies provide all the tools you need to build and manage your whiskey community.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Event Management</h3>
        <p class="text-gray-600">Create events, manage RSVPs, and track attendance all in one place.</p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Forums & Discussion</h3>
        <p class="text-gray-600">Engage in lively discussions about whiskey, events, and everything in between.</p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a4 4 0 00-3-3.87"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Member Management</h3>
        <p class="text-gray-600">Control who joins, manage roles, and keep your community organized.</p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-amber-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Analytics & Insights</h3>
        <p class="text-gray-600">Track engagement, event success, and member activity with detailed analytics.</p>
      </div>
    </div>
  </div>
</section>

<% if user_signed_in? %>
  <!-- User's Societies Section -->
  <section id="your-societies" class="relative w-full py-24 px-4 bg-gradient-to-br from-blue-50 via-white to-indigo-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6">Your Societies</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Manage your whiskey communities and discover new ones to join.</p>
      </div>

      <!-- Search & Filter Bar -->
      <div class="w-full max-w-2xl mx-auto mb-12 flex flex-col md:flex-row gap-4 items-center justify-center">
        <input type="text" placeholder="Search societies..." class="w-full md:w-2/3 px-6 py-4 rounded-2xl bg-white/70 shadow-lg border border-gray-200 text-lg focus:outline-none focus:ring-2 focus:ring-blue-400 placeholder-gray-400 transition" />
        <select class="w-full md:w-1/3 px-4 py-4 rounded-2xl bg-white/70 shadow-lg border border-gray-200 text-lg focus:outline-none focus:ring-2 focus:ring-blue-400 transition">
          <option value="">All Types</option>
          <option value="public">Public</option>
          <option value="private">Private</option>
          <option value="friends">Friends-Only</option>
        </select>
      </div>

      <!-- User's Societies Grid -->
      <div class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        <% if @societies.any? %>
          <% @societies.each do |society| %>
            <%= link_to society_path(society), class: "block" do %>
              <div class="relative group rounded-3xl bg-white/60 backdrop-blur-lg shadow-xl border border-gray-200 p-8 flex flex-col transition-transform duration-200 hover:-translate-y-2 hover:shadow-2xl hover:bg-white/80 cursor-pointer">
                <!-- Glassmorphism Gradient Overlay -->
                <div class="absolute inset-0 rounded-3xl pointer-events-none bg-gradient-to-br from-blue-100/40 via-white/20 to-indigo-100/40 opacity-80 group-hover:opacity-100 transition"></div>
                <div class="relative z-10 flex flex-col gap-4">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-3xl font-bold"><%= society.is_private ? '🔒' : '🌐' %></span>
                    <span class="text-2xl font-extrabold text-gray-900"><%= society.name %></span>
                    <span class="ml-auto px-3 py-1 rounded-full text-xs font-semibold <%= society.is_private ? 'bg-gray-200 text-gray-700' : 'bg-blue-100 text-blue-700' %>">
                      <%= society.is_private ? 'Private' : 'Public' %>
                    </span>
                  </div>
                  <p class="text-gray-700 text-lg mb-2"><%= society.description %></p>
                  <div class="flex items-center gap-6 text-gray-500 text-base mb-4">
                    <span class="flex items-center gap-1">
                      <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a4 4 0 00-3-3.87"></path>
                      </svg>
                      <%= society.members.count %> Members
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      <%= society.events.count %> Events
                    </span>
                  </div>
                  <div class="flex gap-2 mt-auto">
                    <span class="px-6 py-2 rounded-full font-bold text-white bg-indigo-600 shadow text-lg">
                      View Details
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <!-- Empty State -->
          <div class="col-span-full text-center py-16">
            <div class="text-6xl mb-6">🥃</div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">No Societies Yet</h3>
            <p class="text-gray-600 mb-8 max-w-md mx-auto">You haven't joined any societies yet. Start exploring whiskey communities or create your own!</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <%= link_to 'Browse Societies', '#', class: 'px-8 py-3 rounded-full bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition' %>
              <%= link_to 'Create Society', new_society_path, class: 'px-8 py-3 rounded-full bg-gray-100 text-gray-900 font-semibold hover:bg-gray-200 transition' %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Call to Action -->
      <div class="text-center">
        <%= link_to 'Create New Society', new_society_path, class: 'inline-flex items-center gap-3 px-10 py-5 rounded-full bg-black text-white text-2xl font-extrabold shadow-lg hover:bg-indigo-700 transition focus:outline-none focus:ring-2 focus:ring-indigo-400' %>
      </div>
    </div>
  </section>
<% else %>
  <!-- Call to Action Section for Unauthorized Users -->
  <section class="relative w-full py-24 px-4 bg-gradient-to-br from-indigo-50 via-white to-blue-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6">Ready to Join?</h2>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">Subscribe to unlock access to all societies, events, and the full whiskey community experience.</p>
      <%= link_to 'Subscribe & Join Societies', new_user_registration_path, class: 'inline-flex items-center gap-3 px-10 py-5 rounded-full bg-indigo-700 text-white text-2xl font-extrabold shadow-lg hover:bg-black transition focus:outline-none focus:ring-2 focus:ring-indigo-400' %>
    </div>
  </section>
<% end %>
