<% if user_signed_in? %>
  <!-- Simplified Header for Authenticated Users -->
  <section class="relative w-full py-16 px-4 bg-gradient-to-br from-slate-900 via-indigo-900 to-purple-900">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-black text-white mb-4">
        Your Whiskey Societies
      </h1>
      <p class="text-xl text-indigo-200 max-w-2xl mx-auto">
        Manage your communities and discover new ones
      </p>
    </div>
  </section>

  <!-- Main Content for Authenticated Users -->
  <section class="relative w-full py-16 px-4 bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
    <div class="max-w-7xl mx-auto">

      <!-- My Societies Section -->
      <% if @user_societies.any? %>
        <div class="mb-16">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl font-bold text-gray-900">My Societies</h2>
            <%= link_to new_society_path, class: 'inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-indigo-600 text-white font-semibold hover:from-purple-600 hover:to-indigo-700 transition-all duration-200 shadow-lg hover:shadow-xl' do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              <span>Create Society</span>
            <% end %>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% @user_societies.each do |society| %>
              <%= link_to society_path(society), class: "block group" do %>
                <div class="bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-all duration-200 hover:-translate-y-1">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-indigo-600 rounded-xl flex items-center justify-center">
                      <%= render 'shared/society_icon', society: society %>
                    </div>
                    <div class="flex-1">
                      <h3 class="text-lg font-bold text-gray-900 group-hover:text-purple-600 transition-colors"><%= society.name %></h3>
                      <span class="px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
                        <%= society.creator == current_user ? 'Creator' : 'Member' %>
                      </span>
                    </div>
                  </div>

                  <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= society.description %></p>

                  <div class="flex items-center gap-4 text-gray-500 text-sm">
                    <span class="flex items-center gap-1">
                      <%= render 'shared/user_group_icon' %>
                      <%= society.members.count %> members
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      <%= society.events.count %> events
                    </span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% else %>
        <!-- Empty State for My Societies -->
        <div class="text-center py-12 mb-16">
          <div class="text-6xl mb-4">🥃</div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Start Your Whiskey Journey</h2>
          <p class="text-gray-600 mb-6 max-w-md mx-auto">
            You haven't joined any societies yet. Create your own or discover existing communities.
          </p>
          <%= link_to new_society_path, class: 'inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-indigo-600 text-white font-semibold hover:from-purple-600 hover:to-indigo-700 transition-all duration-200 shadow-lg hover:shadow-xl' do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            <span>Create Your First Society</span>
          <% end %>
        </div>
      <% end %>

      <!-- Discover Societies Section -->
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-8">Discover Societies</h2>

        <!-- Enhanced Search Bar with Geolocation -->
        <div class="mb-8">
          <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm" data-controller="society-search">
            <%= form_with url: societies_path, method: :get, local: true, class: "space-y-6", data: { society_search_target: "form" } do |form| %>
              
              <!-- Name Search -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Search by Name</label>
                <div class="relative">
                  <%= form.text_field :search, placeholder: "Search society names...", 
                      value: params[:search], 
                      class: "w-full px-4 py-3 pl-12 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all",
                      data: { society_search_target: "searchInput" } %>
                  <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                </div>
              </div>

              <!-- Location Search -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Search by Location</label>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <!-- Zip Code Input -->
                  <div class="relative">
                    <%= form.text_field :zip_code, placeholder: "Enter ZIP code", 
                        value: params[:zip_code], 
                        pattern: "[0-9]{5}(-[0-9]{4})?",
                        maxlength: "10",
                        class: "w-full px-4 py-3 pl-12 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all",
                        data: { society_search_target: "zipInput" } %>
                    <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                  </div>
                  
                  <!-- Range Dropdown -->
                  <div>
                    <%= form.select :range, 
                        options_for_select([
                          ['5 miles', '5'],
                          ['10 miles', '10'],
                          ['25 miles', '25'],
                          ['50 miles', '50'],
                          ['100 miles', '100']
                        ], params[:range] || '25'),
                        {},
                        {
                          class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all",
                          data: { society_search_target: "rangeSelect" }
                        } %>
                  </div>
                  
                  <!-- Use My Location Button -->
                  <button type="button" 
                          class="px-4 py-3 rounded-xl border border-purple-300 text-purple-600 font-medium hover:bg-purple-50 transition-colors flex items-center justify-center gap-2"
                          data-action="click->society-search#useCurrentLocation"
                          data-society-search-target="locationButton">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                    </svg>
                    <span>Use My Location</span>
                  </button>
                </div>
              </div>

              <!-- Filter Options -->
              <div class="flex flex-wrap gap-4 items-center">
                <!-- Public Toggle -->
                <div class="flex items-center gap-2">
                  <label class="inline-flex items-center cursor-pointer">
                    <%= form.check_box :public_only, checked: params[:public_only] == '1', 
                        class: "sr-only peer", 
                        data: { society_search_target: "publicToggle" } %>
                    <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-purple-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-purple-600"></div>
                    <span class="ml-2 text-sm font-medium text-gray-700">Public Only</span>
                  </label>
                </div>
                
                <!-- Search Button -->
                <button type="submit" class="px-8 py-3 rounded-xl bg-purple-600 text-white font-semibold hover:bg-purple-700 transition-colors flex items-center gap-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                  Search Societies
                </button>
                
                <!-- Clear Filters -->
                <% if params[:search].present? || params[:zip_code].present? || params[:range].present? || params[:public_only] == '1' %>
                  <%= link_to societies_path, class: "text-sm text-purple-600 hover:text-purple-700 font-medium" do %>
                    Clear all filters
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Search Results -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% if @societies.any? %>
            <% @societies.each do |society| %>
              <%= link_to society_path(society), class: "block group" do %>
                <div class="bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-all duration-200 hover:-translate-y-1">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center">
                      <%= render 'shared/society_icon', society: society %>
                    </div>
                    <div class="flex-1">
                      <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors"><%= society.name %></h3>
                      <span class="px-2 py-1 rounded-full text-xs font-medium <%= society.is_private ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700' %>">
                        <%= society.is_private ? 'Private' : 'Public' %>
                      </span>
                    </div>
                  </div>

                  <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= society.description %></p>

                  <% if society.location.present? %>
                    <div class="flex items-center gap-1 text-gray-500 text-sm mb-3">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      <span><%= society.location %></span>
                    </div>
                  <% end %>

                  <div class="flex items-center gap-4 text-gray-500 text-sm">
                    <span class="flex items-center gap-1">
                      <%= render 'shared/user_group_icon' %>
                      <%= society.members.count %> members
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      <%= society.events.count %> events
                    </span>
                  </div>
                </div>
              <% end %>
            <% end %>
          <% else %>
            <!-- Empty Search Results -->
            <div class="col-span-full text-center py-12">
              <div class="text-6xl mb-4">🔍</div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">No societies found</h3>
              <p class="text-gray-600 mb-4">
                <% if params[:search].present? || params[:location].present? %>
                  Try adjusting your search criteria to find more societies.
                <% else %>
                  There are no societies to discover right now.
                <% end %>
              </p>
              <% if params[:search].present? || params[:location].present? %>
                <%= link_to societies_path, class: 'text-purple-600 hover:text-purple-700 font-medium' do %>
                  Show all societies
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>

<% else %>
  <!-- Marketing Page for Unauthenticated Users -->
  <section class="relative min-h-screen flex w-full overflow-hidden bg-gradient-to-br from-slate-900 via-indigo-900 to-purple-900">
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-400/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-purple-400/15 rounded-full blur-3xl animate-pulse delay-1000"></div>
      <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-violet-400/10 rounded-full blur-2xl animate-bounce delay-500"></div>
    </div>

    <!-- Content Container -->
    <div class="relative w-full flex items-center justify-center z-10">
      <div class="px-8 lg:px-16 py-24 w-full max-w-6xl text-center">
        <h1 class="text-6xl md:text-8xl font-black tracking-tight mb-8 leading-[0.9]">
          <span class="block text-white drop-shadow-2xl">Connect.</span>
          <span class="block text-white drop-shadow-2xl">Explore.</span>
          <span class="block bg-gradient-to-r from-purple-400 via-violet-400 to-indigo-400 bg-clip-text text-transparent drop-shadow-lg mb-8">Belong.</span>
          <span class="block text-2xl md:text-4xl font-bold text-indigo-200 -mt-2">Find Your Society.</span>
        </h1>

        <p class="text-xl md:text-2xl text-indigo-100 mb-6 leading-relaxed font-medium max-w-4xl mx-auto">
          Join exclusive whiskey communities where <strong class="text-white">passion meets purpose</strong>. From public meetups to private tastings, discover your perfect whiskey society.
        </p>

        <%= link_to new_user_registration_path, class: 'group inline-flex items-center gap-3 px-10 py-5 rounded-full bg-gradient-to-r from-purple-400 via-violet-500 to-indigo-500 text-white text-xl font-bold shadow-2xl hover:shadow-purple-500/30 transition-all duration-200 hover:-translate-y-0.5' do %>
          <span>Join the Community</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        <% end %>

        <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-8 text-indigo-200">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="font-medium">Public & Private Options</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="font-medium">Events & Meetups</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="font-medium">Expert Communities</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Public Societies Preview -->
  <section class="relative w-full py-16 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Featured Public Societies</h2>
        <p class="text-xl text-gray-600">Get a taste of our vibrant whiskey communities</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if @societies.any? %>
          <% @societies.limit(6).each do |society| %>
            <div class="bg-gray-50 rounded-2xl border border-gray-200 p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-gradient-to-r from-amber-500 to-orange-600 rounded-xl flex items-center justify-center">
                  <%= render 'shared/society_icon', society: society %>
                </div>
                <div class="flex-1">
                  <h3 class="text-lg font-bold text-gray-900"><%= society.name %></h3>
                  <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">Public</span>
                </div>
              </div>

              <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= society.description %></p>

              <div class="flex items-center gap-4 text-gray-500 text-sm">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6 0A4 4 0 005 16m6-4a4 4 0 100-8 4 4 0 000 8zm6 4a4 4 0 00-3-3.87"></path>
                  </svg>
                  <%= society.members.count %> members
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <%= society.events.count %> events
                </span>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="col-span-full text-center py-12">
            <div class="text-6xl mb-4">🥃</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">No public societies yet</h3>
            <p class="text-gray-600">Be the first to create a public whiskey society!</p>
          </div>
        <% end %>
      </div>

      <div class="text-center mt-12">
        <%= link_to new_user_registration_path, class: 'inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-purple-500 to-indigo-600 text-white font-semibold hover:from-purple-600 hover:to-indigo-700 transition-all duration-200 shadow-lg hover:shadow-xl' do %>
          <span>Join to See All Societies</span>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        <% end %>
      </div>
    </div>
  </section>
<% end %>