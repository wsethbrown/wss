<div class="mx-auto max-w-2xl px-4 pt-8 pb-16 text-center">
  <p class="eyebrow mb-3 text-whiskey-600">Welcome</p>
  <h1 class="font-display text-4xl font-semibold leading-tight text-gray-900 md:text-5xl">
    Welcome to the society<%= ", #{@user.first_name}" if @user.first_name.present? %>
  </h1>
  <div class="rule-double mx-auto mt-6 w-20 text-whiskey-800"></div>
  <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-gray-600">
    Your account is set up under <strong class="text-gray-900"><%= @user.email %></strong> and you're signed in now.
  </p>

  <div class="mx-auto mt-10 grid max-w-xl gap-4 text-left sm:grid-cols-2">
    <div class="rounded-2xl border border-whiskey-200 bg-white p-6 shadow-sm">
      <h2 class="eyebrow mb-2 text-whiskey-700">Magic link</h2>
      <p class="text-sm leading-relaxed text-gray-600">
        Enter your email on the sign-in page and we send a one-click link. No password to remember.
      </p>
    </div>
    <div class="rounded-2xl border border-whiskey-200 bg-white p-6 shadow-sm">
      <h2 class="eyebrow mb-2 text-whiskey-700">Google</h2>
      <p class="text-sm leading-relaxed text-gray-600">
        Use Continue with Google on the sign-in page with this same address.
      </p>
    </div>
  </div>

  <div class="mt-10">
    <%= link_to "Go to your dashboard", dashboard_path, class: "btn btn-primary px-8 py-3" %>
  </div>
</div>
