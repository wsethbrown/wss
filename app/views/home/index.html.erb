<%# Homepage. Two-surface system: char (the tasting room) for narrative sections,
    paper (the label) for utility. Signature motif: the amber thread. %>

<!-- ============================================================ Hero -->
<section class="relative flex min-h-[92svh] w-full items-center justify-center overflow-hidden bg-char pt-16">
  <%# Candlelight: one quiet radial glow, no animated blobs. %>
  <div class="pointer-events-none absolute inset-0" aria-hidden="true"
       style="background: radial-gradient(ellipse 70% 45% at 50% 105%, rgba(201, 136, 74, 0.28), transparent 70%);"></div>

  <div class="relative z-10 mx-auto max-w-3xl px-6 py-24 text-center">
    <p class="eyebrow mb-10 text-whiskey-300/90">The Whiskey Share Society &middot; Est. 2019</p>

    <h1 class="font-display text-5xl font-semibold leading-[1.05] text-cream sm:text-6xl lg:text-7xl">
      Every pour has<br>
      <span class="relative inline-block whitespace-nowrap">
        a story.
        <span class="thread absolute -bottom-2 left-0 right-0 sm:-bottom-3" aria-hidden="true"></span>
      </span>
    </h1>

    <p class="mx-auto mt-8 max-w-xl text-lg leading-relaxed text-cream/70 sm:text-xl">
      Narrative tasting decks for whiskey nights that hold together —
      the research done, the script written, the bottles picked.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <%= link_to 'Browse the decks', presentations_path,
          class: 'inline-flex items-center justify-center rounded-xl bg-whiskey-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-whiskey-950/40 transition hover:bg-whiskey-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char' %>
      <%# data-turbo=false: let the browser handle the in-page anchor natively so
          CSS scroll-behavior: smooth applies. Turbo's own anchor scroll overshoots. %>
      <%= link_to 'See how it works', '#how-it-works',
          data: { turbo: false },
          class: 'inline-flex items-center justify-center rounded-xl border border-cream/25 px-7 py-3.5 text-base font-semibold text-cream/90 transition hover:border-cream/50 hover:text-cream focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char' %>
    </div>

    <p class="mt-12 text-sm tracking-wide text-cream/50">
      One credit a month with membership &middot; Or buy any deck outright
    </p>
  </div>
</section>

<!-- ============================================== How it works (pinned) -->
<section id="how-it-works" class="w-full bg-char md:grid md:grid-cols-2">
  <%# Left panel pins while the steps scroll. Grid + self-start is the reliable
      sticky pattern; on mobile it stacks and flows normally. %>
  <div class="flex items-center px-6 py-20 md:sticky md:top-0 md:h-screen md:self-start md:px-12 lg:px-16">
    <div class="max-w-md">
      <p class="eyebrow mb-4 text-whiskey-300/90">How it works</p>
      <h2 class="font-display text-4xl font-semibold leading-tight text-cream lg:text-5xl">
        From bottle to story in three steps.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-cream/70">
        Each deck is a narrative — a thread connecting every pour to the people,
        places, and history behind it. You bring the bottles and enjoy the presentation
        with your friends.
      </p>

      <%# The thread, vertical: three stations for three steps. %>
      <div class="mt-10 flex items-center gap-4" aria-hidden="true">
        <span class="font-display text-sm text-whiskey-300">01</span>
        <span class="h-px flex-1 bg-gradient-to-r from-whiskey-400/70 to-whiskey-400/10"></span>
        <span class="font-display text-sm text-whiskey-300/70">02</span>
        <span class="h-px flex-1 bg-gradient-to-r from-whiskey-400/40 to-whiskey-400/10"></span>
        <span class="font-display text-sm text-whiskey-300/50">03</span>
      </div>

      <div class="mt-10">
        <%= link_to 'Start with a deck', presentations_path,
            class: 'inline-flex items-center justify-center rounded-xl bg-whiskey-500 px-6 py-3 text-base font-semibold text-white transition hover:bg-whiskey-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char' %>
      </div>
    </div>
  </div>

  <!-- Right: the three steps, on paper -->
  <div class="bg-whiskey-50">
    <% [
      {
        number: "01",
        title: "Pick a deck",
        body: "Browse the library and choose the story you want to tell — bourbon, scotch, rye, or something stranger. Filter by difficulty and budget.",
        points: [ "Slides plus a full speaker script",
                  "A bottle list for every budget",
                  "Tasting mats and notes as PDFs" ]
      },
      {
        number: "02",
        title: "Gather your society",
        body: "Start a private society for your friends or join a public one near you. Schedule the night, share the link, and RSVPs take care of themselves.",
        points: [ "Public and private societies",
                  "Events with RSVPs built in",
                  "Roles for organizers and officers" ]
      },
      {
        number: "03",
        title: "Pour and present",
        body: "Follow the thread from first nose to final pour. The script keeps the room moving; the tasting notes keep it honest.",
        points: [ "15-20 minute runtime, easy to trim",
                  "Guided tasting for each bottle",
                  "Written for first-timers and collectors alike",
                  "Great memories waiting to be unlocked"]
      }
    ].each do |step| %>
      <div class="flex min-h-[85vh] items-center justify-center px-6 py-20 md:px-12">
        <div class="max-w-md">
          <div class="flex items-baseline gap-4">
            <span class="font-display text-6xl font-semibold text-whiskey-200"><%= step[:number] %></span>
            <span class="thread w-16 self-center" aria-hidden="true"></span>
          </div>
          <h3 class="mt-6 font-display text-3xl font-semibold text-gray-900"><%= step[:title] %></h3>
          <p class="mt-4 text-lg leading-relaxed text-gray-600"><%= step[:body] %></p>
          <ul class="mt-8 space-y-3">
            <% step[:points].each do |point| %>
              <li class="flex items-center gap-3 rounded-xl border border-whiskey-100 bg-white px-4 py-3">
                <svg class="h-4 w-4 flex-shrink-0 text-whiskey-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="font-medium text-gray-800"><%= point %></span>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <!-- Closing beat of the split -->
    <div class="flex min-h-[60vh] items-center justify-center px-6 py-20 md:px-12">
      <div class="max-w-md text-center">
        <h3 class="font-display text-3xl font-semibold text-gray-900">That's the whole ritual.</h3>
        <p class="mt-4 text-lg text-gray-600">Pick your first deck and set a date. The rest is poured, not planned.</p>
        <div class="mt-8">
          <%= link_to 'Browse the decks', presentations_path,
              class: 'inline-flex items-center justify-center rounded-xl bg-whiskey-600 px-7 py-3.5 text-base font-semibold text-white transition hover:bg-whiskey-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2' %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================================================== The ritual -->
<section class="w-full bg-white px-6 py-16 sm:py-20">
  <div class="mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-2">
    <div>
      <p class="eyebrow mb-4 text-whiskey-600">Why we exist</p>
      <h2 class="font-display text-4xl font-semibold leading-tight text-gray-900 lg:text-5xl">
        Born from a monthly ritual.
      </h2>
      <div class="rule-double mt-6 w-24 text-whiskey-800"></div>
      <p class="mt-8 text-lg leading-relaxed text-gray-600">
        The Society started as a circle of friends. Each month one of us drew a topic,
        did the research, bought the bottles, and told its story over a deck of slides.
        The rules were simple: no fact sheets, tell a story, enjoy a wonderful night with great friends.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-gray-600">
        Societies are that ritual, kept intact: a group, a calendar, and a reason to
        gather. Make yours private for your friends, or public for your city.
      </p>
      <div class="mt-10">
        <%= link_to 'Find your society', societies_path,
            class: 'inline-flex items-center justify-center rounded-xl border border-whiskey-300 bg-white px-6 py-3 text-base font-semibold text-whiskey-800 transition hover:bg-whiskey-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2' %>
      </div>
    </div>

    <%# The house rules, set like the back label of a bottle. %>
    <div class="rounded-2xl border border-whiskey-200 bg-whiskey-50 p-10 shadow-sm">
      <p class="eyebrow text-center text-whiskey-600">House rules</p>
      <div class="rule-double mx-auto mt-3 w-16 text-whiskey-700"></div>
      <ol class="mt-8 space-y-6">
        <% [
          "One presenter a month — everyone takes a turn.",
          "Research your topic like you mean it.",
          "Choose the bottles that belong to the story.",
          "No dry fact sheets. Follow the narrative threads."
        ].each_with_index do |rule, i| %>
          <li class="flex gap-4">
            <span class="font-display text-2xl font-semibold text-whiskey-300"><%= format('%02d', i + 1) %></span>
            <span class="pt-1 font-reading text-lg text-gray-800"><%= rule %></span>
          </li>
        <% end %>
      </ol>
    </div>
  </div>
</section>

<!-- ================================================= Featured decks -->
<% if @featured_presentations&.any? %>
  <section class="w-full bg-whiskey-50 px-6 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="eyebrow mb-4 text-whiskey-600">From the library</p>
          <h2 class="font-display text-4xl font-semibold text-gray-900">Latest decks</h2>
        </div>
        <%= link_to 'See the full library →', presentations_path,
            class: 'text-base font-semibold text-whiskey-700 transition hover:text-whiskey-600' %>
      </div>

      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <% @featured_presentations.each do |deck| %>
          <%= render 'presentations/deck_card', deck: deck,
              owned: user_signed_in? && deck.purchased_by?(current_user) %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<!-- ======================================================= Pricing -->
<!-- The societies -->
<section class="w-full bg-char px-6 py-16 sm:py-20">
  <div class="mx-auto max-w-3xl text-center">
    <p class="eyebrow mb-4 text-whiskey-300/90">The company you keep</p>
    <h2 class="font-display text-4xl font-semibold text-cream sm:text-5xl">Societies</h2>
    <%# Lead line set apart — its own paragraph, warmer than the body copy. %>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-whiskey-200">
      A deck is meant to be presented to people around a table, sharing a space.
    </p>
    <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-cream/80">
      Societies are how those spaces organize: public ones open to new members,
      private ones that run on invitations, each with its own calendar of tasting
      nights and its own record of every pour the room has judged.
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <%= link_to "Browse societies", societies_path, class: "inline-flex items-center justify-center rounded-xl bg-whiskey-500 px-7 py-3.5 font-semibold text-white shadow-lg shadow-whiskey-950/40 transition hover:bg-whiskey-400" %>
    </div>
  </div>
</section>

<!-- The tasting record -->
<section class="w-full bg-white px-6 py-16 sm:py-20">
  <div class="mx-auto max-w-3xl text-center">
    <p class="eyebrow mb-4 text-whiskey-600">The pours, on the record</p>
    <h2 class="font-display text-4xl font-semibold text-gray-900 sm:text-5xl">The tasting record</h2>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-600">
      Every bottle the society tastes gets written down — nose, palate, finish, price, and personal thoughts.
      Graphs and charts drawn from reviewers' own words to help visualize your taste preferences,
      ratings that put the best tastings first, and a record you can search by
      bottle, distillery, or the flavor you're chasing.
    </p>
    <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-gray-600">
      Favorite another Member or a Society whose reviews you trust so their latest thoughts are
      easy to find, helping you find your next favorite purchase.
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <%= link_to "Read the record", reviews_path, class: "inline-flex items-center justify-center rounded-xl bg-whiskey-600 px-7 py-3.5 font-semibold text-white transition hover:bg-whiskey-700" %>
    </div>
  </div>
</section>

<section id="pricing" class="w-full bg-whiskey-50 px-6 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4 text-whiskey-600">Membership</p>
      <h2 class="font-display text-4xl font-semibold text-gray-900 sm:text-5xl">Choose your pour.</h2>
      <p class="mt-6 text-lg text-gray-600">
        Every plan earns one deck credit a month and full run of the societies.
        Prefer to commit? The longer pours cost less.
      </p>
    </div>

    <div id="plan-cards" class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
      <% @stripe_products.each do |product| %>
        <div class="relative flex flex-col rounded-3xl bg-white p-8 shadow-xl transition hover:-translate-y-1 hover:shadow-2xl <%= product[:popular] ? 'border-2 border-whiskey-400' : 'border border-gray-200' %>">
          <% if product[:popular] %>
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="eyebrow rounded-full border border-whiskey-500 bg-whiskey-600 px-4 py-1.5 text-white shadow-sm">Best Value</span>
            </div>
          <% end %>

          <div class="text-center">
            <h3 class="font-display text-2xl font-semibold text-gray-900"><%= product[:name].gsub(' Membership', '') %></h3>
            <p class="mt-1 text-gray-500"><%=
              case product[:id]
              when 'monthly' then 'Perfect for trying it out'
              when 'quarterly' then 'Great value'
              when 'yearly' then 'Save 31%'
              else 'Best value for committed members'
              end
            %></p>

            <div class="mt-6">
              <div class="flex items-end justify-center">
                <span class="font-display text-5xl font-semibold <%= product[:popular] ? 'text-whiskey-700' : 'text-gray-900' %>">$<%= sprintf('%.2f', product[:price] / 100.0) %></span>
                <span class="ml-1 pb-1 text-lg text-gray-400">/mo</span>
              </div>
              <% if product[:id] == 'quarterly' || product[:id] == 'yearly' %>
                <div class="mt-1 text-sm text-gray-500">billed <%= product[:id] == 'quarterly' ? 'quarterly' : 'annually' %></div>
              <% end %>
              <% if product[:savings] %>
                <div class="mt-3 inline-flex items-center rounded-full bg-whiskey-100 px-3 py-1 text-sm font-semibold text-whiskey-800">Save <%= product[:savings] %></div>
              <% end %>
            </div>
          </div>

          <div class="rule-double mx-auto my-8 w-16 text-whiskey-300"></div>

          <ul class="mb-8 flex-grow space-y-3 text-sm text-gray-600">
            <% product[:features].reject { |f| f.include?('%') || f.downcase.include?('save') || f.downcase.include?('savings') }.each do |feature| %>
              <li class="flex items-center">
                <svg class="mr-3 h-4 w-4 flex-shrink-0 text-whiskey-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <%= feature %>
              </li>
            <% end %>
          </ul>

          <div>
            <% if user_signed_in? && current_user.subscription_active? %>
              <%# Members don't need three checkout buttons. Mark their plan;
                  changes happen from the account page. %>
              <% if current_user.subscription_plan == product[:id] %>
                <div class="w-full rounded-xl border-2 border-whiskey-400 bg-whiskey-50 px-6 py-3 text-center text-base font-semibold text-whiskey-800">
                  Your current plan
                </div>
              <% else %>
                <%= link_to 'Manage in your account', account_path(anchor: 'subscription'),
                    class: "block w-full rounded-xl border border-gray-300 px-6 py-3 text-center text-base font-semibold text-gray-700 transition hover:bg-gray-50" %>
              <% end %>
            <% elsif user_signed_in? %>
              <%= form_with url: subscriptions_checkout_path, method: :post, local: true, data: { turbo: false } do |f| %>
                <%= f.hidden_field :price_id, value: product[:id] %>
                <%= f.submit "Get Started", class: "w-full cursor-pointer rounded-xl px-6 py-3 text-base font-semibold text-white transition focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2 #{product[:popular] ? 'bg-whiskey-600 hover:bg-whiskey-700' : 'bg-gray-900 hover:bg-gray-800'}" %>
              <% end %>
            <% else %>
              <%= link_to 'Get Started', auth_path,
                  class: "block w-full rounded-xl px-6 py-3 text-center text-base font-semibold text-white transition focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2 #{product[:popular] ? 'bg-whiskey-600 hover:bg-whiskey-700' : 'bg-gray-900 hover:bg-gray-800'}" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <p class="mt-10 text-center text-sm text-gray-500">
      Credits unlock any deck while your membership is active. Decks bought outright are yours for good.
    </p>
  </div>
</section>

<!-- ========================================================== FAQ -->
<section id="faq" class="w-full bg-char px-6 py-16 sm:py-20">
  <div class="mx-auto max-w-3xl">
    <div class="text-center">
      <p class="eyebrow mb-4 text-whiskey-300/90">Before you pour</p>
      <h2 class="font-display text-4xl font-semibold text-cream sm:text-5xl">Questions, answered.</h2>
    </div>

    <div class="mt-14 space-y-4">
      <% [
        {
          q: "What if I'm a complete whiskey beginner?",
          a: "Perfect — the decks are written for every experience level. Start with something like Bourbon Basics: the script covers the fundamentals and makes you sound like you've done this before, because the research already has."
        },
        {
          q: "How long is a deck?",
          a: "Most run 15–20 minutes, built for a relaxed evening. The structure bends: linger on a tasting when the room is into it, or trim sections for a casual night."
        },
        {
          q: "What equipment do I need?",
          a: "Glasses, water for rinsing, and the bottles from the deck's list. Tasting mats and notes come as downloadable PDFs. Nothing fancy required."
        },
        {
          q: "Can I customize a deck?",
          a: "Yes. Swap bottles for budget or availability, skip sections, add your own chapter. Decks are guides with a spine, not scripts you owe obedience to."
        },
        {
          q: "How much do the whiskeys cost?",
          a: "Every deck recommends bottles across price ranges. You can host a full tasting for $60–80 total, or go deep with bottles north of $200 — there's a version of the night for both."
        }
      ].each do |faq| %>
        <details class="group rounded-2xl border border-oak-edge bg-oak transition hover:border-whiskey-700 open:border-whiskey-700">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 [&::-webkit-details-marker]:hidden">
            <h3 class="font-display text-lg font-semibold text-cream"><%= faq[:q] %></h3>
            <svg class="h-5 w-5 flex-shrink-0 text-whiskey-300 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"></path>
            </svg>
          </summary>
          <p class="px-6 pb-6 leading-relaxed text-cream/70"><%= faq[:a] %></p>
        </details>
      <% end %>
    </div>

    <div class="mt-16 text-center">
      <% if user_signed_in? %>
        <%= link_to 'Browse the decks', presentations_path,
            class: 'inline-flex items-center justify-center rounded-xl bg-whiskey-500 px-8 py-4 text-lg font-semibold text-white shadow-lg shadow-whiskey-950/40 transition hover:bg-whiskey-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char' %>
      <% else %>
        <%= link_to 'Join the Society', auth_path,
            class: 'inline-flex items-center justify-center rounded-xl bg-whiskey-500 px-8 py-4 text-lg font-semibold text-white shadow-lg shadow-whiskey-950/40 transition hover:bg-whiskey-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char' %>
      <% end %>
    </div>
  </div>
</section>
