<% content_for :title, "Contact" %>

<div class="mx-auto max-w-2xl py-12">
  <p class="eyebrow mb-4 text-whiskey-600">Contact</p>
  <h1 class="font-display text-4xl font-semibold text-gray-900">Reach the Society.</h1>

  <div class="mt-10 space-y-6">
    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="font-display text-lg font-semibold text-gray-900">Say hello</h2>
      <p class="mt-1 text-gray-600">General questions, ideas, and everything else.</p>
      <a href="mailto:hello@whiskeysharesociety.com" class="mt-3 inline-block font-semibold text-whiskey-700 hover:text-whiskey-800">hello@whiskeysharesociety.com</a>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="font-display text-lg font-semibold text-gray-900">Get help</h2>
      <p class="mt-1 text-gray-600">Trouble with your account, a deck, or an order.</p>
      <a href="mailto:support@whiskeysharesociety.com" class="mt-3 inline-block font-semibold text-whiskey-700 hover:text-whiskey-800">support@whiskeysharesociety.com</a>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="font-display text-lg font-semibold text-gray-900">Work with us</h2>
      <p class="mt-1 text-gray-600">Distillers, distributors, and collaborations.</p>
      <a href="mailto:partners@whiskeysharesociety.com" class="mt-3 inline-block font-semibold text-whiskey-700 hover:text-whiskey-800">partners@whiskeysharesociety.com</a>
    </div>
  </div>
</div>
