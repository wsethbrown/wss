<%# locals: pours (array of hashes, may be empty), blank_rows (int) %>
<% rows = pours.presence || Array.new(blank_rows) { nil } %>
<table class="w-full border-collapse">
  <thead>
    <tr class="border-b-2 border-whiskey-300">
      <th class="w-2/5 pb-2 pr-3 text-left font-sans text-[0.65rem] font-semibold uppercase tracking-wide text-gray-500">The pour</th>
      <% %w[Nose Palate Finish Overall].each do |criterion| %>
        <th class="pb-2 text-center font-sans text-[0.65rem] font-semibold uppercase tracking-wide text-gray-500"><%= criterion %></th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% rows.each_with_index do |pour, i| %>
      <tr class="align-top">
        <td class="py-3 pr-3">
          <% if pour %>
            <p class="font-display text-base font-semibold leading-tight text-gray-900"><%= pour[:name] %></p>
            <% meta = [pour[:region], pour[:style], pour[:price]].map { |v| v.to_s.strip.presence }.compact.join(" · ") %>
            <% if meta.present? %><p class="mt-0.5 text-xs text-gray-500"><%= meta %></p><% end %>
          <% else %>
            <div class="flex items-end gap-2">
              <span class="font-display text-base font-semibold text-gray-400"><%= i + 1 %>.</span>
              <span class="flex-1 border-b border-gray-300 pb-4">&nbsp;</span>
            </div>
          <% end %>
        </td>
        <% 4.times do %>
          <td class="py-3">
            <div class="flex items-center justify-center gap-1.5">
              <% 5.times do %><span class="pip"></span><% end %>
            </div>
          </td>
        <% end %>
      </tr>
      <tr>
        <td colspan="5" class="pb-4 pt-0">
          <div class="flex items-center gap-2 text-[0.65rem] text-gray-400">
            <span class="font-sans uppercase tracking-wide">Notes</span>
            <span class="flex-1 border-b border-dotted border-gray-300 pb-3">&nbsp;</span>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
