<div>
  <h1 class="font-bold text-4xl">Presentations#index</h1>
  <p>Find me in app/views/presentations/index.html.erb</p>
</div>

<!-- Search Section -->
<section class="relative w-full py-12 px-4 bg-gradient-to-br from-blue-50 via-white to-indigo-50">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">Whiskey Presentations</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Ready-made presentations with slides, scripts, and whiskey recommendations. Host a world-class tasting in minutes.</p>
    </div>

    <!-- Search and Filter Bar -->
    <%= form_with url: presentations_path, method: :get, local: true, class: "bg-white/60 backdrop-blur-xl rounded-3xl shadow-xl border border-white/20 p-6 mb-8" do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Search Bar -->
        <div class="md:col-span-2">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <%= form.text_field :search,
                value: params[:search],
                placeholder: "Search presentations...",
                class: "w-full pl-12 pr-4 py-4 text-lg border-0 rounded-2xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all duration-200 shadow-sm" %>
          </div>
        </div>
                <!-- Category Dropdown -->
        <div class="relative">
          <%= form.select :category,
              options_for_select([
                ['All Categories', ''],
                ['Scotch Whisky', 'Scotch Whisky'],
                ['Bourbon', 'Bourbon'],
                ['Irish Whiskey', 'Irish Whiskey'],
                ['Japanese Whisky', 'Japanese Whisky'],
                ['Rye Whiskey', 'Rye Whiskey'],
                ['Canadian Whisky', 'Canadian Whisky'],
                ['Beginner Friendly', 'Beginner'],
                ['Advanced Tasting', 'Advanced']
              ], params[:category]),
              {},
              { class: "w-full px-4 py-4 text-lg border-0 rounded-2xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all duration-200 shadow-sm appearance-none cursor-pointer" } %>
          <div class="absolute right-4 top-1/2 transform -translate-y-1/2 pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Clear Filters Button (only show if filters are active) -->
      <% if params[:search].present? || params[:category].present? %>
        <div class="mt-4 text-center">
          <%= link_to 'Clear all filters', presentations_path, class: 'inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 text-gray-700 font-medium hover:bg-gray-200 transition' %>
        </div>
      <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- Presentations Grid -->
<section class="relative w-full py-8 px-4 bg-white">
  <div class="max-w-7xl mx-auto">
    <!-- Results Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">
          <% if params[:search].present? || params[:category].present? %>
            Search Results
          <% else %>
            All Presentations
          <% end %>
        </h2>
        <p class="text-gray-600">
          <%= @presentations.count %> presentation<%= 's' unless @presentations.count == 1 %> available
          <% if params[:search].present? %>
            for "<%= params[:search] %>"
          <% end %>
          <% if params[:category].present? %>
            in <%= params[:category] %>
          <% end %>
        </p>
      </div>
      <div class="flex items-center gap-4 mt-4 md:mt-0">
        <span class="text-gray-600">Sort by:</span>
        <%= form_with url: presentations_path, method: :get, local: true, class: "inline" do |form| %>
          <%= form.hidden_field :search, value: params[:search] %>
          <%= form.hidden_field :category, value: params[:category] %>
          <%= form.select :sort,
              options_for_select([
                ['Most Popular', 'popular'],
                ['Newest', 'newest'],
                ['Highest Rated', 'rating'],
                ['Duration', 'duration']
              ], params[:sort] || 'popular'),
              {},
              { class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none", onchange: 'this.form.submit()' } %>
        <% end %>
      </div>
    </div>

        <!-- Presentations Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      <% if @presentations.any? %>
                <% @presentations.each do |presentation| %>
          <div class="group relative bg-white rounded-3xl shadow-xl border border-gray-200 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 cursor-pointer overflow-hidden" onclick="openPresentationModal(<%= presentation[:id] %>)">
          
          <!-- Header Image Section -->
          <div class="relative h-48 bg-cover bg-center bg-gray-800" style="background-image: url('<%= case presentation[:image]
            when 'scotch-intro' then 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=800&h=400&fit=crop&crop=center'
            when 'bourbon-guide' then 'https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=800&h=400&fit=crop&crop=center'
            when 'japanese-whisky' then 'https://images.unsplash.com/photo-1582037928769-181f2644ecb7?w=800&h=400&fit=crop&crop=center'
            when 'irish-traditions' then 'https://images.unsplash.com/photo-1527281400683-1aae777175f8?w=800&h=400&fit=crop&crop=center'
            when 'rye-renaissance' then 'https://images.unsplash.com/photo-1540982736923-fe0e51da8053?w=800&h=400&fit=crop&crop=center'
            when 'canadian-deep-dive' then 'https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?w=800&h=400&fit=crop&crop=center'
            when 'peated-scotch' then 'https://images.unsplash.com/photo-1513475382585-d06e58bcb0e0?w=800&h=400&fit=crop&crop=center'
            when 'single-barrel' then 'https://images.unsplash.com/photo-1523741543316-beb7fc7023d8?w=800&h=400&fit=crop&crop=center'
            when 'food-pairing' then 'https://images.unsplash.com/photo-1551024506-0bccd828d307?w=800&h=400&fit=crop&crop=center'
            when 'craft-distillery' then 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&h=400&fit=crop&crop=center'
            when 'vintage-appreciation' then 'https://images.unsplash.com/photo-1598300042247-d088f8ab3a91?w=800&h=400&fit=crop&crop=center'
            when 'cocktail-classics' then 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=800&h=400&fit=crop&crop=center'
            else 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=800&h=400&fit=crop&crop=center'
          end %>')">
            
            <!-- Dark overlay for text readability -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            
            <!-- Category Badge on Header -->
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-white/20 backdrop-blur-sm border border-white/30 text-white">
                <%= presentation[:category] %>
              </span>
            </div>
            
            <!-- Price on Header -->
            <div class="absolute top-4 right-4">
              <span class="text-2xl font-bold text-white">
                <%= presentation[:price] %>
              </span>
            </div>
          </div>

          <div class="relative z-10 p-6">
            <!-- Title -->
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-700 transition-colors">
              <%= presentation[:title] %>
            </h3>

            <!-- Description -->
            <p class="text-gray-600 text-sm mb-4 line-clamp-3">
              <%= presentation[:description] %>
            </p>

            <!-- Stats -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-4 text-sm text-gray-500">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <%= presentation[:duration] %>
                </span>
                <span class="px-2 py-1 rounded-full text-xs font-semibold <%= presentation[:difficulty] == 'Beginner' ? 'bg-green-100 text-green-700' : presentation[:difficulty] == 'Intermediate' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
                  <%= presentation[:difficulty] %>
                </span>
              </div>
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                </svg>
                <span class="text-sm font-semibold text-gray-900"><%= presentation[:rating] %></span>
                <span class="text-sm text-gray-500">(<%= presentation[:reviews] %>)</span>
              </div>
            </div>

            <!-- CTA Button -->
            <div class="flex gap-2" onclick="event.stopPropagation()">
              <button onclick="openPresentationModal(<%= presentation[:id] %>)" class="flex-1 px-4 py-3 rounded-2xl font-bold text-white bg-indigo-600 shadow text-center group-hover:bg-indigo-700 transition">
                View Details
              </button>
              <button class="px-4 py-3 rounded-2xl font-bold text-indigo-600 bg-indigo-50 shadow hover:bg-indigo-100 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      <% end %>
      <% else %>
        <!-- No Results Message -->
        <div class="col-span-full text-center py-16">
          <div class="max-w-md mx-auto">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No presentations found</h3>
            <p class="text-gray-600 mb-6">
              <% if params[:search].present? %>
                No presentations match "<%= params[:search] %>"
              <% elsif params[:category].present? %>
                No presentations in <%= params[:category] %>
              <% else %>
                No presentations available
              <% end %>
            </p>
            <%= link_to 'Clear filters', presentations_path, class: 'inline-flex items-center gap-2 px-6 py-3 rounded-full bg-blue-600 text-white font-semibold hover:bg-blue-700 transition' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Presentation Modal -->
<div id="presentationModal" class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closePresentationModal()"></div>

  <!-- Modal Content -->
  <div class="relative min-h-screen flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto modal-scroll">
      <!-- Close Button -->
      <button onclick="closePresentationModal()" class="absolute top-4 right-4 z-10 w-10 h-10 bg-white/80 backdrop-blur-sm rounded-full flex items-center justify-center hover:bg-white transition-all duration-200 shadow-lg">
        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Header Image with Title Overlay -->
      <div id="modalHeaderImage" class="relative h-64 md:h-80 bg-cover bg-center bg-gray-800 rounded-t-3xl overflow-hidden" style="background-image: url('https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=800&h=400&fit=crop&crop=center')">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
        <div class="absolute bottom-6 left-6 right-6">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm border border-white/30 text-white font-semibold text-sm mb-3">
            <span class="w-2 h-2 bg-white rounded-full"></span>
            <span id="modalCategory">Scotch Whisky</span>
          </div>
          <h2 id="modalTitle" class="text-3xl md:text-4xl font-bold text-white mb-2">Introduction to Scotch Whisky</h2>
          <div class="flex items-center gap-4 text-white/90 text-sm">
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span id="modalDuration">45 minutes</span>
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
              <span id="modalRating">4.8 (127 reviews)</span>
            </span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="p-6 md:p-8">
        <!-- Short Description -->
        <div class="mb-8">
          <h3 class="text-xl font-bold text-gray-900 mb-4">About This Presentation</h3>
          <p id="modalDescription" class="text-gray-700 leading-relaxed">
            Perfect for beginners, this comprehensive presentation covers the basics of Scotch whisky production, regions, and tasting techniques. You'll learn about the six main regions of Scotland and discover how factors like water source, peat, and barrel aging influence the final product.
          </p>
        </div>

        <!-- Tasting Notes -->
        <div class="mb-8">
          <h3 class="text-xl font-bold text-gray-900 mb-4">What You'll Taste</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-blue-50 rounded-2xl p-4">
              <h4 class="font-semibold text-blue-900 mb-2">Nose</h4>
              <p class="text-blue-700 text-sm">Vanilla, honey, light oak, subtle fruit notes</p>
            </div>
            <div class="bg-green-50 rounded-2xl p-4">
              <h4 class="font-semibold text-green-900 mb-2">Palate</h4>
              <p class="text-green-700 text-sm">Smooth, balanced, with notes of caramel and spice</p>
            </div>
            <div class="bg-amber-50 rounded-2xl p-4">
              <h4 class="font-semibold text-amber-900 mb-2">Finish</h4>
              <p class="text-amber-700 text-sm">Medium length with warming oak and gentle smoke</p>
            </div>
            <div class="bg-purple-50 rounded-2xl p-4">
              <h4 class="font-semibold text-purple-900 mb-2">Body</h4>
              <p class="text-purple-700 text-sm">Medium-bodied with a smooth, approachable texture</p>
            </div>
          </div>
        </div>

        <!-- Recommended Whiskeys -->
        <div class="mb-8">
          <h3 class="text-xl font-bold text-gray-900 mb-4">Recommended Whiskeys</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="border border-gray-200 rounded-2xl p-4">
              <div class="flex items-start justify-between mb-2">
                <h4 class="font-semibold text-gray-900">Glenfiddich 12 Year</h4>
                <span class="text-green-600 font-bold">$</span>
              </div>
              <p class="text-gray-600 text-sm">Speyside • Light & Fruity</p>
            </div>
            <div class="border border-gray-200 rounded-2xl p-4">
              <div class="flex items-start justify-between mb-2">
                <h4 class="font-semibold text-gray-900">Laphroaig 10 Year</h4>
                <span class="text-yellow-600 font-bold">$$</span>
              </div>
              <p class="text-gray-600 text-sm">Islay • Peaty & Smoky</p>
            </div>
            <div class="border border-gray-200 rounded-2xl p-4">
              <div class="flex items-start justify-between mb-2">
                <h4 class="font-semibold text-gray-900">Highland Park 12 Year</h4>
                <span class="text-yellow-600 font-bold">$$</span>
              </div>
              <p class="text-gray-600 text-sm">Highlands • Balanced</p>
            </div>
            <div class="border border-gray-200 rounded-2xl p-4">
              <div class="flex items-start justify-between mb-2">
                <h4 class="font-semibold text-gray-900">Auchentoshan 12 Year</h4>
                <span class="text-green-600 font-bold">$</span>
              </div>
              <p class="text-gray-600 text-sm">Lowlands • Smooth & Light</p>
            </div>
          </div>
        </div>

        <!-- Purchase Section -->
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-3xl p-6 border border-blue-100">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
              <div class="text-3xl font-bold text-gray-900 mb-1" id="modalPrice">$9.99</div>
              <p class="text-gray-600">One-time purchase • Lifetime access</p>
            </div>
            <a href="#" id="modalPurchaseLink" class="inline-block px-8 py-4 bg-black text-white font-bold rounded-2xl hover:bg-blue-800 transition-all duration-200 shadow-lg hover:shadow-xl text-center">
              View Details
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .modal-scroll {
    -ms-overflow-style: none;  /* Internet Explorer 10+ */
    scrollbar-width: none;  /* Firefox */
  }
  .modal-scroll::-webkit-scrollbar {
    display: none;  /* Safari and Chrome */
  }
</style>

<script>
  // Auto-submit form when search input changes (with debounce)
  let searchTimeout;
  document.querySelector('input[name="search"]').addEventListener('input', function() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      this.closest('form').submit();
    }, 500);
  });

  // Auto-submit form when category changes
  document.querySelector('select[name="category"]').addEventListener('change', function() {
    this.closest('form').submit();
  });

  // Modal functionality
  function openPresentationModal(presentationId) {
    // Get presentation data based on ID
    const presentations = <%= raw @presentations.to_json %>;
    const presentation = presentations.find(p => p.id === presentationId);

    if (presentation) {
      // Update modal content
      document.getElementById('modalTitle').textContent = presentation.title;
      document.getElementById('modalCategory').textContent = presentation.category;
      document.getElementById('modalDuration').textContent = presentation.duration;
      document.getElementById('modalRating').textContent = `${presentation.rating} (${presentation.reviews} reviews)`;
      document.getElementById('modalDescription').textContent = presentation.description;
      document.getElementById('modalPrice').textContent = presentation.price;
      document.getElementById('modalPurchaseLink').href = `/presentations/${presentation.id}`;

      // Update modal header image based on presentation
      const headerElement = document.getElementById('modalHeaderImage');
      const imageUrls = {
        'scotch-intro': 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=800&h=400&fit=crop&crop=center',
        'bourbon-guide': 'https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=800&h=400&fit=crop&crop=center',
        'japanese-whisky': 'https://images.unsplash.com/photo-1582037928769-181f2644ecb7?w=800&h=400&fit=crop&crop=center',
        'irish-traditions': 'https://images.unsplash.com/photo-1527281400683-1aae777175f8?w=800&h=400&fit=crop&crop=center',
        'rye-renaissance': 'https://images.unsplash.com/photo-1540982736923-fe0e51da8053?w=800&h=400&fit=crop&crop=center',
        'canadian-deep-dive': 'https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?w=800&h=400&fit=crop&crop=center',
        'peated-scotch': 'https://images.unsplash.com/photo-1513475382585-d06e58bcb0e0?w=800&h=400&fit=crop&crop=center',
        'single-barrel': 'https://images.unsplash.com/photo-1523741543316-beb7fc7023d8?w=800&h=400&fit=crop&crop=center',
        'food-pairing': 'https://images.unsplash.com/photo-1551024506-0bccd828d307?w=800&h=400&fit=crop&crop=center',
        'craft-distillery': 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&h=400&fit=crop&crop=center',
        'vintage-appreciation': 'https://images.unsplash.com/photo-1598300042247-d088f8ab3a91?w=800&h=400&fit=crop&crop=center',
        'cocktail-classics': 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=800&h=400&fit=crop&crop=center'
      };
      
      // Update background image with fallback handling
      const imageUrl = imageUrls[presentation.image] || 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=800&h=400&fit=crop&crop=center';
      
      // Test image loading before applying
      const testImg = new Image();
      testImg.onload = function() {
        // Image loaded successfully
        headerElement.style.backgroundImage = `url('${imageUrl}')`;
        headerElement.style.backgroundSize = 'cover';
        headerElement.style.backgroundPosition = 'center';
      };
      
      testImg.onerror = function() {
        // Image failed to load, use fallback gradient
        headerElement.style.backgroundImage = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
        headerElement.style.backgroundSize = 'cover';
        headerElement.style.backgroundPosition = 'center';
        console.log('Modal header fallback applied for failed image:', imageUrl);
      };
      
      testImg.src = imageUrl;

      // Show modal
      document.getElementById('presentationModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  }

  function closePresentationModal() {
    document.getElementById('presentationModal').classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

  // Close modal with Escape key
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      closePresentationModal();
    }
  });

  // Image loading fallback system
  document.addEventListener('DOMContentLoaded', function() {
    const fallbackGradients = [
      'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
      'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
      'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
      'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
      'linear-gradient(135deg, #fa709a 0%, #fee140 100%)',
      'linear-gradient(135deg, #a8edea 0%, #fed6e3 100%)'
    ];

    // Test each background image and apply fallback if needed
    const imageElements = document.querySelectorAll('[style*="background-image"]');
    imageElements.forEach((element, index) => {
      const bgImage = element.style.backgroundImage;
      if (bgImage && bgImage.includes('unsplash.com')) {
        const img = new Image();
        const url = bgImage.match(/url\(['"]?([^'"]+)['"]?\)/)?.[1];
        
        if (url) {
          img.onload = function() {
            // Image loaded successfully, keep the Unsplash image
            element.style.backgroundImage = bgImage;
          };
          
          img.onerror = function() {
            // Image failed to load, use fallback gradient
            const gradientIndex = index % fallbackGradients.length;
            element.style.backgroundImage = fallbackGradients[gradientIndex];
            console.log('Fallback applied for failed image:', url);
          };
          
          img.src = url;
        }
      }
    });
  });
</script>
