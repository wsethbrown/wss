<%# The deck library. Char masthead + paper catalog; cards are real links
    (the old page trapped every deck behind a JS-only modal). %>

<!-- Masthead -->
<section class="w-full bg-char px-4 pb-14 pt-28">
  <div class="mx-auto max-w-6xl text-center">
    <p class="eyebrow mb-4 text-whiskey-300/90">The library</p>
    <h1 class="font-display text-4xl font-semibold text-cream md:text-5xl">Whiskey Presentations</h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-cream/70">
      Narrative tasting decks — slides, script, and a bottle list for every budget.
      Pick the story you want to tell.
    </p>
    <% if current_user&.admin? %>
      <p class="mt-4">
        <%= link_to "Manage decks in the admin panel", admin_presentations_path, class: "text-sm font-semibold text-whiskey-300 underline underline-offset-4 hover:text-whiskey-200" %>
      </p>
    <% end %>
  </div>
</section>

<!-- Filters -->
<section class="w-full border-b border-whiskey-100 bg-whiskey-50 px-4 py-6">
  <div class="mx-auto max-w-6xl">
    <%= form_with url: presentations_path, method: :get, local: true, id: "deck-filters", class: "flex flex-col gap-4 md:flex-row md:items-center" do |form| %>
      <div class="relative flex-1">
        <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
        </svg>
        <%= form.search_field :search, value: params[:search], placeholder: "Search decks...",
            class: "w-full rounded-xl border border-whiskey-200 bg-white py-3 pl-12 pr-4 text-gray-900 placeholder-gray-400 focus:border-whiskey-500 focus:outline-none focus:ring-2 focus:ring-whiskey-200" %>
      </div>

      <%# Filter options come from the catalog itself (see controller). %>
      <%= form.select :category,
          options_for_select([['All categories', '']] + @categories.map { |c| [c, c] }, params[:category]),
          {},
          class: "rounded-xl border border-whiskey-200 bg-white px-4 py-3 text-gray-900 focus:border-whiskey-500 focus:outline-none focus:ring-2 focus:ring-whiskey-200" %>

      <% if @difficulties.many? %>
        <%= form.select :difficulty,
            options_for_select([['Any level', '']] + @difficulties.map { |d| [d, d] }, params[:difficulty]),
            {},
            class: "rounded-xl border border-whiskey-200 bg-white px-4 py-3 text-gray-900 focus:border-whiskey-500 focus:outline-none focus:ring-2 focus:ring-whiskey-200" %>
      <% end %>

      <%= form.select :sort,
          options_for_select([
            ['Most popular', 'popular'],
            ['Newest', 'newest'],
            ['Price: low to high', 'price_low'],
            ['Price: high to low', 'price_high']
          ], params[:sort]),
          {},
          class: "rounded-xl border border-whiskey-200 bg-white px-4 py-3 text-gray-900 focus:border-whiskey-500 focus:outline-none focus:ring-2 focus:ring-whiskey-200" %>

      <%= form.submit "Filter", class: "cursor-pointer rounded-xl bg-whiskey-600 px-6 py-3 font-semibold text-white transition hover:bg-whiskey-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2" %>
    <% end %>
  </div>
</section>

<!-- Catalog -->
<section class="w-full bg-white px-4 py-14">
  <div class="mx-auto max-w-6xl">
    <% filtering = params[:search].present? || params[:category].present? || params[:difficulty].present? %>
    <div class="mb-8 flex items-baseline justify-between">
      <p class="text-gray-600">
        <%= pluralize(@presentations.total_count, 'deck') %><%= " matching your filters" if filtering %>
      </p>
      <% if filtering %>
        <%= link_to 'Clear filters', presentations_path, class: 'text-sm font-semibold text-whiskey-700 hover:text-whiskey-600' %>
      <% end %>
    </div>

    <% if @presentations.any? %>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <% @presentations.each do |deck| %>
          <%= render 'presentations/deck_card', deck: deck,
              owned: user_signed_in? && deck.purchased_by?(current_user) %>
        <% end %>
      </div>
      <div class="mt-12">
        <%= paginate @presentations if @presentations.respond_to?(:total_pages) %>
      </div>
    <% elsif @library_empty %>
      <div class="mx-auto max-w-md py-16 text-center">
        <p class="font-display text-2xl font-semibold text-gray-900">The library is being stocked.</p>
        <p class="mt-3 text-gray-600">The first decks are on their way — check back soon, or join a society in the meantime.</p>
        <%= link_to 'Browse societies', societies_path,
            class: 'mt-8 inline-flex items-center justify-center rounded-xl bg-whiskey-600 px-6 py-3 font-semibold text-white transition hover:bg-whiskey-700' %>
      </div>
    <% else %>
      <div class="mx-auto max-w-md py-16 text-center">
        <p class="font-display text-2xl font-semibold text-gray-900">No decks match.</p>
        <p class="mt-3 text-gray-600">Try a different search, or clear the filters to see the whole library.</p>
        <%= link_to 'Show all decks', presentations_path,
            class: 'mt-8 inline-flex items-center justify-center rounded-xl bg-whiskey-600 px-6 py-3 font-semibold text-white transition hover:bg-whiskey-700' %>
      </div>
    <% end %>
  </div>
</section>

<script>
  // Debounced auto-submit keeps the filters live without a dedicated Apply click.
  (function () {
    function initFilters() {
      const form = document.getElementById('deck-filters');
      if (!form) return;
      const search = form.querySelector('input[name="search"]');
      let timer;

      if (search && !search.dataset.bound) {
        search.dataset.bound = 'true';
        search.addEventListener('input', function () {
          clearTimeout(timer);
          timer = setTimeout(function () { form.submit(); }, 500);
        });
      }

      form.querySelectorAll('select').forEach(function (select) {
        if (select.dataset.bound) return;
        select.dataset.bound = 'true';
        select.addEventListener('change', function () { form.submit(); });
      });
    }
    document.addEventListener('turbo:load', initFilters);
    document.addEventListener('DOMContentLoaded', initFilters);
  })();
</script>
