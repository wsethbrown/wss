<%# A deck as a label-style card. Used on the homepage and the library index.
    Locals: deck (Presentation), owned (Boolean, optional) %>
<% owned = local_assigns.fetch(:owned, false) %>
<%= link_to presentation_path(deck), class: 'group block h-full' do %>
  <article class="flex h-full flex-col overflow-hidden rounded-2xl border border-whiskey-200 bg-white shadow-sm transition group-hover:-translate-y-1 group-hover:shadow-md">
    <% if deck.featured_image.attached? %>
      <div class="relative">
        <%= image_tag deck.featured_image, alt: deck.title, class: 'aspect-[16/9] w-full object-cover' %>
        <% if owned %>
          <span class="eyebrow absolute right-3 top-3 rounded-full bg-char/85 px-3 py-1 text-whiskey-200">In your library</span>
        <% end %>
      </div>
    <% else %>
      <%# Typographic cover, like a label. %>
      <div class="relative flex aspect-[16/9] w-full items-center justify-center bg-char px-6 text-center">
        <span class="font-display text-2xl font-semibold leading-snug text-cream"><%= deck.title %></span>
        <% if owned %>
          <span class="eyebrow absolute right-3 top-3 rounded-full border border-whiskey-500/40 bg-whiskey-500/10 px-3 py-1 text-whiskey-200">In your library</span>
        <% end %>
      </div>
    <% end %>
    <div class="flex flex-1 flex-col p-6">
      <p class="eyebrow text-whiskey-600"><%= deck.category.presence || 'Whiskey' %><%= " · #{deck.difficulty}" if deck.difficulty.present? %></p>
      <h3 class="mt-2 font-display text-xl font-semibold text-gray-900"><%= deck.title %></h3>
      <p class="mt-2 line-clamp-3 text-gray-600"><%= deck.excerpt(140) %></p>
      <% if deck.tags.any? %>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <% deck.tags.first(4).each do |tag| %>
            <span class="rounded-full bg-whiskey-100 px-2 py-0.5 text-xs font-medium text-whiskey-800"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>
      <div class="mt-auto flex items-center justify-between pt-6">
        <span class="font-semibold text-gray-900"><%= owned ? 'Read it again' : deck.formatted_price %></span>
        <span class="text-sm font-semibold text-whiskey-700">Read the story →</span>
      </div>
    </div>
  </article>
<% end %>
