<%# locals: pour
    The inside of one pour card. Rendered inside an <a> when the pour is linked
    to a catalog bottle, so it must contain NO links of its own: a nested <a> is
    invalid HTML and swallows the click target the whole card is meant to be. %>
<div class="flex items-baseline justify-between gap-4">
  <h3 class="font-display text-xl font-semibold leading-tight text-gray-900">
    <%= pour.title %>
  </h3>
  <% if pour.price.present? %>
    <span class="shrink-0 rounded-full bg-whiskey-100 px-3 py-1 text-sm font-semibold text-whiskey-800"><%= pour.price %></span>
  <% end %>
</div>

<% if pour.label.present? %>
  <p class="mt-1 text-sm italic text-whiskey-700/80"><%= pour.label %></p>
<% end %>

<% if pour.origin_text.present? %>
  <p class="mt-2 flex items-start gap-1.5 text-sm text-gray-500">
    <svg class="mt-0.5 h-4 w-4 shrink-0 text-whiskey-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"></path>
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
    </svg>
    <span><%= pour.origin_text %></span>
  </p>
<% end %>

<%# Only a catalog-linked pour can carry a score, and it's the bottle's score
    across ALL tastings, not this deck's nights, so it has to say so. %>
<% if pour.linked? && pour.bottle.average_rating.present? %>
  <div class="mt-4 flex items-center gap-2">
    <%= render "bottles/rating", value: pour.bottle.average_rating %>
    <span class="text-xs text-gray-500">overall rating</span>
  </div>
<% end %>

<% if pour.style_text.present? %>
  <div class="mt-5 border-t border-gray-100 pt-4">
    <p class="text-sm leading-relaxed text-gray-600"><%= pour.style_text %></p>
  </div>
<% end %>

<% if pour.notes.present? %>
  <div class="mt-4">
    <p class="eyebrow mb-1 text-whiskey-700/70">Tasting notes</p>
    <p class="text-sm leading-relaxed text-gray-700"><%= pour.notes %></p>
  </div>
<% end %>

<% if pour.linked? %>
  <p class="mt-4 text-sm font-semibold text-whiskey-700">
    See how it scored
    <span aria-hidden="true">&rarr;</span>
  </p>
<% end %>
