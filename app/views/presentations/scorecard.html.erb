<% content_for :title, "#{@presentation.title} — Tasting Scorecard" %>

<div class="no-print sticky top-0 z-10 flex items-center justify-between gap-4 bg-char px-6 py-3">
  <span class="font-sans text-sm text-cream/70">A scorecard for your night — print it, or save as PDF.</span>
  <div class="flex items-center gap-3">
    <%= link_to "← Back to the deck", presentation_path(@presentation), class: "font-sans text-sm text-cream/70 hover:text-cream" %>
    <button onclick="window.print()" class="rounded-lg bg-whiskey-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-whiskey-400">Print / Save as PDF</button>
  </div>
</div>

<%# The deck's own pours, pre-filled. %>
<div class="sheet mx-auto my-8 w-full max-w-[8.5in] bg-white px-10 py-8">
  <%= render "presentations/scorecard_sheet", presentation: @presentation, pours: @pours, blank: false %>
</div>

<%# A blank card for a group pouring their own bottles. Always offered; if the
    deck has no pour list, the blank card is all there is. %>
<div class="sheet <%= "page-break" if @pours.any? %> mx-auto my-8 w-full max-w-[8.5in] bg-white px-10 py-8">
  <%= render "presentations/scorecard_sheet", presentation: @presentation, pours: [], blank: true %>
</div>
