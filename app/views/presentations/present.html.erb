<!DOCTYPE html>
<html>
<head>
  <title>Presenting: <%= @presentation.title %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    html, body { margin: 0; height: 100%; background: #000; overflow: hidden;
                 font-family: ui-sans-serif, system-ui, sans-serif; }
    .slide { position: absolute; inset: 0; display: none; align-items: center; justify-content: center; }
    .slide.active { display: flex; }
    .slide img { max-width: 100vw; max-height: 100vh; object-fit: contain; }
    .hud { position: fixed; bottom: 16px; right: 20px; color: rgba(246,237,218,.55);
           font-size: 13px; letter-spacing: .08em; z-index: 2; }
    .exit { position: fixed; top: 14px; right: 20px; color: rgba(246,237,218,.55);
            text-decoration: none; font-size: 13px; z-index: 2; }
    .exit:hover, .hud:hover { color: rgba(246,237,218,.9); }
  </style>
</head>
<body>
  <% slides = @presentation.slide_images.order(:id) %>
  <% slides.each_with_index do |slide, i| %>
    <div class="slide <%= 'active' if i.zero? %>"><%= image_tag slide, alt: "Slide #{i + 1}", loading: i < 3 ? 'eager' : 'lazy' %></div>
  <% end %>
  <a class="exit" href="<%= presentation_path(@presentation) %>">esc, exit</a>
  <div class="hud"><span id="n">1</span> / <%= slides.size %></div>
  <script>
    const slides = document.querySelectorAll('.slide'), n = document.getElementById('n');
    let i = 0;
    function go(d) {
      slides[i].classList.remove('active');
      i = Math.min(Math.max(i + d, 0), slides.length - 1);
      slides[i].classList.add('active');
      n.textContent = i + 1;
    }
    document.addEventListener('keydown', e => {
      if (['ArrowRight', ' ', 'PageDown'].includes(e.key)) { e.preventDefault(); go(1); }
      else if (['ArrowLeft', 'PageUp'].includes(e.key)) { e.preventDefault(); go(-1); }
      else if (e.key === 'Escape') location.href = '<%= presentation_path(@presentation) %>';
      else if (e.key === 'f') document.documentElement.requestFullscreen?.();
    });
    document.addEventListener('click', e => { if (!e.target.closest('a')) go(1); });
  </script>
</body>
</html>
