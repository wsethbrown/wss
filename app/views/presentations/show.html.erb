<!-- Purchase Status Messages -->
<% if params[:purchase] == 'success' %>
  <div class="max-w-2xl mx-auto pt-24 px-4">
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 px-4 py-3 text-center shadow">
      🎉 Purchase successful! You now have access to this presentation.
    </div>
  </div>
<% elsif params[:purchase] == 'cancelled' %>
  <div class="max-w-2xl mx-auto pt-24 px-4">
    <div class="mb-4 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 text-center shadow">
      Purchase cancelled. You can try again anytime.
    </div>
  </div>
<% end %>

<!-- Hero Section -->
<div class="relative min-h-[60vh] flex flex-col items-center justify-center text-center overflow-hidden bg-cover bg-center bg-gray-800 w-full" style="background-image: url('<%= @presentation.featured_image.attached? ? url_for(@presentation.featured_image) : 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?w=1200&h=600&fit=crop&crop=center' %>')">
  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/30"></div>
  <div class="absolute inset-0 pointer-events-none">
    <div class="w-full h-full rounded-[3rem] bg-white/20 blur-3xl opacity-60 mx-auto mt-16"></div>
  </div>
  <div class="relative z-10 px-4 py-24 w-full flex flex-col items-center justify-center">
    <div class="max-w-4xl mx-auto">
      <!-- Category Badge -->
      <% if @presentation.category.present? %>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/20 backdrop-blur-sm border border-white/30 text-white font-semibold text-sm mb-6">
          <span class="w-2 h-2 bg-white rounded-full"></span>
          <%= @presentation.category %>
        </div>
      <% end %>

      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6 leading-tight">
        <%= @presentation.title %>
      </h1>
      <p class="text-xl md:text-2xl text-white/90 mb-8 font-medium max-w-3xl mx-auto">
        <%= @presentation.description %>
      </p>

      <!-- Quick Stats -->
      <div class="flex flex-wrap justify-center gap-8 mb-8">
        <% if @presentation.duration.present? %>
          <div class="flex items-center gap-2 text-white/90">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-semibold"><%= @presentation.duration %></span>
          </div>
        <% end %>
        <% if @presentation.rating.present? %>
          <div class="flex items-center gap-2 text-white/90">
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <span class="font-semibold"><%= @presentation.rating %> (<%= @presentation.review_count || 0 %> reviews)</span>
          </div>
        <% end %>
        <% if @presentation.difficulty.present? %>
          <div class="flex items-center gap-2 text-white/90">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            <span class="font-semibold"><%= @presentation.difficulty %> Level</span>
          </div>
        <% end %>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <% if user_signed_in? && @presentation.purchased_by?(current_user) %>
          <div class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-green-600 text-white text-lg font-bold shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            You Own This Presentation
          </div>
        <% else %>
          <%= link_to new_presentation_purchase_path(@presentation), class: "inline-flex items-center gap-3 px-8 py-4 rounded-full bg-gradient-to-r from-amber-400 to-orange-500 text-white text-lg font-bold shadow-lg hover:from-amber-500 hover:to-orange-600 transition-all duration-300 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-amber-400" do %>
            <span class="text-xl filter drop-shadow-md">🛒</span>
            Purchase for <%= @presentation.formatted_price %>
          <% end %>
        <% end %>
        <button class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-white/20 backdrop-blur-sm text-white text-lg font-bold shadow-lg hover:bg-white/30 transition focus:outline-none focus:ring-2 focus:ring-white/50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          Add to Wishlist
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="relative w-full bg-white">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Left Column - Main Content -->
      <div class="lg:col-span-2">
        <!-- What You'll Learn -->
        <% if @presentation.parsed_what_youll_learn.any? %>
          <section class="mb-16">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">What You'll Learn</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% @presentation.parsed_what_youll_learn.each_with_index do |point, index| %>
                <% colors = ['blue', 'green', 'purple', 'amber'] %>
                <% color = colors[index % colors.length] %>
                <div class="flex items-start gap-4 p-6 rounded-2xl bg-<%= color %>-50 border border-<%= color %>-100">
                  <div class="w-8 h-8 bg-<%= color %>-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <% if point.is_a?(Hash) && point[:title] %>
                      <h3 class="font-semibold text-gray-900 mb-2"><%= point[:title] %></h3>
                      <% if point[:description].present? %>
                        <p class="text-gray-600 text-sm"><%= point[:description] %></p>
                      <% end %>
                    <% else %>
                      <p class="text-gray-900"><%= point %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% elsif Rails.env.development? %>
          <!-- Show hardcoded version in development if no data -->
          <section class="mb-16">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">What You'll Learn</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-blue-50 border border-blue-100">
              <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">Scotch Whisky Basics</h3>
                <p class="text-gray-600 text-sm">Understand the fundamental differences between Scotch and other whiskies, including production methods and legal requirements.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-green-50 border border-green-100">
              <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">Regional Differences</h3>
                <p class="text-gray-600 text-sm">Explore the six main Scotch regions and learn how geography and tradition shape each area's unique flavor profile.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-purple-50 border border-purple-100">
              <div class="w-8 h-8 bg-purple-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">Tasting Techniques</h3>
                <p class="text-gray-600 text-sm">Master the proper way to taste Scotch whisky, from nosing to palate evaluation and finish assessment.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-amber-50 border border-amber-100">
              <div class="w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">Age Statements & Quality</h3>
                <p class="text-gray-600 text-sm">Learn to read labels, understand age statements, and identify quality indicators when selecting Scotch whisky.</p>
              </div>
            </div>
          </div>
        </section>
        <% end %>

        <!-- The Story — narrative deck content, rendered from Markdown -->
        <section class="mb-16" id="deck-story">
          <p class="eyebrow text-whiskey-600 mb-2">The story</p>
          <h2 class="font-display text-3xl font-semibold text-gray-900 mb-3">Inside this deck</h2>
          <div class="rule-double text-whiskey-800 mb-10"></div>

          <div class="relative pl-6 md:pl-10">
            <%# The thread: a thin amber line that fills as you read — the narrative
                spine connecting the pour to its story. %>
            <div class="absolute left-0 top-1 bottom-1 w-[2px] rounded bg-whiskey-100" aria-hidden="true">
              <div id="deck-thread" class="w-full rounded bg-gradient-to-b from-whiskey-300 to-whiskey-600 transition-[height] duration-150 ease-out" style="height: 0%"></div>
            </div>

            <% if @presentation.content.present? %>
              <div class="prose-deck prose-deck--dropcap">
                <%= render_markdown(@presentation.content) %>
              </div>
            <% else %>
              <p class="prose-deck"><%= @presentation.description %></p>
            <% end %>
          </div>
        </section>

        <script>
          // Fill the story thread to match reading progress through the section.
          (function () {
            function initDeckThread() {
              const story = document.getElementById('deck-story');
              const thread = document.getElementById('deck-thread');
              if (!story || !thread) return;

              function update() {
                const rect = story.getBoundingClientRect();
                const viewport = window.innerHeight;
                const total = rect.height - viewport * 0.5;
                const progress = total > 0 ? Math.min(1, Math.max(0, (viewport * 0.5 - rect.top) / total)) : 1;
                thread.style.height = (progress * 100).toFixed(1) + '%';
              }

              update();
              window.addEventListener('scroll', update, { passive: true });
              window.addEventListener('resize', update, { passive: true });
            }
            document.addEventListener('turbo:load', initDeckThread);
            document.addEventListener('DOMContentLoaded', initDeckThread);
          })();
        </script>

        <!-- Tasting Notes (if present) — set like the back of a label -->
        <% if @presentation.nose_notes.present? || @presentation.palate_notes.present? || @presentation.finish_notes.present? || @presentation.body_notes.present? %>
          <section class="mb-16">
            <p class="eyebrow text-whiskey-600 mb-2">Tasting notes</p>
            <h2 class="font-display text-3xl font-semibold text-gray-900 mb-3">What you'll taste</h2>
            <div class="rule-double text-whiskey-800 mb-8"></div>
            <div class="rounded-2xl border border-whiskey-200 bg-whiskey-50 p-8">
              <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6">
                <% {
                  "Nose"   => @presentation.nose_notes,
                  "Palate" => @presentation.palate_notes,
                  "Finish" => @presentation.finish_notes,
                  "Body"   => @presentation.body_notes
                }.each do |label, notes| %>
                  <% next if notes.blank? %>
                  <div>
                    <dt class="eyebrow text-whiskey-700 mb-1"><%= label %></dt>
                    <dd class="font-reading text-lg text-gray-800 leading-relaxed"><%= notes %></dd>
                  </div>
                <% end %>
              </dl>
            </div>
          </section>
        <% end %>

        <!-- Preview Images (if present) -->
        <% if @presentation.preview_images.attached? %>
          <section class="mb-16">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Preview</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <% @presentation.ordered_preview_images.each_with_index do |image, index| %>
                <div class="relative group cursor-pointer">
                  <%= image_tag image, class: "w-full rounded-2xl shadow-lg hover:shadow-xl transition-shadow", alt: "Preview #{index + 1}" %>
                  <div class="absolute top-4 left-4 bg-black/70 text-white px-3 py-1 rounded-full text-sm font-semibold">
                    Slide <%= index + 1 %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <!-- Slides Preview -->
        <% if @presentation.parsed_slides_preview.any? %>
          <section class="mb-16">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Slides Preview</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% @presentation.parsed_slides_preview.each_with_index do |slide, index| %>
                <div class="group relative bg-gray-50 rounded-2xl p-6 hover:bg-gray-100 transition-all duration-200 cursor-pointer">
                  <div class="flex items-start justify-between mb-3">
                    <span class="text-sm font-semibold text-blue-600"><%= slide[:slide_number] %></span>
                    <span class="text-sm text-gray-500"><%= slide[:duration] %></span>
                  </div>
                  <h3 class="font-bold text-gray-900 mb-2"><%= slide[:title] %></h3>
                  <p class="text-gray-600 text-sm"><%= slide[:description] %></p>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <!-- Whiskey Recommendations -->
        <% if @presentation.parsed_whiskey_recommendations.any? %>
          <section class="mb-16">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Recommended Whiskeys</h2>
            <p class="text-gray-700 mb-8">These carefully selected bottles are perfect for tasting alongside this presentation. Each represents a different region and style of <%= @presentation.category || 'whiskey' %>.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% @presentation.parsed_whiskey_recommendations.each do |whiskey| %>
                <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
                  <div class="flex items-start justify-between mb-3">
                    <h3 class="font-bold text-gray-900"><%= whiskey[:name] %></h3>
                    <span class="text-lg font-bold text-blue-600"><%= whiskey[:price] || whiskey[:price_range] %></span>
                  </div>
                  <div class="space-y-2 text-sm">
                    <div class="flex items-center gap-2">
                      <span class="font-semibold text-gray-700">Region:</span>
                      <span class="text-gray-600"><%= whiskey[:region] %></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class="font-semibold text-gray-700">Style:</span>
                      <span class="text-gray-600"><%= whiskey[:style] || whiskey[:description] %></span>
                    </div>
                    <% if whiskey[:notes].present? %>
                      <div class="flex items-center gap-2">
                        <span class="font-semibold text-gray-700">Notes:</span>
                        <span class="text-gray-600"><%= whiskey[:notes] %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <%# Reviews intentionally removed: the previous section rendered hard-coded
            fictional testimonials. When a real Review model exists, rebuild here. %>
      </div>

      <!-- Right Column - Sidebar -->
      <div class="lg:col-span-1">
        <!-- Purchase Card -->
        <div class="sticky top-8">
          <div class="bg-white border border-gray-200 rounded-3xl shadow-xl p-8">
            <div class="text-center mb-6">
              <% if user_signed_in? && @presentation.purchased_by?(current_user) %>
                <% purchase = current_user.user_presentations.find_by(presentation_id: @presentation.id) %>
                <% if purchase&.purchase_type == 'credit' && !current_user.subscription_active? %>
                  <div class="text-3xl font-bold text-amber-600 mb-2">Subscription Required</div>
                  <p class="text-gray-600">You own this presentation</p>
                  <p class="text-sm text-amber-600 mt-2">Reactivate your subscription to access</p>
                <% else %>
                  <div class="text-4xl font-bold text-green-600 mb-2">Already Purchased</div>
                  <p class="text-gray-600">You have access to this presentation</p>
                <% end %>
              <% else %>
                <div class="text-4xl font-bold text-gray-900 mb-2"><%= @presentation.formatted_price %></div>
                <p class="text-gray-600">One-time purchase</p>
              <% end %>
            </div>

            <div class="space-y-4 mb-8">
              <% if @presentation.duration.present? %>
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-700"><%= @presentation.duration %> presentation</span>
                </div>
              <% end %>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">Professional content</span>
              </div>
              <% if @presentation.difficulty.present? %>
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-700"><%= @presentation.difficulty %> level</span>
                </div>
              <% end %>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">Lifetime access</span>
              </div>
            </div>

            <% if user_signed_in? && @presentation.purchased_by?(current_user) %>
              <!-- Already purchased -->
              <% purchase = current_user.user_presentations.find_by(presentation_id: @presentation.id) %>
              
              <% if purchase&.purchase_type == 'credit' && !current_user.subscription_active? %>
                <!-- Owns via credit but subscription inactive -->
                <div class="w-full bg-amber-100 text-amber-800 font-bold py-4 px-6 rounded-2xl mb-4 text-center">
                  <div class="flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                    <span>Subscription Required</span>
                  </div>
                  <div class="text-sm mt-1">
                    You purchased this with a credit
                  </div>
                </div>
                
                <%= link_to subscriptions_plans_path, class: "block w-full bg-amber-600 text-white font-bold py-4 px-6 rounded-2xl hover:bg-amber-700 transition mb-4 text-center" do %>
                  Reactivate Subscription
                <% end %>
              <% else %>
                <!-- Has access (direct purchase or active subscription) -->
                <div class="w-full bg-green-100 text-green-800 font-bold py-4 px-6 rounded-2xl mb-4 text-center">
                  <div class="flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>You Own This</span>
                  </div>
                  <div class="text-sm mt-1">
                    <%= purchase&.purchase_type == 'direct' ? 'Lifetime access' : 'Access via subscription' %>
                  </div>
                </div>
                
                <!-- Downloads Section -->
                <div class="bg-gray-50 rounded-2xl p-4 mb-4">
                  <h4 class="font-semibold text-gray-900 mb-3 text-sm">Available Downloads</h4>
                  <div class="space-y-2">
                    <% if @presentation.pdf_file.attached? %>
                      <%= link_to full_presentation_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-blue-500 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Full Presentation</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    
                    <% if @presentation.speaker_notes.attached? %>
                      <%= link_to speaker_notes_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-blue-500 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Speaker Notes</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    
                    <% if @presentation.outline_file.attached? %>
                      <%= link_to outline_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-blue-500 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Outline</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    
                    <% if @presentation.recommendations_sheet.attached? %>
                      <%= link_to recommendations_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-blue-500 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Whiskey List</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <!-- Not purchased yet -->
              <%= link_to new_presentation_purchase_path(@presentation), class: "block w-full bg-black text-white font-bold py-4 px-6 rounded-2xl hover:bg-blue-800 transition mb-4 text-center" do %>
                Purchase Now
              <% end %>
            <% end %>

            <button class="w-full bg-gray-100 text-gray-700 font-bold py-4 px-6 rounded-2xl hover:bg-gray-200 transition mb-4">
              Add to Wishlist
            </button>

            <div class="text-center">
              <p class="text-sm text-gray-500">30-day money-back guarantee</p>
            </div>
            
            <!-- Sneak Peek Available to All -->
            <% if @presentation.sneak_peek_file.attached? %>
              <div class="mt-4 pt-4 border-t border-gray-200">
                <%= link_to sneak_peek_presentation_downloads_path(@presentation), 
                    class: "flex items-center justify-center gap-2 text-sm text-blue-600 hover:text-blue-800 font-medium" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                  </svg>
                  View Free Preview
                <% end %>
              </div>
            <% end %>
          </div>

          <!-- Author Info -->
          <div class="bg-gray-50 rounded-2xl p-6 mt-6">
            <h3 class="font-bold text-gray-900 mb-4">About the Author</h3>
            <div class="flex items-center gap-4">
              <% if @presentation.author.profile_image.attached? %>
                <%= image_tag @presentation.author.profile_image, class: "w-12 h-12 rounded-full object-cover" %>
              <% else %>
                <div class="w-12 h-12 bg-blue-500 rounded-full flex items-center justify-center">
                  <span class="text-white font-bold"><%= @presentation.author.first_name.first %><%= @presentation.author.last_name.first if @presentation.author.last_name.present? %></span>
                </div>
              <% end %>
              <div>
                <h4 class="font-semibold text-gray-900"><%= @presentation.author.full_name %></h4>
                <p class="text-sm text-gray-600">Presentation Author</p>
                <% if @presentation.author.bio.present? %>
                  <p class="text-xs text-gray-500"><%= @presentation.author.bio.truncate(50) %></p>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
