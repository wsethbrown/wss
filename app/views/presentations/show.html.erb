<!-- Purchase Status Messages -->
<% if params[:purchase] == 'success' %>
  <div class="max-w-2xl mx-auto pt-24 px-4">
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 px-4 py-3 text-center shadow">
      🎉 Purchase successful! You now have access to this presentation.
    </div>
  </div>
<% elsif params[:purchase] == 'cancelled' %>
  <div class="max-w-2xl mx-auto pt-24 px-4">
    <div class="mb-4 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 text-center shadow">
      Purchase cancelled. You can try again anytime.
    </div>
  </div>
<% end %>

<!-- Hero: the deck's cover. Featured image when present, otherwise the char label. -->
<div class="relative flex min-h-[60vh] w-full flex-col items-center justify-center overflow-hidden bg-char pt-16 text-center <%= 'bg-cover bg-center' if @presentation.featured_image.attached? %>"
     <% if @presentation.featured_image.attached? %>style="background-image: url('<%= url_for(@presentation.featured_image) %>')"<% end %>>
  <% if @presentation.featured_image.attached? %>
    <div class="absolute inset-0 bg-gradient-to-t from-char via-char/60 to-char/40"></div>
  <% else %>
    <div class="pointer-events-none absolute inset-0" aria-hidden="true"
         style="background: radial-gradient(ellipse 70% 45% at 50% 108%, rgba(201, 136, 74, 0.25), transparent 70%);"></div>
  <% end %>

  <div class="relative z-10 mx-auto max-w-4xl px-4 py-20">
    <p class="eyebrow mb-4 text-whiskey-300/90">
      <%= [@presentation.category.presence, @presentation.difficulty.presence, @presentation.duration.presence].compact.join(' · ') %>
    </p>
    <div class="rule-double mx-auto mb-8 w-20 text-whiskey-300"></div>

    <h1 class="font-display text-4xl font-semibold leading-tight text-cream md:text-6xl">
      <%= @presentation.title %>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-cream/70 md:text-xl">
      <%= @presentation.description %>
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <% if user_signed_in? && @presentation.purchased_by?(current_user) %>
        <a href="#deck-story" class="inline-flex items-center justify-center gap-2 rounded-xl bg-whiskey-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-whiskey-950/40 transition hover:bg-whiskey-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char">
          Start reading
        </a>
      <% else %>
        <%= link_to new_presentation_purchase_path(@presentation),
            class: "inline-flex items-center justify-center gap-2 rounded-xl bg-whiskey-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-whiskey-950/40 transition hover:bg-whiskey-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char" do %>
          <%= @presentation.free? ? 'Add to my library — free' : "Get this deck — #{@presentation.formatted_price}" %>
        <% end %>
      <% end %>
      <% if @presentation.sneak_peek_file.attached? %>
        <%= link_to sneak_peek_presentation_downloads_path(@presentation),
            class: "inline-flex items-center justify-center gap-2 rounded-xl border border-cream/25 px-7 py-3.5 text-base font-semibold text-cream/90 transition hover:border-cream/50 hover:text-cream focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-300 focus-visible:ring-offset-2 focus-visible:ring-offset-char" do %>
          Preview the deck
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="relative w-full bg-white">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Left Column - Main Content -->
      <div class="lg:col-span-2">
        <!-- What You'll Learn -->
        <% if @presentation.parsed_what_youll_learn.any? %>
          <section class="mb-16">
            <p class="eyebrow text-whiskey-600 mb-2">The takeaways</p>
            <h2 class="font-display text-3xl font-semibold text-gray-900 mb-3">What you'll learn</h2>
            <div class="rule-double text-whiskey-800 mb-8"></div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% @presentation.parsed_what_youll_learn.each do |point| %>
                <div class="flex items-start gap-4 p-6 rounded-2xl bg-whiskey-50 border border-whiskey-100">
                  <div class="w-8 h-8 bg-whiskey-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <% if point.is_a?(Hash) && point[:title] %>
                      <h3 class="font-semibold text-gray-900 mb-2"><%= point[:title] %></h3>
                      <% if point[:description].present? %>
                        <p class="text-gray-600 text-sm"><%= point[:description] %></p>
                      <% end %>
                    <% else %>
                      <p class="text-gray-900"><%= point %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <!-- The Story — narrative deck content, rendered from Markdown -->
        <section class="mb-16" id="deck-story">
          <p class="eyebrow text-whiskey-600 mb-2">The story</p>
          <h2 class="font-display text-3xl font-semibold text-gray-900 mb-3">Inside this deck</h2>
          <div class="rule-double text-whiskey-800 mb-10"></div>

          <div class="relative pl-6 md:pl-10">
            <%# The thread: a thin amber line that fills as you read — the narrative
                spine connecting the pour to its story. %>
            <div class="absolute left-0 top-1 bottom-1 w-[2px] rounded bg-whiskey-100" aria-hidden="true">
              <div id="deck-thread" class="w-full rounded bg-gradient-to-b from-whiskey-300 to-whiskey-600 transition-[height] duration-150 ease-out" style="height: 0%"></div>
            </div>

            <% if @presentation.content.present? %>
              <div class="prose-deck prose-deck--dropcap">
                <%= render_markdown(@presentation.content) %>
              </div>
            <% else %>
              <p class="prose-deck"><%= @presentation.description %></p>
            <% end %>
          </div>
        </section>

        <script>
          // Fill the story thread to match reading progress through the section.
          (function () {
            function initDeckThread() {
              const story = document.getElementById('deck-story');
              const thread = document.getElementById('deck-thread');
              if (!story || !thread) return;

              function update() {
                const rect = story.getBoundingClientRect();
                const viewport = window.innerHeight;
                const total = rect.height - viewport * 0.5;
                const progress = total > 0 ? Math.min(1, Math.max(0, (viewport * 0.5 - rect.top) / total)) : 1;
                thread.style.height = (progress * 100).toFixed(1) + '%';
              }

              update();
              window.addEventListener('scroll', update, { passive: true });
              window.addEventListener('resize', update, { passive: true });
            }
            document.addEventListener('turbo:load', initDeckThread);
            document.addEventListener('DOMContentLoaded', initDeckThread);
          })();
        </script>

        <!-- Tasting Notes (if present) — set like the back of a label -->
        <% if @presentation.nose_notes.present? || @presentation.palate_notes.present? || @presentation.finish_notes.present? || @presentation.body_notes.present? %>
          <section class="mb-16">
            <p class="eyebrow text-whiskey-600 mb-2">Tasting notes</p>
            <h2 class="font-display text-3xl font-semibold text-gray-900 mb-3">What you'll taste</h2>
            <div class="rule-double text-whiskey-800 mb-8"></div>
            <div class="rounded-2xl border border-whiskey-200 bg-whiskey-50 p-8">
              <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6">
                <% {
                  "Nose"   => @presentation.nose_notes,
                  "Palate" => @presentation.palate_notes,
                  "Finish" => @presentation.finish_notes,
                  "Body"   => @presentation.body_notes
                }.each do |label, notes| %>
                  <% next if notes.blank? %>
                  <div>
                    <dt class="eyebrow text-whiskey-700 mb-1"><%= label %></dt>
                    <dd class="font-reading text-lg text-gray-800 leading-relaxed"><%= notes %></dd>
                  </div>
                <% end %>
              </dl>
            </div>
          </section>
        <% end %>

        <!-- Preview Images (if present) -->
        <% if @presentation.preview_images.attached? %>
          <section class="mb-16">
            <h2 class="font-display text-3xl font-semibold text-gray-900 mb-8">Preview</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <% @presentation.ordered_preview_images.each_with_index do |image, index| %>
                <div class="relative group cursor-pointer">
                  <%= image_tag image, class: "w-full rounded-2xl shadow-lg hover:shadow-xl transition-shadow", alt: "Preview #{index + 1}" %>
                  <div class="absolute top-4 left-4 bg-black/70 text-white px-3 py-1 rounded-full text-sm font-semibold">
                    Slide <%= index + 1 %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <!-- Slides Preview -->
        <% if @presentation.parsed_slides_preview.any? %>
          <section class="mb-16">
            <h2 class="font-display text-3xl font-semibold text-gray-900 mb-8">Slides Preview</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% @presentation.parsed_slides_preview.each_with_index do |slide, index| %>
                <div class="group relative bg-gray-50 rounded-2xl p-6 hover:bg-gray-100 transition-all duration-200 cursor-pointer">
                  <div class="flex items-start justify-between mb-3">
                    <span class="text-sm font-semibold text-whiskey-600"><%= slide[:slide_number] %></span>
                    <span class="text-sm text-gray-500"><%= slide[:duration] %></span>
                  </div>
                  <h3 class="font-bold text-gray-900 mb-2"><%= slide[:title] %></h3>
                  <p class="text-gray-600 text-sm"><%= slide[:description] %></p>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <!-- Whiskey Recommendations -->
        <% if @presentation.parsed_whiskey_recommendations.any? %>
          <section class="mb-16">
            <h2 class="font-display text-3xl font-semibold text-gray-900 mb-8">Recommended Whiskeys</h2>
            <p class="text-gray-700 mb-8">These carefully selected bottles are perfect for tasting alongside this presentation. Each represents a different region and style of <%= @presentation.category || 'whiskey' %>.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% @presentation.parsed_whiskey_recommendations.each do |whiskey| %>
                <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
                  <div class="flex items-start justify-between mb-3">
                    <h3 class="font-bold text-gray-900"><%= whiskey[:name] %></h3>
                    <span class="text-lg font-bold text-whiskey-700"><%= whiskey[:price] || whiskey[:price_range] %></span>
                  </div>
                  <div class="space-y-2 text-sm">
                    <div class="flex items-center gap-2">
                      <span class="font-semibold text-gray-700">Region:</span>
                      <span class="text-gray-600"><%= whiskey[:region] %></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class="font-semibold text-gray-700">Style:</span>
                      <span class="text-gray-600"><%= whiskey[:style] || whiskey[:description] %></span>
                    </div>
                    <% if whiskey[:notes].present? %>
                      <div class="flex items-center gap-2">
                        <span class="font-semibold text-gray-700">Notes:</span>
                        <span class="text-gray-600"><%= whiskey[:notes] %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <%# Reviews intentionally removed: the previous section rendered hard-coded
            fictional testimonials. When a real Review model exists, rebuild here. %>
      </div>

      <!-- Right Column - Sidebar -->
      <div class="lg:col-span-1">
        <!-- Purchase Card -->
        <div class="sticky top-8">
          <div class="bg-white border border-whiskey-200 rounded-3xl shadow-xl p-8">
            <div class="text-center mb-6">
              <% owned_purchase = user_signed_in? ? current_user.user_presentations.find_by(presentation_id: @presentation.id) : nil %>
              <% if owned_purchase %>
                <% if owned_purchase.purchase_type == 'credit' && !current_user.subscription_active? %>
                  <p class="eyebrow text-whiskey-600 mb-2">In your library</p>
                  <div class="font-display text-3xl font-semibold text-gray-900 mb-2">Membership paused</div>
                  <p class="text-gray-600">You unlocked this deck with a credit — reactivate to read it again.</p>
                <% else %>
                  <p class="eyebrow text-whiskey-600 mb-2">In your library</p>
                  <div class="font-display text-3xl font-semibold text-gray-900 mb-2"><%= owned_purchase.purchase_type == 'direct' ? 'Yours for good' : 'Unlocked' %></div>
                  <p class="text-gray-600"><%= owned_purchase.purchase_type == 'direct' ? 'Bought outright — lifetime access.' : 'Unlocked with a credit via your membership.' %></p>
                <% end %>
              <% else %>
                <div class="font-display text-4xl font-semibold text-gray-900 mb-1"><%= @presentation.formatted_price %></div>
                <p class="text-gray-600"><%= @presentation.free? ? 'Free for everyone' : 'One-time purchase' %></p>
                <% if user_signed_in? && current_user.subscription_active? && current_user.credits > 0 && !@presentation.free? %>
                  <p class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-whiskey-100 px-3 py-1 text-sm font-semibold text-whiskey-800">
                    or 1 credit — you have <%= current_user.credits %>
                  </p>
                <% end %>
              <% end %>
            </div>

            <div class="space-y-4 mb-8">
              <% if @presentation.duration.present? %>
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-whiskey-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-700"><%= @presentation.duration %> presentation</span>
                </div>
              <% end %>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-whiskey-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">Professional content</span>
              </div>
              <% if @presentation.difficulty.present? %>
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-whiskey-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-700"><%= @presentation.difficulty %> level</span>
                </div>
              <% end %>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-whiskey-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">
                  <%# Honest access terms: credit unlocks last as long as the membership;
                      direct purchases (and unowned decks bought outright) are forever. %>
                  <%= owned_purchase&.purchase_type == 'credit' ? 'Access with your membership' : 'Lifetime access when bought outright' %>
                </span>
              </div>
            </div>

            <% if owned_purchase %>
              <% if owned_purchase.purchase_type == 'credit' && !current_user.subscription_active? %>
                <!-- Owns via credit but subscription inactive -->
                <%= link_to root_path(anchor: 'pricing'), class: "block w-full bg-whiskey-600 text-white font-semibold py-4 px-6 rounded-2xl hover:bg-whiskey-700 transition mb-4 text-center" do %>
                  Reactivate membership
                <% end %>
              <% else %>
                <!-- Downloads Section -->
                <div class="bg-whiskey-50 rounded-2xl p-4 mb-4">
                  <h4 class="eyebrow text-whiskey-700 mb-3">Downloads</h4>
                  <div class="space-y-2">
                    <% if @presentation.pdf_file.attached? %>
                      <%= link_to full_presentation_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-whiskey-400 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Full Presentation</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    
                    <% if @presentation.speaker_notes.attached? %>
                      <%= link_to speaker_notes_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-whiskey-400 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Speaker Notes</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    
                    <% if @presentation.outline_file.attached? %>
                      <%= link_to outline_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-whiskey-400 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Outline</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    
                    <% if @presentation.recommendations_sheet.attached? %>
                      <%= link_to recommendations_presentation_downloads_path(@presentation), 
                          class: "flex items-center justify-between p-2 bg-white border border-gray-200 rounded-lg hover:border-whiskey-400 transition text-sm" do %>
                        <span class="font-medium text-gray-700">Whiskey List</span>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% elsif user_signed_in? %>
              <!-- Not purchased yet -->
              <%= link_to new_presentation_purchase_path(@presentation), class: "block w-full bg-whiskey-600 text-white font-semibold py-4 px-6 rounded-2xl hover:bg-whiskey-700 transition mb-4 text-center" do %>
                <%= @presentation.free? ? 'Add to my library' : 'Get this deck' %>
              <% end %>
            <% else %>
              <!-- Signed out -->
              <%= link_to auth_path, class: "block w-full bg-whiskey-600 text-white font-semibold py-4 px-6 rounded-2xl hover:bg-whiskey-700 transition mb-4 text-center" do %>
                Sign in to get this deck
              <% end %>
            <% end %>

            <!-- Sneak Peek Available to All -->
            <% if @presentation.sneak_peek_file.attached? %>
              <div class="mt-4 pt-4 border-t border-gray-200">
                <%= link_to sneak_peek_presentation_downloads_path(@presentation), 
                    class: "flex items-center justify-center gap-2 text-sm text-whiskey-700 hover:text-whiskey-600 font-medium" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                  </svg>
                  View Free Preview
                <% end %>
              </div>
            <% end %>
          </div>

          <!-- Author Info -->
          <div class="bg-gray-50 rounded-2xl p-6 mt-6">
            <h3 class="font-bold text-gray-900 mb-4">About the Author</h3>
            <div class="flex items-center gap-4">
              <% if @presentation.author.profile_image.attached? %>
                <%= image_tag @presentation.author.profile_image, class: "w-12 h-12 rounded-full object-cover" %>
              <% else %>
                <div class="w-12 h-12 bg-whiskey-600 rounded-full flex items-center justify-center">
                  <span class="text-white font-bold"><%= @presentation.author.first_name.first %><%= @presentation.author.last_name.first if @presentation.author.last_name.present? %></span>
                </div>
              <% end %>
              <div>
                <h4 class="font-semibold text-gray-900"><%= @presentation.author.full_name %></h4>
                <p class="text-sm text-gray-600">Presentation Author</p>
                <% if @presentation.author.bio.present? %>
                  <p class="text-xs text-gray-500"><%= @presentation.author.bio.truncate(50) %></p>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
