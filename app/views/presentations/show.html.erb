            <%= form.hidden_field :purchase_type, value: 'credit' %>
            <%= form.submit "Purchase with Credit", class: "w-full bg-green-600 text-white font-bold py-3 rounded-xl hover:bg-green-700 transition", onclick: "console.log('Credit purchase clicked'); console.log('Form action:', this.form.action); return true;" %>
          <% end %>
        </div>
      <% elsif current_user.has_active_subscription? %>
        <div class="mb-4 p-4 border-2 border-gray-200 rounded-2xl bg-gray-50">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gray-400 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4zM18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-600">Use Credit</h4>
                <p class="text-sm text-gray-500">No credits remaining</p>
              </div>
            </div>
            <div class="text-right">
              <div class="text-lg font-bold text-gray-600">1 Credit</div>
              <div class="text-xs text-gray-500">0 remaining</div>
            </div>
          </div>
          <button disabled class="w-full bg-gray-300 text-gray-500 font-bold py-3 rounded-xl cursor-not-allowed">
            No Credits Available
          </button>
        </div>
      <% end %>

      <!-- Direct Purchase Option -->
      <div class="p-4 border-2 border-blue-200 rounded-2xl bg-blue-50">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4zM18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z"></path>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-blue-800">Purchase Directly</h4>
              <p class="text-sm text-blue-600">Lifetime access, no subscription needed</p>
            </div>
          </div>
          <div class="text-right">
            <div class="text-lg font-bold text-blue-800"><%= @presentation.formatted_price %></div>
            <div class="text-xs text-blue-600">One-time payment</div>
          </div>
        </div>
        <%= form_with url: purchase_presentation_path(params[:id]), method: :post, local: true, id: "direct-purchase-form" do |form| %>
          <%= form.hidden_field :purchase_type, value: 'direct' %>
          <%= form.submit "Purchase for #{@presentation.formatted_price}", class: "w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition", onclick: "console.log('Purchase button clicked'); console.log('Form action:', this.form.action); console.log('Form method:', this.form.method); return true;" %>
        <% end %>
      </div>
    <% else %>
      <!-- Not signed in -->
      <div class="text-center p-6 bg-gray-50 rounded-2xl">
        <p class="text-gray-600 mb-4">Please sign in to purchase this presentation</p>
        <%= link_to "Sign In", auth_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition" %>
      </div>
    <% end %>
