<div class="min-h-screen bg-whiskey-50 py-12 px-4 pt-28 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <!-- Back link -->
    <div class="mb-6">
      <%= link_to presentation_path(@presentation), class: "inline-flex items-center text-sm font-medium text-whiskey-700 hover:text-whiskey-600 transition" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to the deck
      <% end %>
    </div>

    <div class="overflow-hidden rounded-2xl border border-whiskey-200 bg-white shadow-sm">
      <!-- Header -->
      <div class="bg-char px-8 py-6">
        <p class="eyebrow text-whiskey-300/90"><%= @presentation.free? ? 'Free deck' : 'Get this deck' %></p>
        <h1 class="mt-1 font-display text-2xl font-semibold text-cream"><%= @presentation.title %></h1>
      </div>

      <!-- Deck summary -->
      <div class="border-b border-whiskey-100 px-8 py-5">
        <p class="text-gray-600"><%= @presentation.excerpt(140) %></p>
        <div class="mt-3 flex items-center gap-4 text-sm text-gray-500">
          <span><%= @presentation.reading_time %> min read</span>
          <% if @presentation.difficulty.present? %>
            <span aria-hidden="true">&middot;</span>
            <span><%= @presentation.difficulty %></span>
          <% end %>
          <% if @presentation.category.present? %>
            <span aria-hidden="true">&middot;</span>
            <span><%= @presentation.category %></span>
          <% end %>
        </div>
      </div>

      <div class="p-8">
        <% if @presentation.free? %>
          <%# ------------------------------------------------ Free deck %>
          <p class="text-gray-700">
            This deck is free for everyone. Add it to your library and it's yours for good —
            slides, script, and downloads included.
          </p>
          <%= form_with url: presentation_purchases_path(@presentation), local: true, data: { turbo: false } do |f| %>
            <%= f.submit "Add to my library — free",
                class: "mt-8 w-full cursor-pointer rounded-xl bg-whiskey-600 px-6 py-4 text-lg font-semibold text-white transition hover:bg-whiskey-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2" %>
          <% end %>
        <% else %>
          <%# --------------------------------------- Paid deck: pick a method %>
          <%= form_with url: presentation_purchases_path(@presentation), local: true, data: { turbo: false } do |f| %>
            <fieldset class="space-y-4">
              <legend class="sr-only">Purchase method</legend>

              <% if @can_use_credit %>
                <label class="block cursor-pointer">
                  <input type="radio" name="purchase_method" value="credit" class="peer sr-only" checked>
                  <div class="rounded-xl border-2 border-whiskey-100 p-6 transition hover:border-whiskey-300 peer-checked:border-whiskey-600 peer-checked:bg-whiskey-50 peer-focus-visible:ring-2 peer-focus-visible:ring-whiskey-500 peer-focus-visible:ring-offset-2">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <h3 class="text-lg font-semibold text-gray-900">Use a credit</h3>
                        <p class="mt-1 text-gray-600">You have <%= current_user.credits %> credit<%= 's' if current_user.credits != 1 %>. Access lasts as long as your membership.</p>
                      </div>
                      <div class="text-right shrink-0">
                        <span class="font-display text-2xl font-semibold text-whiskey-700">1 credit</span>
                        <p class="text-sm text-gray-500">No charge</p>
                      </div>
                    </div>
                  </div>
                </label>
              <% end %>

              <label class="block cursor-pointer">
                <input type="radio" name="purchase_method" value="direct" class="peer sr-only" <%= 'checked' unless @can_use_credit %>>
                <div class="rounded-xl border-2 border-whiskey-100 p-6 transition hover:border-whiskey-300 peer-checked:border-whiskey-600 peer-checked:bg-whiskey-50 peer-focus-visible:ring-2 peer-focus-visible:ring-whiskey-500 peer-focus-visible:ring-offset-2">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-lg font-semibold text-gray-900">Buy it outright</h3>
                      <p class="mt-1 text-gray-600">One-time payment. Yours for good, membership or not.</p>
                    </div>
                    <div class="text-right shrink-0">
                      <span class="font-display text-2xl font-semibold text-gray-900"><%= @presentation.formatted_price %></span>
                      <p class="text-sm text-gray-500">One-time</p>
                    </div>
                  </div>
                </div>
              </label>
            </fieldset>

            <% unless current_user.subscription_active? %>
              <div class="mt-6 rounded-xl border border-whiskey-200 bg-whiskey-50 p-5">
                <p class="text-sm text-whiskey-900">
                  <strong>Members get a deck credit every month</strong> — most months, that
                  makes the membership cheaper than one deck.
                  <%= link_to "See membership plans", root_path(anchor: "pricing"), class: "font-semibold underline underline-offset-2 hover:text-whiskey-700" %>
                </p>
              </div>
            <% end %>

            <%= f.submit "Continue", class: "mt-8 w-full cursor-pointer rounded-xl bg-whiskey-600 px-6 py-4 text-lg font-semibold text-white transition hover:bg-whiskey-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-whiskey-500 focus-visible:ring-offset-2" %>
          <% end %>

          <p class="mt-5 flex items-center justify-center gap-2 text-sm text-gray-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            Secure payment by Stripe — cards, Apple Pay, and more
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>
