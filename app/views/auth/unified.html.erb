<%# One narrow card, one decision at a time (the Notion/Linear/Slack pattern):
    providers, an "or", a single email field. The magic link IS the unified
    continue-with-email path (it creates-or-finds the account). Passwords are
    a secondary path behind a quiet toggle. %>
<%# Full-bleed page: clears the fixed nav itself (pt-24), beige spans the viewport. %>
<div class="min-h-screen bg-whiskey-50 flex items-center justify-center pt-24 pb-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md">
    <div class="bg-white shadow-lg rounded-2xl border border-whiskey-100 p-8 space-y-6">
      <!-- Header -->
      <div class="text-center">
        <h2 class="text-3xl font-bold text-gray-900 mb-2 font-display" data-auth-toggle-target="authTitle">Join the Society</h2>
        <p class="text-gray-600" data-auth-toggle-target="authSubtitle">Create your account</p>
      </div>

      <!-- Providers -->
      <div class="space-y-3">
        <% if google_sign_in_available? %>
          <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post,
              class: "w-full flex items-center justify-center px-4 py-3 border border-gray-300 rounded-xl shadow-sm bg-white text-gray-700 hover:bg-gray-50 cursor-pointer",
              form: { data: { turbo: false } } do %>
            <svg class="w-5 h-5 mr-3" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <span class="font-medium">Continue with Google</span>
          <% end %>
        <% elsif Rails.env.development? %>
          <div class="w-full flex items-center justify-center px-4 py-3 border border-dashed border-gray-300 rounded-xl bg-gray-50 text-gray-400 text-sm">
            Google sign-in hidden, set GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET in .env (see .env.example)
          </div>
        <% end %>

        <% if apple_sign_in_available? %>
          <%= button_to user_apple_omniauth_authorize_path, method: :post,
              class: "w-full flex items-center justify-center px-4 py-3 border border-gray-300 rounded-xl shadow-sm bg-black text-white hover:bg-gray-900 cursor-pointer",
              form: { data: { turbo: false } } do %>
            <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <span class="font-medium">Continue with Apple</span>
          <% end %>
        <% end %>
      </div>

      <!-- Divider -->
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500">or</span>
        </div>
      </div>

      <!-- Email (magic link: creates or finds the account) -->
      <div id="magic-link-form">
        <%= form_with url: magic_links_path, local: true, class: "space-y-3",
                      data: { turbo: "false" } do |f| %>
          <div>
            <label for="magic-link-email" class="sr-only">Email address</label>
            <%# text-center matches the centered button label below it. %>
            <input type="email" name="email" id="magic-link-email" required
                   class="appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 text-center rounded-xl focus:outline-none focus:ring-2 focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm"
                   placeholder="Enter your email">
          </div>
          <button type="submit"
                  class="w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-whiskey-600 hover:bg-whiskey-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-whiskey-500 transition">
            Send magic link
          </button>
        <% end %>
      </div>

      <!-- Password path, hidden until asked for. It reuses the email typed
           above: one lookup decides whether to ask for a password (existing
           account) or a name + password (new account). No second email box. -->
      <div class="text-center">
        <button type="button" id="password-toggle" onclick="togglePasswordForms()"
                class="text-sm text-gray-500 hover:text-whiskey-700 underline underline-offset-2 cursor-pointer">
          Use a password instead
        </button>
      </div>

      <div id="password-forms" class="hidden space-y-5">
        <p id="password-context" class="text-center text-sm text-gray-500"></p>

        <!-- Existing account: just the password -->
        <div id="password-signin" class="hidden">
          <%= form_for(User.new, as: :user, url: user_session_path,
              html: { class: "space-y-5" }) do |f| %>
            <%= f.hidden_field :email, id: "signin-email" %>
            <div>
              <%= f.label :password, class: "sr-only" %>
              <%= f.password_field :password, autocomplete: "current-password", id: "signin-password",
                  class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 text-center rounded-xl focus:outline-none focus:ring-2 focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm",
                  placeholder: "Enter your password" %>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <%= f.check_box :remember_me, class: "h-4 w-4 text-whiskey-600 focus:ring-whiskey-500 border-gray-300 rounded" %>
                <%= f.label :remember_me, class: "ml-2 block text-sm text-gray-900" %>
              </div>
              <%= link_to "Forgot password?", new_user_password_path,
                  class: "text-sm text-whiskey-600 hover:text-whiskey-500" %>
            </div>
            <div>
              <%= f.submit "Sign in",
                  class: "w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-whiskey-600 hover:bg-whiskey-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-whiskey-500 cursor-pointer" %>
            </div>
          <% end %>
        </div>

        <!-- New account: name + password -->
        <div id="password-signup" class="hidden">
          <%= form_for(User.new, as: :user, url: user_registration_path,
              html: { class: "space-y-5" }) do |f| %>
            <%= f.hidden_field :email, id: "signup-email" %>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.text_field :first_name, autocomplete: "given-name",
                    class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm",
                    placeholder: "First name" %>
              </div>
              <div>
                <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.text_field :last_name, autocomplete: "family-name",
                    class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm",
                    placeholder: "Last name" %>
              </div>
            </div>
            <div>
              <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.password_field :password, autocomplete: "new-password",
                  class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm",
                  placeholder: "Create a password (min 6 characters)" %>
            </div>
            <div>
              <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-whiskey-500 focus:border-whiskey-500 sm:text-sm",
                  placeholder: "Confirm your password" %>
            </div>
            <div>
              <%= f.submit "Create account",
                  class: "w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-whiskey-600 hover:bg-whiskey-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-whiskey-500 cursor-pointer" %>
            </div>
          <% end %>
          <div class="text-center mt-4">
            <p class="text-xs text-gray-500">
              By creating an account, you agree to our
              <%= link_to "Terms of Service", "#", class: "text-whiskey-600 hover:text-whiskey-500" %> and
              <%= link_to "Privacy Policy", "#", class: "text-whiskey-600 hover:text-whiskey-500" %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// The password path branches on one email lookup: existing account shows a
// password box, unknown email shows the name + password signup. The email
// comes from the magic-link field above; it is never asked for twice.
async function togglePasswordForms() {
  const forms = document.getElementById('password-forms');
  const toggle = document.getElementById('password-toggle');
  const emailInput = document.getElementById('magic-link-email');
  if (!forms || !emailInput) return;

  if (!forms.classList.contains('hidden')) {
    forms.classList.add('hidden');
    if (toggle) toggle.textContent = 'Use a password instead';
    return;
  }

  const email = emailInput.value.trim();
  if (!email || !emailInput.checkValidity()) {
    emailInput.focus();
    if (emailInput.reportValidity) emailInput.reportValidity();
    return;
  }

  await revealPasswordForm(email);
  if (toggle) toggle.textContent = 'Hide password sign-in';
}

async function revealPasswordForm(email) {
  const forms = document.getElementById('password-forms');
  const context = document.getElementById('password-context');
  const signin = document.getElementById('password-signin');
  const signup = document.getElementById('password-signup');
  let exists = false;
  try {
    const response = await fetch('/auth/email_check', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
      },
      body: JSON.stringify({ email: email })
    });
    exists = (await response.json()).exists;
  } catch (e) {
    if (context) context.textContent = 'Something went wrong checking that email. Try the magic link instead.';
    forms.classList.remove('hidden');
    signin.classList.add('hidden');
    signup.classList.add('hidden');
    return;
  }

  document.getElementById('signin-email').value = email;
  document.getElementById('signup-email').value = email;
  if (context) {
    context.textContent = exists ? ('Signing in as ' + email) : ('Creating an account for ' + email);
  }
  signin.classList.toggle('hidden', !exists);
  signup.classList.toggle('hidden', exists);
  forms.classList.remove('hidden');
  const focusTarget = exists
    ? document.getElementById('signin-password')
    : signup.querySelector('input[name="user[first_name]"]');
  if (focusTarget) focusTarget.focus();
}

// Editing the email while the password panel is open re-runs the branch.
document.addEventListener('DOMContentLoaded', function () {
  const emailInput = document.getElementById('magic-link-email');
  if (!emailInput) return;
  let debounce;
  emailInput.addEventListener('input', function () {
    const forms = document.getElementById('password-forms');
    if (!forms || forms.classList.contains('hidden')) return;
    clearTimeout(debounce);
    debounce = setTimeout(function () {
      const email = emailInput.value.trim();
      if (email && emailInput.checkValidity()) revealPasswordForm(email);
    }, 400);
  });
});
</script>
