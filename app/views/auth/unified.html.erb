<div class="min-h-screen bg-white flex items-center justify-center py-8 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-lg">
    <div class="bg-white shadow-lg rounded-2xl p-8 space-y-6 border border-gray-100 w-[32rem] flex flex-col">
    <!-- Header -->
    <div class="text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-2" data-auth-toggle-target="authTitle">Join the Society</h2>
      <p class="text-gray-600" data-auth-toggle-target="authSubtitle">Create your account</p>
    </div>

    <!-- OAuth Buttons -->
    <div class="space-y-4">
      <!-- Google Auth (only shown when Google OAuth is configured) -->
      <% if google_sign_in_available? %>
        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post,
            class: "w-full flex items-center justify-center px-4 py-3 border border-gray-300 rounded-xl shadow-sm bg-white text-gray-700 hover:bg-gray-50",
            form: { data: { turbo: false } } do %>
          <svg class="w-5 h-5 mr-3" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="font-medium">Continue with Google</span>
        <% end %>
      <% elsif Rails.env.development? %>
        <div class="w-full flex items-center justify-center px-4 py-3 border border-dashed border-gray-300 rounded-xl bg-gray-50 text-gray-400 text-sm">
          Google sign-in hidden — set GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET in .env (see .env.example)
        </div>
      <% end %>

      <!-- Apple Auth (only shown when Apple Sign In is configured) -->
      <% if apple_sign_in_available? %>
        <%= button_to user_apple_omniauth_authorize_path, method: :post,
            class: "w-full flex items-center justify-center px-4 py-3 border border-gray-300 rounded-xl shadow-sm bg-black text-white hover:bg-gray-900",
            form: { data: { turbo: false } } do %>
          <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <span class="font-medium">Continue with Apple</span>
        <% end %>
      <% end %>

      <!-- Magic Link Option -->
      <div class="text-center">
        <button type="button" onclick="showMagicLinkForm()"
            class="w-full flex items-center justify-center px-4 py-3 border border-amber-300 rounded-xl shadow-sm bg-amber-50 text-amber-700 hover:bg-amber-100">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          <span class="font-medium">Sign in with magic link</span>
        </button>
      </div>
      
      <!-- Magic Link Form (hidden by default) -->
      <div id="magic-link-form" class="hidden mt-6">
        <%= form_with url: magic_links_path, local: true, class: "space-y-4", 
                      data: { turbo: "false" },
                      onsubmit: "console.log('🔗 Magic link form submitted!'); return true;" do |f| %>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email address</label>
            <input type="email" name="email" id="magic-link-email" required
                   class="appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm"
                   placeholder="Enter your email">
          </div>
          <div>
            <button type="submit"
                    class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-gradient-to-r from-amber-600 to-orange-600 hover:from-amber-700 hover:to-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition-colors duration-200">
              Send magic link
            </button>
          </div>
        <% end %>
        <div class="text-center mt-4">
          <button type="button" onclick="hideMagicLinkForm()" class="text-sm text-gray-500 hover:text-gray-700">
            Back to other options
          </button>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="relative">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-gray-300"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="px-2 bg-white text-gray-500">or</span>
      </div>
    </div>

    <!-- Unified Form -->
    <div class="space-y-6">
      <!-- Mode Toggle -->
      <div class="relative flex bg-gray-100 rounded-xl p-1 overflow-hidden">
        <!-- Sliding background -->
        <div class="absolute top-1 bottom-1 w-1/2 bg-amber-600 rounded-lg shadow-sm transition-transform duration-300 ease-in-out" style="transform: translateX(100%);" id="slider"></div>
        
        <button type="button" class="relative z-10 flex-1 py-2 px-4 text-sm font-medium rounded-lg transition-colors duration-300" style="color: #374151;" id="signin-tab">
          Sign In
        </button>
        <button type="button" class="relative z-10 flex-1 py-2 px-4 text-sm font-medium rounded-lg transition-colors duration-300" style="color: white;" id="signup-tab">
          Sign Up
        </button>
      </div>

      <!-- Sign In Form -->
      <div id="signin-form" class="hidden transform transition-all duration-500 ease-in-out opacity-0 translate-x-4">
        <%= form_for(User.new, as: :user, url: user_session_path,
            html: { class: "space-y-6" }) do |f| %>

          <!-- Email Field -->
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.email_field :email, autocomplete: "email",
                class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
                placeholder: "Enter your email" %>
          </div>

          <!-- Password Field -->
          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
                placeholder: "Enter your password" %>
          </div>

          <!-- Remember Me -->
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "h-4 w-4 text-amber-600 focus:ring-amber-500 border-gray-300 rounded" %>
              <%= f.label :remember_me, class: "ml-2 block text-sm text-gray-900" %>
            </div>

            <%= link_to "Forgot password?", new_user_password_path,
                class: "text-sm text-amber-600 hover:text-amber-500" %>
          </div>

          <!-- Submit Button -->
          <div>
            <%= f.submit "Sign in",
                class: "w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-gradient-to-r from-amber-600 to-orange-600 hover:from-amber-700 hover:to-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500" %>
          </div>
        <% end %>
      </div>

      <!-- Sign Up Form -->
      <div id="signup-form" class="transform transition-all duration-500 ease-in-out opacity-100 translate-x-0">
        <%= form_for(User.new, as: :user, url: user_registration_path,
            html: { class: "space-y-6" }) do |f| %>

          <!-- First Name Field -->
          <div>
            <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.text_field :first_name, autocomplete: "given-name",
                class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
                placeholder: "Enter your first name" %>
          </div>

          <!-- Last Name Field -->
          <div>
            <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.text_field :last_name, autocomplete: "family-name",
                class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
                placeholder: "Enter your last name" %>
          </div>

          <!-- Email Field -->
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.email_field :email, autocomplete: "email",
                class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
                placeholder: "Enter your email" %>
          </div>

          <!-- Password Field -->
          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.password_field :password, autocomplete: "new-password",
                class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
                placeholder: "Create a password (min 6 characters)" %>
          </div>

          <!-- Password Confirmation Field -->
          <div>
            <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm",
                placeholder: "Confirm your password" %>
          </div>

          <!-- Submit Button -->
          <div>
            <%= f.submit "Create account",
                class: "w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-gradient-to-r from-amber-600 to-orange-600 hover:from-amber-700 hover:to-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500" %>
          </div>
        <% end %>

        <!-- Terms -->
        <div class="text-center">
          <p class="text-xs text-gray-500">
            By creating an account, you agree to our
            <%= link_to "Terms of Service", "#", class: "text-amber-600 hover:text-amber-500" %> and
            <%= link_to "Privacy Policy", "#", class: "text-amber-600 hover:text-amber-500" %>
          </p>
        </div>
      </div>
    </div>

    </div>
  </div>
</div>

<script>
function initializeAuthTabs() {
  const signupTab = document.getElementById('signup-tab');
  const signinTab = document.getElementById('signin-tab');
  const signupForm = document.getElementById('signup-form');
  const signinForm = document.getElementById('signin-form');
  const slider = document.getElementById('slider');
  
  if (!signupTab || !signinTab || !signupForm || !signinForm || !slider) {
    return; // Elements not found, exit
  }
  
  function showSignup() {
    // Slide the background to the right
    slider.style.transform = 'translateX(100%)';
    
    // Update button text colors using inline styles
    signupTab.style.color = 'white';
    signinTab.style.color = '#374151';
    
    // Animate forms with slide effect
    animateFormTransition('signup');
  }
  
  function showSignin() {
    // Slide the background to the left
    slider.style.transform = 'translateX(0%)';
    
    // Update button text colors using inline styles
    signinTab.style.color = 'white';
    signupTab.style.color = '#374151';
    
    // Animate forms with slide effect
    animateFormTransition('signin');
  }
  
  function animateFormTransition(targetForm) {
    if (targetForm === 'signin') {
      // Hide signup form with slide out animation
      signupForm.classList.add('opacity-0', 'translate-x-4');
      signupForm.classList.remove('opacity-100', 'translate-x-0');
      
      setTimeout(() => {
        signupForm.classList.add('hidden');
        signinForm.classList.remove('hidden');
        
        // Small delay to ensure DOM update, then animate in
        requestAnimationFrame(() => {
          signinForm.classList.remove('opacity-0', 'translate-x-4');
          signinForm.classList.add('opacity-100', 'translate-x-0');
        });
      }, 250); // Half the transition duration
    } else {
      // Hide signin form with slide out animation
      signinForm.classList.add('opacity-0', 'translate-x-4');
      signinForm.classList.remove('opacity-100', 'translate-x-0');
      
      setTimeout(() => {
        signinForm.classList.add('hidden');
        signupForm.classList.remove('hidden');
        
        // Small delay to ensure DOM update, then animate in
        requestAnimationFrame(() => {
          signupForm.classList.remove('opacity-0', 'translate-x-4');
          signupForm.classList.add('opacity-100', 'translate-x-0');
        });
      }, 250); // Half the transition duration
    }
  }
  
  // Remove existing event listeners to avoid duplicates
  signupTab.removeEventListener('click', showSignup);
  signinTab.removeEventListener('click', showSignin);
  
  // Add event listeners
  signupTab.addEventListener('click', showSignup);
  signinTab.addEventListener('click', showSignin);
  
  // Initialize to signup by default
  showSignup();
}

// Magic Link Form Functions
function showMagicLinkForm() {
  const magicLinkForm = document.getElementById('magic-link-form');
  if (magicLinkForm) {
    magicLinkForm.classList.remove('hidden');
    // Focus on the email input
    const emailInput = document.getElementById('magic-link-email');
    if (emailInput) {
      emailInput.focus();
    }
  }
}

function hideMagicLinkForm() {
  const magicLinkForm = document.getElementById('magic-link-form');
  if (magicLinkForm) {
    magicLinkForm.classList.add('hidden');
  }
}

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', initializeAuthTabs);

// Initialize on Turbo visits (for navigation)
document.addEventListener('turbo:visit', initializeAuthTabs);
document.addEventListener('turbo:render', initializeAuthTabs);
</script>

