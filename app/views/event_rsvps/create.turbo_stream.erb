<%# The segmented control is deliberately NOT streamed: re-rendering it tore
    the sliding indicator out mid-transition. Only the note is server-owned. %>
<%= turbo_stream.replace "rsvp-note-region" do %>
  <%= render partial: "events/rsvp_note", locals: { event: @event, user_rsvp: @rsvp } %>
<% end %>

<%= turbo_stream.replace "header-rsvp-count" do %>
  <%= render partial: "events/header_rsvp_count", locals: { event: @event } %>
<% end %>

<%= turbo_stream.replace "event-attendees" do %>
  <%= render partial: "events/attendees", locals: { event: @event } %>
<% end %>

<%= turbo_stream.replace "event-stats" do %>
  <%= render partial: "events/stats", locals: { event: @event } %>
<% end %>

<%= turbo_stream.update "flash-messages" do %>
  <!-- Clear any existing flash messages -->
<% end %>