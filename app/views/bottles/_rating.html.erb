<%# locals: value (Float, arbitrary precision, or nil) %>
<% if value %>
  <% snapped = [[(value * 2).round / 2.0, 0.5].max, 5.0].min %>
  <span class="whitespace-nowrap text-whiskey-600" aria-label="<%= value %> out of 5">
    <%= "★" * snapped.floor %><%= "½" if snapped % 1 == 0.5 %><span class="text-whiskey-200"><%= "★" * (5 - snapped.ceil) %></span>
  </span>
<% else %>
  <span class="text-sm text-gray-400">No tastings yet</span>
<% end %>
