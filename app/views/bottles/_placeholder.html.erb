<%# locals: bottle, size (tailwind h-* class), the designed stand-in until a
    label photo exists (images phase): a linework bottle, tinted by style. %>
<% tint = case bottle.style.to_s.downcase
   when /bourbon|rye/ then "#a05c28"
   when /scotch|malt|peat/ then "#6b5744"
   when /irish/ then "#7a8a4f"
   when /cocktail/ then "#b0563a"
   else "#8a6b4f"
   end %>
<svg viewBox="0 0 60 120" class="<%= local_assigns.fetch(:size, 'h-24') %> w-auto" role="img" aria-label="<%= bottle.name %>">
  <g fill="none" stroke="<%= tint %>" stroke-width="2.5" stroke-linejoin="round">
    <path d="M25 8 h10 v6 h-10 z" fill="<%= tint %>" fill-opacity="0.9"/>
    <path d="M26 14 v18 c0 6 -9 8 -9 18 v58 a4 4 0 0 0 4 4 h18 a4 4 0 0 0 4 -4 v-58 c0 -10 -9 -12 -9 -18 v-18"/>
    <rect x="21" y="62" width="18" height="26" rx="2" fill="<%= tint %>" fill-opacity="0.16"/>
    <line x1="24" y1="70" x2="36" y2="70" stroke-width="1.5" stroke-opacity="0.7"/>
    <line x1="24" y1="76" x2="34" y2="76" stroke-width="1.5" stroke-opacity="0.45"/>
  </g>
</svg>
