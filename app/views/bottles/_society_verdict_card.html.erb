<%# A society's collective take on this bottle, shaped like any tasting
    card, but the author is the room: aggregate score plus the most common
    tasting words across the members' reviews. Clicking through opens the
    verdict page with every individual card.
    locals: society (with verdict_avg/verdict_reviewers), bottle, reviews %>
<article class="rounded-2xl border-2 border-whiskey-200 bg-white p-6 shadow-sm">
  <p class="eyebrow mb-2 flex items-center gap-1.5 text-whiskey-600">
    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"></path>
    </svg>
    Society verdict
  </p>
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <span><%= link_to society.name, society_path(society), class: "font-semibold text-gray-900 hover:text-whiskey-700" %> <%= render "shared/century_badge", record: society %></span>
    <span class="flex items-center gap-2 whitespace-nowrap">
      <span class="font-semibold text-gray-900"><%= number_with_precision(society.verdict_avg, precision: 2, strip_insignificant_zeros: true) %></span>
      <%= render "bottles/rating", value: society.verdict_avg.to_f %>
    </span>
  </div>

  <% sections = Review.common_descriptors(reviews) %>
  <% wheel = Review.blended_wheel(reviews) %>
  <% if sections.any? || wheel.any? %>
    <div class="mt-4 grid items-start gap-6 border-t border-gray-100 pt-4 <%= 'sm:grid-cols-[1fr_11rem]' if sections.any? && wheel.any? %>">
      <% if sections.any? %>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-3">
          <% sections.each do |label, words| %>
            <div><dt class="eyebrow text-whiskey-700"><%= label %></dt><dd class="mt-1 text-sm text-gray-600"><%= words.join(", ").capitalize %></dd></div>
          <% end %>
        </dl>
      <% end %>
      <% if wheel.any? %>
        <%= render "reviews/palate_wheel", profile: wheel %>
      <% end %>
    </div>
  <% end %>

  <div class="mt-3 flex items-center justify-between">
    <p class="text-sm text-gray-400"><%= pluralize(society.verdict_reviewers, "taster") %> at their nights</p>
    <%= link_to "Read the tastings →", verdict_bottle_path(bottle, society_id: society.id), class: "text-sm font-semibold text-whiskey-700 hover:text-whiskey-600" %>
  </div>
</article>
