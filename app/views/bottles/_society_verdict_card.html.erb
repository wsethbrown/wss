<%# A society's collective take on this bottle — sits in the Tastings list
    like any review card, marked as the room's verdict rather than one
    member's. Expanding shows the individual event reviews, each linking
    through to the taster's profile.
    locals: society (with verdict_avg/verdict_reviewers), reviews %>
<article class="rounded-2xl border-2 border-whiskey-200 bg-white p-6 shadow-sm">
  <p class="eyebrow mb-2 flex items-center gap-1.5 text-whiskey-600">
    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"></path>
    </svg>
    Society verdict
  </p>
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <span><%= link_to society.name, society_path(society), class: "font-display text-lg font-semibold text-gray-900 hover:text-whiskey-700" %> <%= render "shared/century_badge", record: society %></span>
    <span class="flex items-center gap-2 whitespace-nowrap">
      <span class="font-semibold text-gray-900"><%= number_with_precision(society.verdict_avg, precision: 2, strip_insignificant_zeros: true) %></span>
      <%= render "bottles/rating", value: society.verdict_avg.to_f %>
    </span>
  </div>
  <p class="mt-1 text-sm text-gray-500"><%= pluralize(society.verdict_reviewers, "taster") %> at their nights</p>

  <% if reviews.any? %>
    <details class="mt-3 border-t border-gray-100 pt-3">
      <summary class="cursor-pointer text-sm font-semibold text-whiskey-700 hover:text-whiskey-600">The individual pours</summary>
      <div class="mt-3 space-y-3">
        <% reviews.each do |review| %>
          <div class="rounded-lg bg-whiskey-50 p-3">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <span class="text-sm font-semibold"><%= link_to "#{review.user.first_name} #{review.user.last_name}", profile_path(review.user), class: "text-gray-900 hover:text-whiskey-700" %> <%= render "shared/century_badge", record: review.user %></span>
              <%= render "bottles/rating", value: review.rating.to_f %>
            </div>
            <p class="mt-0.5 text-xs text-gray-400"><%= review.event.title %></p>
            <% if review.notes.present? %><p class="mt-1 text-sm text-gray-600"><%= review.notes %></p><% end %>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>
</article>
