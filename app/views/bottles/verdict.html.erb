<% content_for :title, "#{@society.name} on #{@bottle.name} - Whiskey Share Society" %>
<%# The drill-in behind a society verdict card: the aggregate as the
    masthead, every member's tasting card below. %>

<section class="w-full bg-char px-4 pb-10 pt-24">
  <div class="mx-auto max-w-2xl text-center">
    <p class="eyebrow mb-3 text-whiskey-300/90">Society verdict</p>
    <h1 class="font-display text-3xl font-semibold text-cream sm:text-4xl">
      <%= link_to @society.name, society_path(@society), class: "transition hover:text-whiskey-200" %>
      <span class="text-cream/60">on</span>
      <%= link_to @bottle.name, bottle_path(@bottle), class: "transition hover:text-whiskey-200" %>
    </h1>
    <div class="mt-5 flex items-center justify-center gap-3 text-xl">
      <%= render "bottles/rating", value: @verdict.verdict_avg.to_f %>
      <span class="font-semibold text-cream"><%= number_with_precision(@verdict.verdict_avg, precision: 2, strip_insignificant_zeros: true) %></span>
    </div>
    <p class="mt-3 text-cream/70"><%= pluralize(@verdict.verdict_reviewers, "taster") %> at their nights</p>
  </div>
</section>

<section class="w-full bg-whiskey-50 px-4 py-12">
  <div class="mx-auto max-w-2xl space-y-6">
    <%= render partial: "bottles/tasting_card", collection: @reviews, as: :review %>
  </div>
</section>
