<%= render "mailers/layout_open" %>
      <h2 style="margin-top:0;">Your sign-in link<%= @user.first_name.present? ? ", #{@user.first_name}" : "" %></h2>
      <p>Click the button and you're in. No password needed.</p>
      <a class="btn" href="<%= @magic_link_url %>">Sign in to Whiskey Share Society</a>
      <p class="meta" style="margin-top: 20px;">The link works once and expires in 15 minutes. If you didn't request it, ignore this email and nothing happens.</p>
<%= render "mailers/layout_close" %>
