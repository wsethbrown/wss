<%= render "mailers/layout_open" %>
      <h2 style="margin-top:0;">Confirm your new email</h2>
      <p>You asked to change your Whiskey Share Society email to <strong><%= @new_email %></strong>. Confirm it below.</p>
      <a class="btn" href="<%= @verification_url %>">Confirm this email</a>
      <p class="meta" style="margin-top: 20px;">If you didn't request this change, ignore this email and your address stays as it is.</p>
<%= render "mailers/layout_close" %>
