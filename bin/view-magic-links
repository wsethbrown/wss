#!/usr/bin/env ruby

# Get the project root directory
project_root = File.expand_path('..', __dir__)
mail_dir = File.join(project_root, 'tmp/mail')

unless Dir.exist?(mail_dir)
  puts "❌ No mail directory found at #{mail_dir}"
  exit 1
end

email_files = Dir.glob("#{mail_dir}/*").sort_by { |f| File.mtime(f) }.reverse

if email_files.empty?
  puts "📭 No emails found in #{mail_dir}"
  exit 0
end

puts "📧 MAGIC LINK EMAILS (most recent first)"
puts "=" * 50

email_files.each_with_index do |file, index|
  email = File.basename(file)
  mtime = File.mtime(file).strftime("%Y-%m-%d %H:%M:%S")
  
  puts "\n#{index + 1}. #{email} (#{mtime})"
  
  # Extract magic link URLs from the email
  content = File.read(file)
  magic_links = content.scan(/https:\/\/[^\s<>"]+\/magic_links\/[A-Za-z0-9_-]+/)
  
  magic_links.uniq.each do |link|
    puts "   🔗 #{link}"
  end
end

puts "\n" + "=" * 50
puts "💡 To view full email content: cat '#{email_files.first}'"