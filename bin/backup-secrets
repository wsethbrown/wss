#!/usr/bin/env bash
set -euo pipefail
# Weekly secrets snapshot: encrypts the un-recoverable WSS keys into
# ~/Documents/WSS-Backups (iCloud carries the encrypted blob off-machine).
#
# What's covered: config/master.key (Rails credentials) and
# ~/.wss-production.env (AR 2FA-encryption keys, DB password, API tokens).
# Losing these means losing users' 2FA and re-provisioning every service.
#
# Passphrase: macOS Keychain item "wss-secrets-backup" (created on first
# run). ALSO store it in your password manager — the Keychain copy dies
# with the machine; the password-manager copy is the disaster-recovery one:
#   security find-generic-password -s wss-secrets-backup -w

REPO="$(cd "$(dirname "$0")/.." && pwd)"
DEST="$HOME/Documents/WSS-Backups"
KEYCHAIN_ITEM="wss-secrets-backup"
KEEP=8

FILES=()
[ -f "$REPO/config/master.key" ] && FILES+=("$REPO/config/master.key")
[ -f "$HOME/.wss-production.env" ] && FILES+=("$HOME/.wss-production.env")
if [ "${#FILES[@]}" -eq 0 ]; then
  echo "ERROR: nothing to back up — neither master.key nor .wss-production.env found" >&2
  exit 1
fi

# Passphrase from Keychain; generate one on first run (never printed here).
if ! PASS=$(security find-generic-password -s "$KEYCHAIN_ITEM" -w 2>/dev/null); then
  PASS=$(openssl rand -base64 32)
  security add-generic-password -a "$USER" -s "$KEYCHAIN_ITEM" -w "$PASS"
  echo "NOTE: created new Keychain passphrase '$KEYCHAIN_ITEM'."
  echo "      Run: security find-generic-password -s $KEYCHAIN_ITEM -w"
  echo "      and store the result in your password manager NOW."
fi

export PASS
mkdir -p "$DEST"
STAMP=$(date +%Y%m%d_%H%M%S)
OUT="$DEST/wss-secrets-$STAMP.tar.enc"

tar -czf - -C / "${FILES[@]/#\//}" \
  | openssl enc -aes-256-cbc -pbkdf2 -salt -pass env:PASS -out "$OUT" \
  || { rm -f "$OUT"; echo "ERROR: encryption failed" >&2; exit 1; }

# Prove the archive decrypts before trusting it.
openssl enc -d -aes-256-cbc -pbkdf2 -pass env:PASS -in "$OUT" | tar -tzf - >/dev/null \
  || { echo "ERROR: verification decrypt failed for $OUT" >&2; exit 1; }

# Keep the newest $KEEP snapshots.
ls -1t "$DEST"/wss-secrets-*.tar.enc 2>/dev/null | tail -n +$((KEEP + 1)) | xargs -I{} rm -f {}

echo "OK: $(basename "$OUT") ($(du -h "$OUT" | cut -f1 | xargs)) — verified decryptable; $(ls -1 "$DEST"/wss-secrets-*.tar.enc | wc -l | xargs) snapshots kept"
