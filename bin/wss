#!/usr/bin/env bash
set -e

# Whiskey Share Society CLI Tool
# Usage: ./bin/wss [command] [options]

PROJECT_NAME="Whiskey Share Society"
DOCKER_COMPOSE_FILE="docker-compose.yml"
SERVICES="web db redis"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

show_help() {
    cat << EOF
${GREEN}🥃 Whiskey Share Society - Development CLI${NC}

${YELLOW}Usage:${NC}
  wss [command] [options]

${YELLOW}Commands:${NC}
  ${GREEN}start${NC}             Start all services with HTTPS + Stripe webhooks (Docker preferred, falls back to native Rails)
  ${GREEN}stop${NC}              Stop all services and Stripe webhooks  
  ${GREEN}restart${NC}           Restart all services and Stripe webhooks
  ${GREEN}build${NC}             Build/rebuild Docker images
  ${GREEN}logs${NC} [service]    Show logs (optionally for specific service)
  ${GREEN}shell${NC}             Open Rails console in container
  ${GREEN}bash${NC}              Open bash shell in web container
  ${GREEN}db${NC}                Database operations
  ${GREEN}test${NC}              Run test suite
  ${GREEN}setup${NC}             Initial setup (build, migrate, seed)
  ${GREEN}clean${NC}             Clean up containers and volumes
  ${GREEN}status${NC}            Show service status + Stripe webhooks
  ${GREEN}help${NC}              Show this help message

${YELLOW}Database Commands:${NC}
  wss db migrate         Run database migrations
  wss db seed            Seed database with sample data
  wss db reset           Reset database (drop, create, migrate, seed)
  wss db console         Open database console

${YELLOW}Examples:${NC}
  wss start              # Start all services
  wss logs web           # Show web service logs
  wss logs -f            # Follow all logs
  wss db migrate         # Run migrations
  wss shell              # Open Rails console

${YELLOW}OAuth Testing:${NC}
  Both Google and Apple OAuth are supported via HTTPS

${YELLOW}Stripe Integration:${NC}
  Webhook forwarding starts automatically with 'wss start'
  Subscription changes sync automatically from Stripe
  View webhook logs: tail -f stripe-webhooks.log
  
${BLUE}Visit:${NC} https://dev.whiskeysharesociety.com:3000 (HTTPS only)
EOF
}

check_docker() {
    if ! command -v docker &> /dev/null; then
        log_warning "Docker is not installed or not in PATH"
        return 1
    fi
    
    if ! command -v docker-compose &> /dev/null; then
        log_warning "Docker Compose is not installed or not in PATH"
        return 1
    fi
    
    # Check if Docker daemon is running
    if ! docker info &> /dev/null; then
        log_warning "Docker daemon is not running"
        return 1
    fi
    
    return 0
}

check_env_file() {
    if [[ ! -f .env ]]; then
        log_warning ".env file not found. OAuth may not work properly."
        log_info "Copy .env.example to .env and configure your OAuth credentials"
    fi
}

check_stripe_cli() {
    if ! command -v stripe &> /dev/null; then
        log_warning "Stripe CLI not found. Install with: brew install stripe/stripe-cli/stripe"
        return 1
    fi
    return 0
}

start_stripe_webhooks() {
    if check_stripe_cli; then
        log_info "Starting Stripe webhook forwarding..."
        
        # Check if stripe CLI is already running for webhooks
        if pgrep -f "stripe listen" > /dev/null; then
            log_warning "Stripe webhook forwarding already running"
            return 0
        fi
        
        # Start stripe webhooks in background
        nohup stripe listen --forward-to https://dev.whiskeysharesociety.com:3000/webhooks/stripe \
            > stripe-webhooks.log 2>&1 &
        
        local stripe_pid=$!
        echo $stripe_pid > .stripe_pid
        
        # Give it a moment to start
        sleep 2
        
        if ps -p $stripe_pid > /dev/null; then
            log_success "Stripe webhook forwarding started (PID: $stripe_pid)"
            log_info "Webhook events will be logged to: stripe-webhooks.log"
        else
            log_error "Failed to start Stripe webhook forwarding"
            return 1
        fi
    else
        log_info "Skipping Stripe webhook forwarding (CLI not installed)"
    fi
}

stop_stripe_webhooks() {
    if [[ -f .stripe_pid ]]; then
        local stripe_pid=$(cat .stripe_pid)
        if ps -p $stripe_pid > /dev/null; then
            log_info "Stopping Stripe webhook forwarding (PID: $stripe_pid)..."
            kill $stripe_pid
            log_success "Stripe webhook forwarding stopped"
        fi
        rm -f .stripe_pid
    fi
}

start_services_native() {
    log_info "Starting ${PROJECT_NAME} with native Rails..."
    check_env_file
    
    # Check for SSL certificates (required for HTTPS-only mode)
    if [[ ! -f "dev-cert.pem" ]] || [[ ! -f "dev-key.pem" ]]; then
        log_warning "SSL certificates not found. Generating..."
        openssl req -x509 -newkey rsa:2048 -keyout dev-key.pem -out dev-cert.pem -days 365 -nodes \
            -subj "/C=US/ST=Georgia/L=Athens/O=WSS Ltd/CN=dev.whiskeysharesociety.com"
        log_success "SSL certificates generated"
    fi
    
    # Check if Rails is available
    if ! command -v rails &> /dev/null; then
        log_error "Rails not found. Please install Rails or use Docker mode."
        exit 1
    fi
    
    # Check if bin/dev exists (Foreman)
    if [[ -f "bin/dev" ]]; then
        log_info "Starting Rails with Foreman (bin/dev)..."
        nohup bin/dev > rails-server.log 2>&1 &
        local rails_pid=$!
        echo $rails_pid > .rails_pid
        log_success "Rails server started (PID: $rails_pid)"
        log_info "Server logs: tail -f rails-server.log"
    else
        log_info "Starting Rails server directly..."
        nohup rails server > rails-server.log 2>&1 &
        local rails_pid=$!
        echo $rails_pid > .rails_pid
        log_success "Rails server started (PID: $rails_pid)"
        log_info "Server logs: tail -f rails-server.log"
    fi
    
    # Start Stripe webhook forwarding
    start_stripe_webhooks
    
    log_success "Development server started!"
    log_info "Visit https://localhost:3000 or https://dev.whiskeysharesociety.com:3000"
    
    if check_stripe_cli; then
        log_info "💳 Stripe webhooks: Subscription changes will auto-sync"
    fi
}

start_services() {
    log_info "Starting ${PROJECT_NAME}..."
    check_env_file
    
    # Check for SSL certificates (required for HTTPS-only mode)
    if [[ ! -f "dev-cert.pem" ]] || [[ ! -f "dev-key.pem" ]]; then
        log_warning "SSL certificates not found. Generating..."
        openssl req -x509 -newkey rsa:2048 -keyout dev-key.pem -out dev-cert.pem -days 365 -nodes \
            -subj "/C=US/ST=Georgia/L=Athens/O=WSS Ltd/CN=dev.whiskeysharesociety.com"
        log_success "SSL certificates generated"
    fi
    
    docker-compose up -d
    
    # Wait a moment for services to start
    sleep 3
    
    # Start Stripe webhook forwarding
    start_stripe_webhooks
    
    log_success "Services started with HTTPS!"
    log_info "Visit https://dev.whiskeysharesociety.com:3000 (accept SSL warning)"
    
    if check_stripe_cli; then
        log_info "💳 Stripe webhooks: Subscription changes will auto-sync"
    fi
}


stop_services_native() {
    log_info "Stopping ${PROJECT_NAME} (native Rails)..."
    
    # Stop Stripe webhook forwarding first
    stop_stripe_webhooks
    
    # Stop Rails server
    if [[ -f .rails_pid ]]; then
        local rails_pid=$(cat .rails_pid)
        if ps -p $rails_pid > /dev/null; then
            log_info "Stopping Rails server (PID: $rails_pid)..."
            kill $rails_pid
            log_success "Rails server stopped"
        fi
        rm -f .rails_pid
    else
        log_warning "No Rails PID file found. Trying to kill by process name..."
        pkill -f "bin/dev\|rails server" || true
    fi
    
    log_success "Services stopped"
}

stop_services() {
    log_info "Stopping ${PROJECT_NAME}..."
    
    # Stop Stripe webhook forwarding first
    stop_stripe_webhooks
    
    docker-compose down
    log_success "Services stopped"
}

restart_services() {
    log_info "Restarting ${PROJECT_NAME}..."
    
    # Stop Stripe webhooks
    stop_stripe_webhooks
    
    docker-compose restart
    
    # Wait for services to restart
    sleep 3
    
    # Restart Stripe webhooks
    start_stripe_webhooks
    
    log_success "Services restarted"
    
    if check_stripe_cli; then
        log_info "💳 Stripe webhooks: Subscription changes will auto-sync"
    fi
}

build_images() {
    log_info "Building Docker images..."
    docker-compose build --no-cache
    log_success "Images built successfully"
}

show_logs() {
    if [[ -n "$2" ]]; then
        # Show logs for specific service
        docker-compose logs -f "$2"
    else
        # Show logs for all services
        docker-compose logs "${@:2}"
    fi
}

open_shell() {
    log_info "Opening Rails console..."
    docker-compose exec web rails console
}

open_bash() {
    log_info "Opening bash shell in web container..."
    docker-compose exec web bash
}

run_tests() {
    log_info "Running test suite..."
    docker-compose exec web rails test
}

db_operations() {
    case "$2" in
        migrate)
            log_info "Running database migrations..."
            docker-compose exec web rails db:migrate
            ;;
        seed)
            log_info "Seeding database..."
            docker-compose exec web rails db:seed
            ;;
        reset)
            log_info "Resetting database..."
            docker-compose exec web rails db:reset
            ;;
        console)
            log_info "Opening database console..."
            docker-compose exec web rails db
            ;;
        *)
            log_error "Unknown database command: $2"
            log_info "Available: migrate, seed, reset, console"
            exit 1
            ;;
    esac
}

setup_project() {
    log_info "Setting up ${PROJECT_NAME} for development..."
    
    # Build images
    log_info "Building Docker images..."
    docker-compose build
    
    # Start services
    log_info "Starting services..."
    docker-compose up -d
    
    # Wait for database
    log_info "Waiting for database to be ready..."
    sleep 10
    
    # Setup database
    log_info "Setting up database..."
    docker-compose exec web rails db:create db:migrate db:seed
    
    log_success "Setup complete! Visit http://localhost:3000"
}

clean_docker() {
    log_warning "This will remove all containers and volumes. Are you sure? (y/N)"
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
        log_info "Cleaning up Docker containers and volumes..."
        docker-compose down -v --remove-orphans
        docker system prune -f
        log_success "Cleanup complete"
    else
        log_info "Cleanup cancelled"
    fi
}

show_status() {
    log_info "Service status:"
    
    if check_docker; then
        docker-compose ps
    else
        # Check native Rails status
        if [[ -f .rails_pid ]]; then
            local rails_pid=$(cat .rails_pid)
            if ps -p $rails_pid > /dev/null; then
                echo -e "${GREEN}✓${NC} Rails server running (PID: $rails_pid)"
                echo -e "${BLUE}📄${NC} Server logs: tail -f rails-server.log"
            else
                echo -e "${RED}✗${NC} Rails server not running (stale PID file)"
                rm -f .rails_pid
            fi
        else
            if pgrep -f "bin/dev\|rails server" > /dev/null; then
                echo -e "${YELLOW}⚠${NC} Rails process running but not managed by wss"
            else
                echo -e "${RED}✗${NC} Rails server not running"
            fi
        fi
    fi
    
    echo ""
    log_info "Stripe webhook status:"
    if [[ -f .stripe_pid ]]; then
        local stripe_pid=$(cat .stripe_pid)
        if ps -p $stripe_pid > /dev/null; then
            echo -e "${GREEN}✓${NC} Stripe webhook forwarding running (PID: $stripe_pid)"
            echo -e "${BLUE}📄${NC} Logs: tail -f stripe-webhooks.log"
        else
            echo -e "${RED}✗${NC} Stripe webhook forwarding not running (stale PID file)"
            rm -f .stripe_pid
        fi
    else
        if pgrep -f "stripe listen" > /dev/null; then
            echo -e "${YELLOW}⚠${NC} Stripe CLI running but not managed by wss"
        else
            echo -e "${RED}✗${NC} Stripe webhook forwarding not running"
        fi
    fi
}

# Main command handler
case "$1" in
    start)
        if check_docker; then
            start_services
        else
            log_warning "Docker not available, falling back to native Rails development..."
            start_services_native
        fi
        ;;
    stop)
        if check_docker; then
            stop_services
        else
            stop_services_native
        fi
        ;;
    restart)
        if check_docker; then
            restart_services
        else
            log_info "Restarting native Rails..."
            stop_services_native
            sleep 2
            start_services_native
        fi
        ;;
    build)
        check_docker
        build_images
        ;;
    logs)
        check_docker
        show_logs "$@"
        ;;
    shell)
        check_docker
        open_shell
        ;;
    bash)
        check_docker
        open_bash
        ;;
    test)
        check_docker
        run_tests
        ;;
    db)
        check_docker
        db_operations "$@"
        ;;
    setup)
        check_docker
        setup_project
        ;;
    clean)
        check_docker
        clean_docker
        ;;
    status)
        show_status
        ;;
    help|--help|-h)
        show_help
        ;;
    "")
        log_error "No command specified"
        show_help
        exit 1
        ;;
    *)
        log_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac